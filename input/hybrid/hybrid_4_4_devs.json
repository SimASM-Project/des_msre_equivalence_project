{
  "model_name": "hybrid_4_4_devs",
  "description": "Hybrid 4x4-Queue using DEVS formalism - 4 tandem stations, 4 fork-join branches, feedback p=0.5",
  "entities": {
    "Load": {
      "name": "Load",
      "parent": "Object",
      "attributes": {
        "arrival_time": "Real",
        "departure_time": "Real"
      }
    }
  },
  "parameters": {
    "service_capacity": {
      "type": "Nat",
      "value": 1,
      "description": "Number of servers per station"
    },
    "iat_mean": {
      "type": "Real",
      "value": 1.25,
      "description": "Inter-arrival time mean"
    },
    "ist_mean": {
      "type": "Real",
      "value": 1.0,
      "description": "Service time mean per station"
    },
    "feedback_prob": {
      "type": "Real",
      "value": 0.5,
      "description": "Probability of feedback to station 1"
    },
    "sim_end_time": {
      "type": "Real",
      "value": 10000.0,
      "description": "Simulation end time"
    }
  },
  "random_streams": {
    "interarrival_time": {
      "distribution": "exponential",
      "params": {
        "mean": "iat_mean"
      },
      "stream_name": "arrivals"
    },
    "service_time_Server_1": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "service_1"
    },
    "service_time_Server_2": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "service_2"
    },
    "service_time_Server_3": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "service_3"
    },
    "service_time_Server_4": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "service_4"
    },
    "service_time_Branch_1": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "branch_service_1"
    },
    "service_time_Branch_2": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "branch_service_2"
    },
    "service_time_Branch_3": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "branch_service_3"
    },
    "service_time_Branch_4": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "branch_service_4"
    }
  },
  "atomic_models": [
    {
      "name": "Generator",
      "description": "Job generator (source)",
      "inputs": [],
      "outputs": [
        "out"
      ],
      "states": [
        {
          "name": "active",
          "time_advance": "interarrival_time"
        }
      ],
      "initial_state": "active",
      "state_variables": {
        "job_count": {
          "type": "Nat",
          "initial": 0
        }
      },
      "internal_transitions": [
        {
          "from": "active",
          "to": "active",
          "state_change": "job_count := job_count + 1"
        }
      ],
      "external_transitions": [],
      "output_function": [
        {
          "state": "active",
          "output_port": "out",
          "value": "job"
        }
      ]
    },
    {
      "name": "Server_1",
      "description": "Single-server queue-processor: Server_1",
      "inputs": [
        "in"
      ],
      "outputs": [
        "out"
      ],
      "states": [
        {
          "name": "passive",
          "time_advance": "infinity"
        },
        {
          "name": "starting",
          "time_advance": 0
        },
        {
          "name": "busy",
          "time_advance": "service_time_Server_1"
        }
      ],
      "initial_state": "passive",
      "state_variables": {
        "queue_count": {
          "type": "Nat",
          "initial": 0
        },
        "server_count": {
          "type": "Nat",
          "initial": 0
        }
      },
      "internal_transitions": [
        {
          "from": "starting",
          "to": "busy",
          "state_change": "queue_count := queue_count - 1; server_count := server_count + 1"
        },
        {
          "from": "busy",
          "to": "starting",
          "condition": "queue_count > 0",
          "state_change": "server_count := server_count - 1"
        },
        {
          "from": "busy",
          "to": "passive",
          "condition": "queue_count == 0",
          "state_change": "server_count := server_count - 1"
        }
      ],
      "external_transitions": [
        {
          "from": "passive",
          "input_port": "in",
          "to": "starting",
          "state_change": "queue_count := queue_count + 1"
        },
        {
          "from": "starting",
          "input_port": "in",
          "to": "starting",
          "state_change": "queue_count := queue_count + 1"
        },
        {
          "from": "busy",
          "input_port": "in",
          "to": "busy",
          "state_change": "queue_count := queue_count + 1"
        }
      ],
      "output_function": [
        {
          "state": "busy",
          "output_port": "out",
          "value": "job"
        }
      ]
    },
