    {
      "name": "Joiner",
      "description": "Join: synchronize 4 parallel branches",
      "inputs": [
        "in_1",
        "in_2",
        "in_3",
        "in_4"
      ],
      "outputs": [
        "out"
      ],
      "states": [
        {
          "name": "idle",
          "time_advance": "infinity"
        },
        {
          "name": "checking",
          "time_advance": 0
        },
        {
          "name": "joining",
          "time_advance": 0
        }
      ],
      "initial_state": "idle",
      "state_variables": {
        "part_1_count": {
          "type": "Nat",
          "initial": 0
        },
        "part_2_count": {
          "type": "Nat",
          "initial": 0
        },
        "part_3_count": {
          "type": "Nat",
          "initial": 0
        },
        "part_4_count": {
          "type": "Nat",
          "initial": 0
        }
      },
      "internal_transitions": [
        {
          "from": "checking",
          "to": "joining",
          "condition": "part_1_count > 0 and part_2_count > 0 and part_3_count > 0 and part_4_count > 0"
        },
        {
          "from": "checking",
          "to": "idle",
          "condition": "not (part_1_count > 0 and part_2_count > 0 and part_3_count > 0 and part_4_count > 0)"
        },
        {
          "from": "joining",
          "to": "idle",
          "state_change": "part_1_count := part_1_count - 1; part_2_count := part_2_count - 1; part_3_count := part_3_count - 1; part_4_count := part_4_count - 1"
        }
      ],
      "external_transitions": [
        {
          "from": "idle",
          "input_port": "in_1",
          "to": "checking",
          "state_change": "part_1_count := part_1_count + 1"
        },
        {
          "from": "idle",
          "input_port": "in_2",
          "to": "checking",
          "state_change": "part_2_count := part_2_count + 1"
        },
        {
          "from": "idle",
          "input_port": "in_3",
          "to": "checking",
          "state_change": "part_3_count := part_3_count + 1"
        },
        {
          "from": "idle",
          "input_port": "in_4",
          "to": "checking",
          "state_change": "part_4_count := part_4_count + 1"
        },
        {
          "from": "checking",
          "input_port": "in_1",
          "to": "checking",
          "state_change": "part_1_count := part_1_count + 1"
        },
        {
          "from": "checking",
          "input_port": "in_2",
          "to": "checking",
          "state_change": "part_2_count := part_2_count + 1"
        },
        {
          "from": "checking",
          "input_port": "in_3",
          "to": "checking",
          "state_change": "part_3_count := part_3_count + 1"
        },
        {
          "from": "checking",
          "input_port": "in_4",
          "to": "checking",
          "state_change": "part_4_count := part_4_count + 1"
        },
        {
          "from": "joining",
          "input_port": "in_1",
          "to": "checking",
          "state_change": "part_1_count := part_1_count + 1"
        },
        {
          "from": "joining",
          "input_port": "in_2",
          "to": "checking",
          "state_change": "part_2_count := part_2_count + 1"
        },
        {
          "from": "joining",
          "input_port": "in_3",
          "to": "checking",
          "state_change": "part_3_count := part_3_count + 1"
        },
        {
          "from": "joining",
          "input_port": "in_4",
          "to": "checking",
          "state_change": "part_4_count := part_4_count + 1"
        }
      ],
      "output_function": [
        {
          "state": "joining",
          "output_port": "out",
          "value": "job"
        }
      ]
    },
    {
      "name": "Router",
      "description": "Probabilistic feedback/depart routing",
      "inputs": [
        "in"
      ],
      "outputs": [
        "feedback",
        "depart"
      ],
      "states": [
        {
          "name": "idle",
          "time_advance": "infinity"
        },
        {
          "name": "routing",
          "time_advance": 0
        }
      ],
      "initial_state": "idle",
      "state_variables": {
        "route_decision": {
          "type": "Real",
          "initial": 0.0
        }
      },
      "internal_transitions": [
        {
          "from": "routing",
          "to": "idle"
        }
      ],
      "external_transitions": [
        {
          "from": "idle",
          "input_port": "in",
          "to": "routing",
          "state_change": "route_decision := rnd.uniform(0.0, 1.0)"
        },
        {
          "from": "routing",
          "input_port": "in",
          "to": "routing",
          "state_change": "route_decision := rnd.uniform(0.0, 1.0)"
        }
      ],
      "output_function": [
        {
          "state": "routing",
          "output_port": "feedback",
          "value": "job",
          "condition": "route_decision < feedback_prob"
        },
        {
          "state": "routing",
          "output_port": "depart",
          "value": "job",
          "condition": "route_decision >= feedback_prob"
        }
      ]
    },
    {
      "name": "Sink",
      "description": "Job sink (absorbs completed jobs)",
      "inputs": [
        "in"
      ],
      "outputs": [],
      "states": [
        {
          "name": "idle",
          "time_advance": "infinity"
        }
      ],
      "initial_state": "idle",
      "state_variables": {
        "departure_count": {
          "type": "Nat",
          "initial": 0
        }
      },
      "internal_transitions": [],
      "external_transitions": [
        {
          "from": "idle",
          "input_port": "in",
          "to": "idle",
          "state_change": "departure_count := departure_count + 1"
        }
      ],
      "output_function": []
    }
  ],
