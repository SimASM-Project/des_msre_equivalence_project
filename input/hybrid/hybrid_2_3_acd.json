{
  "model_name": "hybrid_2_3_acd",
  "description": "Hybrid 2x3-Queue using Activity Cycle Diagram - 2 tandem stations, 3 fork-join branches, feedback p=0.5",
  "parameters": {
    "num_servers": {
      "type": "Nat",
      "value": 5,
      "description": "Number of servers per station"
    },
    "iat_mean": {
      "type": "Real",
      "value": 1.25,
      "description": "Inter-arrival time mean"
    },
    "ist_mean": {
      "type": "Real",
      "value": 1.0,
      "description": "Service time mean per station"
    },
    "feedback_prob": {
      "type": "Real",
      "value": 0.5,
      "description": "Probability of feedback to station 1"
    },
    "sim_end_time": {
      "type": "Real",
      "value": 10000.0,
      "description": "Simulation end time"
    }
  },
  "token_types": {
    "Job": {
      "name": "Job",
      "parent": "Token",
      "attributes": {
        "arrival_time": {
          "type": "Real",
          "description": "Time job arrived"
        },
        "service_start_time_1": {
          "type": "Real",
          "description": "Time job started service at tandem station 1"
        },
        "service_start_time_2": {
          "type": "Real",
          "description": "Time job started service at tandem station 2"
        },
        "fork_time": {
          "type": "Real",
          "description": "Time job was forked"
        },
        "branch_start_time_1": {
          "type": "Real",
          "description": "Time job started service at branch 1"
        },
        "branch_start_time_2": {
          "type": "Real",
          "description": "Time job started service at branch 2"
        },
        "branch_start_time_3": {
          "type": "Real",
          "description": "Time job started service at branch 3"
        }
      },
      "description": "Customer job token"
    },
    "Resource": {
      "name": "Resource",
      "parent": "Token",
      "attributes": {},
      "description": "Reusable resource token"
    }
  },
  "queues": {
    "C": {
      "token_type": "Resource",
      "is_resource": true,
      "description": "Creator resource queue",
      "initial_marking": 1
    },
    "Q_1": {
      "token_type": "Job",
      "is_resource": false,
      "description": "Job waiting queue at tandem station 1",
      "initial_marking": 0
    },
    "S_1": {
      "token_type": "Resource",
      "is_resource": true,
      "description": "Server resource queue at tandem station 1",
      "initial_marking": 5
    },
    "Q_2": {
      "token_type": "Job",
      "is_resource": false,
      "description": "Job waiting queue at tandem station 2",
      "initial_marking": 0
    },
    "S_2": {
      "token_type": "Resource",
      "is_resource": true,
      "description": "Server resource queue at tandem station 2",
      "initial_marking": 5
    },
    "Q_fork": {
      "token_type": "Job",
      "is_resource": false,
      "description": "Pre-fork queue",
      "initial_marking": 0
    },
    "BQ_1": {
      "token_type": "Job",
      "is_resource": false,
      "description": "Job waiting queue at branch 1",
      "initial_marking": 0
    },
    "BS_1": {
      "token_type": "Resource",
      "is_resource": true,
      "description": "Server resource queue at branch 1",
      "initial_marking": 5
    },
    "P_1": {
      "token_type": "Job",
      "is_resource": false,
      "description": "Part completion queue at branch 1",
      "initial_marking": 0
    },
    "BQ_2": {
      "token_type": "Job",
      "is_resource": false,
      "description": "Job waiting queue at branch 2",
      "initial_marking": 0
    },
    "BS_2": {
      "token_type": "Resource",
      "is_resource": true,
      "description": "Server resource queue at branch 2",
      "initial_marking": 5
    },
    "P_2": {
      "token_type": "Job",
      "is_resource": false,
      "description": "Part completion queue at branch 2",
      "initial_marking": 0
    },
    "BQ_3": {
      "token_type": "Job",
      "is_resource": false,
      "description": "Job waiting queue at branch 3",
      "initial_marking": 0
    },
    "BS_3": {
      "token_type": "Resource",
      "is_resource": true,
      "description": "Server resource queue at branch 3",
      "initial_marking": 5
    },
    "P_3": {
      "token_type": "Job",
      "is_resource": false,
      "description": "Part completion queue at branch 3",
      "initial_marking": 0
    },
    "Jobs": {
      "token_type": "Job",
      "is_resource": false,
      "description": "Completed jobs (sink)",
      "initial_marking": 0
    }
  },
  "activities": [
    {
      "name": "Create",
      "priority": 4,
      "description": "Job creation activity",
      "at_begin": {
        "condition": "marking(C) >= 1",
        "action": "C--",
        "bind": [
          "creator_token:C"
        ]
      },
      "bto_event": {
        "time": "duration_create",
        "name": "Create_done"
      },
      "at_end": [
        {
          "arc": 1,
          "action": "C++ <- creator_token; Q_1++ <- new Job",
          "accumulate": [
            "job_id_counter += 1"
          ]
        }
      ]
    },
    {
      "name": "Serve_1",
      "priority": 3,
      "description": "Service activity at tandem station 1",
      "at_begin": {
        "condition": "marking(S_1) >= 1 and marking(Q_1) >= 1",
        "action": "S_1--; Q_1--",
        "bind": [
          "server_token:S_1",
          "job_token:Q_1"
        ],
        "set": [
          "job_token.service_start_time_1 = sim_clocktime"
        ]
      },
      "bto_event": {
        "time": "duration_serve_1",
        "name": "Serve_1_done"
      },
      "at_end": [
        {
          "arc": 1,
          "action": "S_1++ <- server_token; Q_2++ <- job_token"
        }
      ]
    },
    {
      "name": "Serve_2",
      "priority": 3,
      "description": "Service activity at tandem station 2",
      "at_begin": {
        "condition": "marking(S_2) >= 1 and marking(Q_2) >= 1",
        "action": "S_2--; Q_2--",
        "bind": [
          "server_token:S_2",
          "job_token:Q_2"
        ],
        "set": [
          "job_token.service_start_time_2 = sim_clocktime"
        ]
      },
      "bto_event": {
        "time": "duration_serve_2",
        "name": "Serve_2_done"
      },
      "at_end": [
        {
          "arc": 1,
          "action": "S_2++ <- server_token; Q_fork++ <- job_token"
        }
      ]
    },
    {
      "name": "Fork",
      "priority": 2,
      "description": "Fork: distribute job to all branches",
      "at_begin": {
        "condition": "marking(Q_fork) >= 1",
        "action": "Q_fork--",
        "bind": [
          "fork_token:Q_fork"
        ]
      },
      "bto_event": {
        "time": "duration_fork",
        "name": "Fork_done"
      },
      "at_end": [
        {
          "arc": 1,
          "action": "BQ_1++ <- new Job; BQ_2++ <- new Job; BQ_3++ <- new Job"
        }
      ]
    },
    {
      "name": "Branch_Serve_1",
      "priority": 1,
      "description": "Service activity at branch 1",
      "at_begin": {
        "condition": "marking(BS_1) >= 1 and marking(BQ_1) >= 1",
        "action": "BS_1--; BQ_1--",
        "bind": [
          "server_token:BS_1",
          "job_token:BQ_1"
        ],
        "set": [
          "job_token.branch_start_time_1 = sim_clocktime"
        ]
      },
      "bto_event": {
        "time": "duration_branch_serve_1",
        "name": "Branch_Serve_1_done"
      },
      "at_end": [
        {
          "arc": 1,
          "action": "BS_1++ <- server_token; P_1++ <- job_token"
        }
      ]
    },
    {
      "name": "Branch_Serve_2",
      "priority": 1,
      "description": "Service activity at branch 2",
      "at_begin": {
        "condition": "marking(BS_2) >= 1 and marking(BQ_2) >= 1",
        "action": "BS_2--; BQ_2--",
        "bind": [
          "server_token:BS_2",
          "job_token:BQ_2"
        ],
        "set": [
          "job_token.branch_start_time_2 = sim_clocktime"
        ]
      },
      "bto_event": {
        "time": "duration_branch_serve_2",
        "name": "Branch_Serve_2_done"
      },
      "at_end": [
        {
          "arc": 1,
          "action": "BS_2++ <- server_token; P_2++ <- job_token"
        }
      ]
    },
    {
      "name": "Branch_Serve_3",
      "priority": 1,
      "description": "Service activity at branch 3",
      "at_begin": {
        "condition": "marking(BS_3) >= 1 and marking(BQ_3) >= 1",
        "action": "BS_3--; BQ_3--",
        "bind": [
          "server_token:BS_3",
          "job_token:BQ_3"
        ],
        "set": [
          "job_token.branch_start_time_3 = sim_clocktime"
        ]
      },
      "bto_event": {
        "time": "duration_branch_serve_3",
        "name": "Branch_Serve_3_done"
      },
      "at_end": [
        {
          "arc": 1,
          "action": "BS_3++ <- server_token; P_3++ <- job_token"
        }
      ]
    },
    {
      "name": "Join",
      "priority": 0,
      "description": "Join: synchronize all branches (with feedback)",
      "at_begin": {
        "condition": "marking(P_1) >= 1 and marking(P_2) >= 1 and marking(P_3) >= 1",
        "action": "P_1--; P_2--; P_3--",
        "bind": [
          "part_token_1:P_1",
          "part_token_2:P_2",
          "part_token_3:P_3"
        ]
      },
      "bto_event": {
        "time": "duration_join",
        "name": "Join_done"
      },
      "at_end": [
        {
          "arc": 1,
          "action": "Q_1++ <- new Job",
          "condition": "feedback"
        },
        {
          "arc": 2,
          "action": "Jobs++ <- new Job",
          "condition": "not_feedback",
          "accumulate": [
            "departure_count += 1"
          ]
        }
      ]
    }
  ],
  "random_streams": {
    "duration_create": {
      "distribution": "exponential",
      "params": {
        "mean": "iat_mean"
      },
      "stream_name": "arrivals"
    },
    "duration_fork": {
      "distribution": "constant",
      "params": {
        "value": 0
      },
      "stream_name": "fork"
    },
    "duration_join": {
      "distribution": "constant",
      "params": {
        "value": 0
      },
      "stream_name": "join"
    },
    "duration_serve_1": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "service_1"
    },
    "duration_serve_2": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "service_2"
    },
    "duration_branch_serve_1": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "branch_service_1"
    },
    "duration_branch_serve_2": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "branch_service_2"
    },
    "duration_branch_serve_3": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "branch_service_3"
    }
  },
  "state_variables": {
    "job_id_counter": {
      "type": "Nat",
      "initial": 0
    },
    "departure_count": {
      "type": "Nat",
      "initial": 0
    }
  },
  "stopping_condition": "sim_clocktime >= sim_end_time",
  "observables": {
    "queue_count_1": {
      "name": "queue_count_1",
      "expression": "marking(Q_1)",
      "description": "Number in queue at tandem station 1"
    },
    "server_count_1": {
      "name": "server_count_1",
      "expression": "num_servers - marking(S_1)",
      "description": "Number of busy servers at tandem station 1"
    },
    "queue_count_2": {
      "name": "queue_count_2",
      "expression": "marking(Q_2)",
      "description": "Number in queue at tandem station 2"
    },
    "server_count_2": {
      "name": "server_count_2",
      "expression": "num_servers - marking(S_2)",
      "description": "Number of busy servers at tandem station 2"
    },
    "branch_queue_1": {
      "name": "branch_queue_1",
      "expression": "marking(BQ_1)",
      "description": "Number in queue at branch 1"
    },
    "branch_server_1": {
      "name": "branch_server_1",
      "expression": "num_servers - marking(BS_1)",
      "description": "Number of busy servers at branch 1"
    },
    "branch_queue_2": {
      "name": "branch_queue_2",
      "expression": "marking(BQ_2)",
      "description": "Number in queue at branch 2"
    },
    "branch_server_2": {
      "name": "branch_server_2",
      "expression": "num_servers - marking(BS_2)",
      "description": "Number of busy servers at branch 2"
    },
    "branch_queue_3": {
      "name": "branch_queue_3",
      "expression": "marking(BQ_3)",
      "description": "Number in queue at branch 3"
    },
    "branch_server_3": {
      "name": "branch_server_3",
      "expression": "num_servers - marking(BS_3)",
      "description": "Number of busy servers at branch 3"
    },
    "in_system": {
      "name": "in_system",
      "expression": "marking(Q_1) + (num_servers - marking(S_1)) + marking(Q_2) + (num_servers - marking(S_2)) + marking(BQ_1) + (num_servers - marking(BS_1)) + marking(P_1) + marking(BQ_2) + (num_servers - marking(BS_2)) + marking(P_2) + marking(BQ_3) + (num_servers - marking(BS_3)) + marking(P_3)",
      "description": "Total in system"
    },
    "L_q_total": {
      "name": "L_q_total",
      "expression": "marking(Q_1) + marking(Q_2) + marking(BQ_1) + marking(BQ_2) + marking(BQ_3)",
      "description": "Total queue length"
    },
    "departure_count": {
      "name": "departure_count",
      "expression": "departure_count",
      "description": "Total departures"
    }
  },
  "statistics": [
    {
      "name": "L_q_total",
      "type": "time_average",
      "description": "Average total queue length",
      "observable": "marking(Q_1) + marking(Q_2) + marking(BQ_1) + marking(BQ_2) + marking(BQ_3)"
    },
    {
      "name": "L",
      "type": "time_average",
      "description": "Average number in system",
      "observable": "marking(Q_1) + (num_servers - marking(S_1)) + marking(Q_2) + (num_servers - marking(S_2)) + marking(BQ_1) + (num_servers - marking(BS_1)) + marking(P_1) + marking(BQ_2) + (num_servers - marking(BS_2)) + marking(P_2) + marking(BQ_3) + (num_servers - marking(BS_3)) + marking(P_3)"
    },
    {
      "name": "throughput",
      "type": "count",
      "description": "Total departures",
      "observable": "departure_count"
    }
  ]
}