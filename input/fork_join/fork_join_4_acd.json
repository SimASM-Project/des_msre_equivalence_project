{
  "model_name": "fork_join_4_acd",
  "description": "Fork-Join 4-Queue using Activity Cycle Diagram - 4 parallel branches",
  "parameters": {
    "num_servers": {
      "type": "Nat",
      "value": 5,
      "description": "Number of servers per branch"
    },
    "iat_mean": {
      "type": "Real",
      "value": 1.25,
      "description": "Inter-arrival time mean"
    },
    "ist_mean": {
      "type": "Real",
      "value": 1.0,
      "description": "Service time mean per branch"
    },
    "sim_end_time": {
      "type": "Real",
      "value": 10000.0,
      "description": "Simulation end time"
    }
  },
  "token_types": {
    "Job": {
      "name": "Job",
      "parent": "Token",
      "attributes": {
        "arrival_time": {
          "type": "Real",
          "description": "Time job arrived"
        },
        "service_start_time_1": {
          "type": "Real",
          "description": "Time job started service at branch 1"
        },
        "service_start_time_2": {
          "type": "Real",
          "description": "Time job started service at branch 2"
        },
        "service_start_time_3": {
          "type": "Real",
          "description": "Time job started service at branch 3"
        },
        "service_start_time_4": {
          "type": "Real",
          "description": "Time job started service at branch 4"
        }
      },
      "description": "Customer job token"
    },
    "Resource": {
      "name": "Resource",
      "parent": "Token",
      "attributes": {},
      "description": "Reusable resource token"
    }
  },
  "queues": {
    "C": {
      "token_type": "Resource",
      "is_resource": true,
      "description": "Creator resource queue",
      "initial_marking": 1
    },
    "Q_fork": {
      "token_type": "Job",
      "is_resource": false,
      "description": "Pre-fork queue",
      "initial_marking": 0
    },
    "Q_1": {
      "token_type": "Job",
      "is_resource": false,
      "description": "Job waiting queue at branch 1",
      "initial_marking": 0
    },
    "S_1": {
      "token_type": "Resource",
      "is_resource": true,
      "description": "Server resource queue at branch 1",
      "initial_marking": 5
    },
    "P_1": {
      "token_type": "Job",
      "is_resource": false,
      "description": "Part completion queue at branch 1",
      "initial_marking": 0
    },
    "Q_2": {
      "token_type": "Job",
      "is_resource": false,
      "description": "Job waiting queue at branch 2",
      "initial_marking": 0
    },
    "S_2": {
      "token_type": "Resource",
      "is_resource": true,
      "description": "Server resource queue at branch 2",
      "initial_marking": 5
    },
    "P_2": {
      "token_type": "Job",
      "is_resource": false,
      "description": "Part completion queue at branch 2",
      "initial_marking": 0
    },
    "Q_3": {
      "token_type": "Job",
      "is_resource": false,
      "description": "Job waiting queue at branch 3",
      "initial_marking": 0
    },
    "S_3": {
      "token_type": "Resource",
      "is_resource": true,
      "description": "Server resource queue at branch 3",
      "initial_marking": 5
    },
    "P_3": {
      "token_type": "Job",
      "is_resource": false,
      "description": "Part completion queue at branch 3",
      "initial_marking": 0
    },
    "Q_4": {
      "token_type": "Job",
      "is_resource": false,
      "description": "Job waiting queue at branch 4",
      "initial_marking": 0
    },
    "S_4": {
      "token_type": "Resource",
      "is_resource": true,
      "description": "Server resource queue at branch 4",
      "initial_marking": 5
    },
    "P_4": {
      "token_type": "Job",
      "is_resource": false,
      "description": "Part completion queue at branch 4",
      "initial_marking": 0
    },
    "Jobs": {
      "token_type": "Job",
      "is_resource": false,
      "description": "Completed jobs (sink)",
      "initial_marking": 0
    }
  },
  "activities": [
    {
      "name": "Create",
      "priority": 3,
      "description": "Job creation activity",
      "at_begin": {
        "condition": "marking(C) >= 1",
        "action": "C--",
        "bind": [
          "creator_token:C"
        ]
      },
      "bto_event": {
        "time": "duration_create",
        "name": "Create_done"
      },
      "at_end": [
        {
          "arc": 1,
          "action": "C++ <- creator_token; Q_fork++ <- new Job",
          "accumulate": [
            "job_id_counter += 1"
          ]
        }
      ]
    },
    {
      "name": "Fork",
      "priority": 2,
      "description": "Fork: distribute job to all branches",
      "at_begin": {
        "condition": "marking(Q_fork) >= 1",
        "action": "Q_fork--",
        "bind": [
          "fork_token:Q_fork"
        ]
      },
      "bto_event": {
        "time": "duration_fork",
        "name": "Fork_done"
      },
      "at_end": [
        {
          "arc": 1,
          "action": "Q_1++ <- new Job; Q_2++ <- new Job; Q_3++ <- new Job; Q_4++ <- new Job"
        }
      ]
    },
    {
      "name": "Serve_1",
      "priority": 1,
      "description": "Service activity at branch 1",
      "at_begin": {
        "condition": "marking(S_1) >= 1 and marking(Q_1) >= 1",
        "action": "S_1--; Q_1--",
        "bind": [
          "server_token:S_1",
          "job_token:Q_1"
        ],
        "set": [
          "job_token.service_start_time_1 = sim_clocktime"
        ]
      },
      "bto_event": {
        "time": "duration_serve_1",
        "name": "Serve_1_done"
      },
      "at_end": [
        {
          "arc": 1,
          "action": "S_1++ <- server_token; P_1++ <- job_token"
        }
      ]
    },
    {
      "name": "Serve_2",
      "priority": 1,
      "description": "Service activity at branch 2",
      "at_begin": {
        "condition": "marking(S_2) >= 1 and marking(Q_2) >= 1",
        "action": "S_2--; Q_2--",
        "bind": [
          "server_token:S_2",
          "job_token:Q_2"
        ],
        "set": [
          "job_token.service_start_time_2 = sim_clocktime"
        ]
      },
      "bto_event": {
        "time": "duration_serve_2",
        "name": "Serve_2_done"
      },
      "at_end": [
        {
          "arc": 1,
          "action": "S_2++ <- server_token; P_2++ <- job_token"
        }
      ]
    },
    {
      "name": "Serve_3",
      "priority": 1,
      "description": "Service activity at branch 3",
      "at_begin": {
        "condition": "marking(S_3) >= 1 and marking(Q_3) >= 1",
        "action": "S_3--; Q_3--",
        "bind": [
          "server_token:S_3",
          "job_token:Q_3"
        ],
        "set": [
          "job_token.service_start_time_3 = sim_clocktime"
        ]
      },
      "bto_event": {
        "time": "duration_serve_3",
        "name": "Serve_3_done"
      },
      "at_end": [
        {
          "arc": 1,
          "action": "S_3++ <- server_token; P_3++ <- job_token"
        }
      ]
    },
    {
      "name": "Serve_4",
      "priority": 1,
      "description": "Service activity at branch 4",
      "at_begin": {
        "condition": "marking(S_4) >= 1 and marking(Q_4) >= 1",
        "action": "S_4--; Q_4--",
        "bind": [
          "server_token:S_4",
          "job_token:Q_4"
        ],
        "set": [
          "job_token.service_start_time_4 = sim_clocktime"
        ]
      },
      "bto_event": {
        "time": "duration_serve_4",
        "name": "Serve_4_done"
      },
      "at_end": [
        {
          "arc": 1,
          "action": "S_4++ <- server_token; P_4++ <- job_token"
        }
      ]
    },
    {
      "name": "Join",
      "priority": 0,
      "description": "Join: synchronize all branches",
      "at_begin": {
        "condition": "marking(P_1) >= 1 and marking(P_2) >= 1 and marking(P_3) >= 1 and marking(P_4) >= 1",
        "action": "P_1--; P_2--; P_3--; P_4--",
        "bind": [
          "part_token_1:P_1",
          "part_token_2:P_2",
          "part_token_3:P_3",
          "part_token_4:P_4"
        ]
      },
      "bto_event": {
        "time": "duration_join",
        "name": "Join_done"
      },
      "at_end": [
        {
          "arc": 1,
          "action": "Jobs++ <- new Job",
          "accumulate": [
            "departure_count += 1"
          ]
        }
      ]
    }
  ],
  "random_streams": {
    "duration_create": {
      "distribution": "exponential",
      "params": {
        "mean": "iat_mean"
      },
      "stream_name": "arrivals"
    },
    "duration_fork": {
      "distribution": "constant",
      "params": {
        "value": 0
      },
      "stream_name": "fork"
    },
    "duration_join": {
      "distribution": "constant",
      "params": {
        "value": 0
      },
      "stream_name": "join"
    },
    "duration_serve_1": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "service_1"
    },
    "duration_serve_2": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "service_2"
    },
    "duration_serve_3": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "service_3"
    },
    "duration_serve_4": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "service_4"
    }
  },
  "state_variables": {
    "job_id_counter": {
      "type": "Nat",
      "initial": 0
    },
    "departure_count": {
      "type": "Nat",
      "initial": 0
    }
  },
  "stopping_condition": "sim_clocktime >= sim_end_time",
  "observables": {
    "queue_count_1": {
      "name": "queue_count_1",
      "expression": "marking(Q_1)",
      "description": "Number in queue at branch 1"
    },
    "server_count_1": {
      "name": "server_count_1",
      "expression": "num_servers - marking(S_1)",
      "description": "Number of busy servers at branch 1"
    },
    "queue_count_2": {
      "name": "queue_count_2",
      "expression": "marking(Q_2)",
      "description": "Number in queue at branch 2"
    },
    "server_count_2": {
      "name": "server_count_2",
      "expression": "num_servers - marking(S_2)",
      "description": "Number of busy servers at branch 2"
    },
    "queue_count_3": {
      "name": "queue_count_3",
      "expression": "marking(Q_3)",
      "description": "Number in queue at branch 3"
    },
    "server_count_3": {
      "name": "server_count_3",
      "expression": "num_servers - marking(S_3)",
      "description": "Number of busy servers at branch 3"
    },
    "queue_count_4": {
      "name": "queue_count_4",
      "expression": "marking(Q_4)",
      "description": "Number in queue at branch 4"
    },
    "server_count_4": {
      "name": "server_count_4",
      "expression": "num_servers - marking(S_4)",
      "description": "Number of busy servers at branch 4"
    },
    "part_1_num": {
      "name": "part_1_num",
      "expression": "marking(P_1)",
      "description": "Completed but not yet joined at branch 1"
    },
    "part_2_num": {
      "name": "part_2_num",
      "expression": "marking(P_2)",
      "description": "Completed but not yet joined at branch 2"
    },
    "part_3_num": {
      "name": "part_3_num",
      "expression": "marking(P_3)",
      "description": "Completed but not yet joined at branch 3"
    },
    "part_4_num": {
      "name": "part_4_num",
      "expression": "marking(P_4)",
      "description": "Completed but not yet joined at branch 4"
    },
    "in_system": {
      "name": "in_system",
      "expression": "marking(Q_1) + (num_servers - marking(S_1)) + marking(P_1) + marking(Q_2) + (num_servers - marking(S_2)) + marking(P_2) + marking(Q_3) + (num_servers - marking(S_3)) + marking(P_3) + marking(Q_4) + (num_servers - marking(S_4)) + marking(P_4)",
      "description": "Total in system"
    }
  },
  "statistics": [
    {
      "name": "L_q_total",
      "type": "time_average",
      "description": "Average total queue length",
      "observable": "marking(Q_1) + marking(Q_2) + marking(Q_3) + marking(Q_4)"
    },
    {
      "name": "L",
      "type": "time_average",
      "description": "Average number in system",
      "observable": "marking(Q_1) + (num_servers - marking(S_1)) + marking(P_1) + marking(Q_2) + (num_servers - marking(S_2)) + marking(P_2) + marking(Q_3) + (num_servers - marking(S_3)) + marking(P_3) + marking(Q_4) + (num_servers - marking(S_4)) + marking(P_4)"
    },
    {
      "name": "throughput",
      "type": "count",
      "description": "Total departures",
      "observable": "departure_count"
    }
  ]
}