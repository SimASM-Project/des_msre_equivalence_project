      "duration": "duration_serve_7"
    },
    {
      "name": "Join",
      "priority": 0,
      "at_begin": {
        "condition": "true",
        "consume": [
          {
            "queue": "P_1",
            "count": 1,
            "bind_as": "part_token_1"
          },
          {
            "queue": "P_2",
            "count": 1,
            "bind_as": "part_token_2"
          },
          {
            "queue": "P_3",
            "count": 1,
            "bind_as": "part_token_3"
          },
          {
            "queue": "P_4",
            "count": 1,
            "bind_as": "part_token_4"
          },
          {
            "queue": "P_5",
            "count": 1,
