    },
    {
      "name": "Serve_5",
      "priority": 1,
      "at_begin": {
        "condition": "true",
        "consume": [
          {
            "queue": "S_5",
            "count": 1,
            "bind_as": "server_token"
          },
          {
            "queue": "Q_5",
            "count": 1,
            "bind_as": "job_token"
          }
        ],
        "actions": [
          "service_start_time_5(job_token) := sim_clocktime"
        ]
