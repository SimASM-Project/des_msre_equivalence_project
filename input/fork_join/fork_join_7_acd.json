  ],
  "random_streams": {
    "duration_create": {
      "distribution": "exponential",
      "params": {
        "mean": "iat_mean"
      },
      "stream_name": "arrivals"
    },
    "duration_fork": {
      "distribution": "constant",
      "params": {
        "value": 0
      },
      "stream_name": "fork"
    },
    "duration_join": {
      "distribution": "constant",
      "params": {
        "value": 0
      },
      "stream_name": "join"
    },
    "duration_serve_1": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "service_1"
    },
    "duration_serve_2": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "service_2"
    },
    "duration_serve_3": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "service_3"
    },
    "duration_serve_4": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "service_4"
    },
    "duration_serve_5": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "service_5"
    },
    "duration_serve_6": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "service_6"
    },
    "duration_serve_7": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "service_7"
    }
  },
  "state_variables": {
    "job_id_counter": {
      "type": "Nat",
      "initial": 0
    },
    "departure_count": {
      "type": "Nat",
      "initial": 0
    }
  },
  "stopping_condition": "sim_clocktime >= sim_end_time",
  "observables": {
    "queue_count_1": {
      "name": "queue_count_1",
      "expression": "marking(Q_1)",
      "description": "Number in queue at branch 1"
    },
    "server_count_1": {
      "name": "server_count_1",
      "expression": "num_servers - marking(S_1)",
      "description": "Number of busy servers at branch 1"
    },
    "queue_count_2": {
      "name": "queue_count_2",
      "expression": "marking(Q_2)",
      "description": "Number in queue at branch 2"
    },
    "server_count_2": {
      "name": "server_count_2",
      "expression": "num_servers - marking(S_2)",
      "description": "Number of busy servers at branch 2"
    },
    "queue_count_3": {
      "name": "queue_count_3",
      "expression": "marking(Q_3)",
      "description": "Number in queue at branch 3"
    },
    "server_count_3": {
      "name": "server_count_3",
      "expression": "num_servers - marking(S_3)",
      "description": "Number of busy servers at branch 3"
    },
    "queue_count_4": {
      "name": "queue_count_4",
      "expression": "marking(Q_4)",
      "description": "Number in queue at branch 4"
    },
    "server_count_4": {
      "name": "server_count_4",
      "expression": "num_servers - marking(S_4)",
      "description": "Number of busy servers at branch 4"
    },
    "queue_count_5": {
      "name": "queue_count_5",
      "expression": "marking(Q_5)",
      "description": "Number in queue at branch 5"
    },
    "server_count_5": {
      "name": "server_count_5",
      "expression": "num_servers - marking(S_5)",
      "description": "Number of busy servers at branch 5"
    },
    "queue_count_6": {
      "name": "queue_count_6",
      "expression": "marking(Q_6)",
      "description": "Number in queue at branch 6"
    },
    "server_count_6": {
      "name": "server_count_6",
      "expression": "num_servers - marking(S_6)",
      "description": "Number of busy servers at branch 6"
    },
    "queue_count_7": {
      "name": "queue_count_7",
      "expression": "marking(Q_7)",
      "description": "Number in queue at branch 7"
    },
    "server_count_7": {
      "name": "server_count_7",
      "expression": "num_servers - marking(S_7)",
      "description": "Number of busy servers at branch 7"
    },
    "part_1_num": {
      "name": "part_1_num",
      "expression": "marking(P_1)",
      "description": "Completed but not yet joined at branch 1"
    },
    "part_2_num": {
      "name": "part_2_num",
      "expression": "marking(P_2)",
      "description": "Completed but not yet joined at branch 2"
    },
    "part_3_num": {
      "name": "part_3_num",
      "expression": "marking(P_3)",
      "description": "Completed but not yet joined at branch 3"
    },
    "part_4_num": {
      "name": "part_4_num",
      "expression": "marking(P_4)",
      "description": "Completed but not yet joined at branch 4"
    },
    "part_5_num": {
      "name": "part_5_num",
      "expression": "marking(P_5)",
      "description": "Completed but not yet joined at branch 5"
    },
    "part_6_num": {
      "name": "part_6_num",
      "expression": "marking(P_6)",
      "description": "Completed but not yet joined at branch 6"
    },
    "part_7_num": {
      "name": "part_7_num",
      "expression": "marking(P_7)",
      "description": "Completed but not yet joined at branch 7"
    },
    "in_system": {
      "name": "in_system",
      "expression": "marking(Q_1) + (num_servers - marking(S_1)) + marking(P_1) + marking(Q_2) + (num_servers - marking(S_2)) + marking(P_2) + marking(Q_3) + (num_servers - marking(S_3)) + marking(P_3) + marking(Q_4) + (num_servers - marking(S_4)) + marking(P_4) + marking(Q_5) + (num_servers - marking(S_5)) + marking(P_5) + marking(Q_6) + (num_servers - marking(S_6)) + marking(P_6) + marking(Q_7) + (num_servers - marking(S_7)) + marking(P_7)",
      "description": "Total in system"
    }
  },
  "statistics": [
    {
      "name": "L_q_total",
      "type": "time_average",
      "expression": "marking(Q_1) + marking(Q_2) + marking(Q_3) + marking(Q_4) + marking(Q_5) + marking(Q_6) + marking(Q_7)",
      "description": "Average total queue length"
    },
    {
      "name": "L",
      "type": "time_average",
      "expression": "marking(Q_1) + (num_servers - marking(S_1)) + marking(P_1) + marking(Q_2) + (num_servers - marking(S_2)) + marking(P_2) + marking(Q_3) + (num_servers - marking(S_3)) + marking(P_3) + marking(Q_4) + (num_servers - marking(S_4)) + marking(P_4) + marking(Q_5) + (num_servers - marking(S_5)) + marking(P_5) + marking(Q_6) + (num_servers - marking(S_6)) + marking(P_6) + marking(Q_7) + (num_servers - marking(S_7)) + marking(P_7)",
      "description": "Average number in system"
    },
    {
      "name": "throughput",
      "type": "count",
      "expression": "departure_count",
      "description": "Total departures"
    }
  ]
}