{
  "model_name": "fork_join_7_acd",
  "description": "Fork-Join 7-Queue using Activity Cycle Diagram - 7 parallel branches",
  "parameters": {
    "num_servers": {
      "type": "Nat",
      "value": 5,
      "description": "Number of servers per branch"
    },
    "iat_mean": {
      "type": "Real",
      "value": 1.25,
      "description": "Inter-arrival time mean"
    },
    "ist_mean": {
      "type": "Real",
      "value": 1.0,
      "description": "Service time mean per branch"
    },
    "sim_end_time": {
      "type": "Real",
      "value": 10000.0,
      "description": "Simulation end time"
    }
  },
  "token_types": {
    "Job": {
      "name": "Job",
      "parent": "Token",
      "attributes": {
        "arrival_time": {
          "type": "Real",
          "description": "Time job arrived"
        },
        "service_start_time_1": {
          "type": "Real",
          "description": "Time job started service at branch 1"
        },
        "service_start_time_2": {
          "type": "Real",
          "description": "Time job started service at branch 2"
        },
        "service_start_time_3": {
          "type": "Real",
          "description": "Time job started service at branch 3"
        },
        "service_start_time_4": {
          "type": "Real",
          "description": "Time job started service at branch 4"
        },
        "service_start_time_5": {
          "type": "Real",
          "description": "Time job started service at branch 5"
        },
        "service_start_time_6": {
          "type": "Real",
          "description": "Time job started service at branch 6"
        },
        "service_start_time_7": {
          "type": "Real",
          "description": "Time job started service at branch 7"
        }
      },
      "description": "Customer job token"
    },
    "Resource": {
      "name": "Resource",
      "parent": "Token",
      "attributes": {},
      "description": "Reusable resource token"
    }
  },
  "queues": {
    "C": {
      "initial_tokens": 1,
      "token_type": "Resource",
      "is_resource": true,
      "description": "Creator resource queue"
    },
    "Q_fork": {
      "initial_tokens": 0,
      "token_type": "Job",
      "is_resource": false,
      "description": "Pre-fork queue"
    },
    "Q_1": {
      "initial_tokens": 0,
      "token_type": "Job",
      "is_resource": false,
      "description": "Job waiting queue at branch 1"
    },
    "S_1": {
      "initial_tokens": 5,
      "token_type": "Resource",
      "is_resource": true,
      "description": "Server resource queue at branch 1"
    },
    "P_1": {
      "initial_tokens": 0,
      "token_type": "Job",
      "is_resource": false,
      "description": "Part completion queue at branch 1"
    },
    "Q_2": {
      "initial_tokens": 0,
      "token_type": "Job",
      "is_resource": false,
      "description": "Job waiting queue at branch 2"
    },
    "S_2": {
      "initial_tokens": 5,
      "token_type": "Resource",
      "is_resource": true,
      "description": "Server resource queue at branch 2"
    },
    "P_2": {
      "initial_tokens": 0,
      "token_type": "Job",
      "is_resource": false,
      "description": "Part completion queue at branch 2"
    },
    "Q_3": {
      "initial_tokens": 0,
      "token_type": "Job",
      "is_resource": false,
      "description": "Job waiting queue at branch 3"
    },
    "S_3": {
      "initial_tokens": 5,
      "token_type": "Resource",
      "is_resource": true,
      "description": "Server resource queue at branch 3"
    },
    "P_3": {
      "initial_tokens": 0,
      "token_type": "Job",
      "is_resource": false,
      "description": "Part completion queue at branch 3"
    },
    "Q_4": {
      "initial_tokens": 0,
      "token_type": "Job",
      "is_resource": false,
      "description": "Job waiting queue at branch 4"
    },
    "S_4": {
      "initial_tokens": 5,
      "token_type": "Resource",
      "is_resource": true,
      "description": "Server resource queue at branch 4"
    },
    "P_4": {
      "initial_tokens": 0,
      "token_type": "Job",
      "is_resource": false,
      "description": "Part completion queue at branch 4"
    },
    "Q_5": {
      "initial_tokens": 0,
      "token_type": "Job",
      "is_resource": false,
      "description": "Job waiting queue at branch 5"
    },
    "S_5": {
      "initial_tokens": 5,
      "token_type": "Resource",
      "is_resource": true,
      "description": "Server resource queue at branch 5"
    },
    "P_5": {
      "initial_tokens": 0,
      "token_type": "Job",
      "is_resource": false,
      "description": "Part completion queue at branch 5"
    },
    "Q_6": {
      "initial_tokens": 0,
      "token_type": "Job",
      "is_resource": false,
      "description": "Job waiting queue at branch 6"
    },
    "S_6": {
      "initial_tokens": 5,
      "token_type": "Resource",
      "is_resource": true,
      "description": "Server resource queue at branch 6"
    },
    "P_6": {
      "initial_tokens": 0,
      "token_type": "Job",
      "is_resource": false,
      "description": "Part completion queue at branch 6"
    },
    "Q_7": {
      "initial_tokens": 0,
      "token_type": "Job",
      "is_resource": false,
      "description": "Job waiting queue at branch 7"
    },
    "S_7": {
      "initial_tokens": 5,
      "token_type": "Resource",
      "is_resource": true,
      "description": "Server resource queue at branch 7"
    },
    "P_7": {
      "initial_tokens": 0,
      "token_type": "Job",
      "is_resource": false,
      "description": "Part completion queue at branch 7"
    },
    "Jobs": {
      "initial_tokens": 0,
      "token_type": "Job",
      "is_resource": false,
      "description": "Completed jobs (sink)"
    }
  },
  "activities": [
    {
      "name": "Create",
      "priority": 3,
      "at_begin": {
        "condition": "true",
        "consume": [
          {
            "queue": "C",
            "count": 1,
            "bind_as": "creator_token"
          }
        ],
        "actions": []
      },
      "at_end": [
        {
          "condition": "true",
          "produce": [
            {
              "queue": "C",
              "count": 1,
              "token_source": "creator_token"
            },
            {
              "queue": "Q_fork",
              "count": 1,
              "token_source": "new"
            }
          ],
          "actions": [
            "job_id_counter := job_id_counter + 1"
          ]
        }
      ],
      "description": "Job creation activity",
      "duration": "duration_create"
    },
    {
      "name": "Fork",
      "priority": 2,
      "at_begin": {
        "condition": "true",
        "consume": [
          {
            "queue": "Q_fork",
            "count": 1,
            "bind_as": "fork_token"
          }
        ],
        "actions": []
      },
      "at_end": [
        {
          "condition": "true",
          "produce": [
            {
              "queue": "Q_1",
              "count": 1,
              "token_source": "new"
            },
            {
              "queue": "Q_2",
              "count": 1,
              "token_source": "new"
            },
            {
              "queue": "Q_3",
              "count": 1,
              "token_source": "new"
            },
            {
              "queue": "Q_4",
              "count": 1,
              "token_source": "new"
            },
            {
              "queue": "Q_5",
              "count": 1,
              "token_source": "new"
            },
            {
              "queue": "Q_6",
              "count": 1,
              "token_source": "new"
            },
            {
              "queue": "Q_7",
              "count": 1,
              "token_source": "new"
            }
          ],
          "actions": []
        }
      ],
      "description": "Fork: distribute job to all branches",
      "duration": "duration_fork"
    },
    {
      "name": "Serve_1",
      "priority": 1,
      "at_begin": {
        "condition": "true",
        "consume": [
          {
            "queue": "S_1",
            "count": 1,
            "bind_as": "server_token"
          },
          {
            "queue": "Q_1",
            "count": 1,
            "bind_as": "job_token"
          }
        ],
        "actions": [
          "service_start_time_1(job_token) := sim_clocktime"
        ]
      },
      "at_end": [
        {
          "condition": "true",
          "produce": [
            {
              "queue": "S_1",
              "count": 1,
              "token_source": "server_token"
            },
            {
              "queue": "P_1",
              "count": 1,
              "token_source": "job_token"
            }
          ],
          "actions": []
        }
      ],
      "description": "Service activity at branch 1",
      "duration": "duration_serve_1"
    },
    {
      "name": "Serve_2",
      "priority": 1,
      "at_begin": {
        "condition": "true",
        "consume": [
          {
            "queue": "S_2",
            "count": 1,
            "bind_as": "server_token"
          },
          {
            "queue": "Q_2",
            "count": 1,
            "bind_as": "job_token"
          }
        ],
        "actions": [
          "service_start_time_2(job_token) := sim_clocktime"
        ]
      },
      "at_end": [
        {
          "condition": "true",
          "produce": [
            {
              "queue": "S_2",
              "count": 1,
              "token_source": "server_token"
            },
            {
              "queue": "P_2",
              "count": 1,
              "token_source": "job_token"
            }
          ],
          "actions": []
        }
      ],
      "description": "Service activity at branch 2",
      "duration": "duration_serve_2"
    },
    {
      "name": "Serve_3",
      "priority": 1,
      "at_begin": {
        "condition": "true",
        "consume": [
          {
            "queue": "S_3",
            "count": 1,
