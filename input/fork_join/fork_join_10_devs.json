{
  "model_name": "fork_join_10_devs",
  "description": "Fork-Join 10-Queue using DEVS formalism - 10 parallel branches with synchronizing join",
  "entities": {
    "Load": {
      "name": "Load",
      "parent": "Object",
      "attributes": {
        "arrival_time": "Real",
        "service_start_time_1": "Real",
        "service_start_time_2": "Real",
        "service_start_time_3": "Real",
        "service_start_time_4": "Real",
        "service_start_time_5": "Real",
        "service_start_time_6": "Real",
        "service_start_time_7": "Real",
        "service_start_time_8": "Real",
        "service_start_time_9": "Real",
        "service_start_time_10": "Real",
        "join_time": "Real",
        "departure_time": "Real"
      }
    }
  },
  "parameters": {
    "service_capacity": {
      "type": "Nat",
      "value": 1,
      "description": "Number of servers per branch"
    },
    "iat_mean": {
      "type": "Real",
      "value": 1.25,
      "description": "Inter-arrival time mean"
    },
    "ist_mean": {
      "type": "Real",
      "value": 1.0,
      "description": "Service time mean per branch"
    },
    "sim_end_time": {
      "type": "Real",
      "value": 10000.0,
      "description": "Simulation end time"
    }
  },
  "random_streams": {
    "interarrival_time": {
      "distribution": "exponential",
      "params": {
        "mean": "iat_mean"
      },
      "stream_name": "arrivals"
    },
    "service_time_1": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "service_1"
    },
    "service_time_2": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "service_2"
    },
    "service_time_3": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "service_3"
    },
    "service_time_4": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "service_4"
    },
    "service_time_5": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "service_5"
    },
    "service_time_6": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "service_6"
    },
    "service_time_7": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "service_7"
    },
    "service_time_8": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "service_8"
    },
    "service_time_9": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "service_9"
    },
    "service_time_10": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "service_10"
    }
  },
  "atomic_models": [
    {
      "name": "Generator",
      "description": "Job generator (source)",
      "inputs": [],
      "outputs": [
        "out"
      ],
      "states": [
        {
          "name": "active",
          "time_advance": "interarrival_time"
        }
      ],
      "initial_state": "active",
      "state_variables": {
        "job_count": {
          "type": "Nat",
          "initial": 0
        }
      },
      "internal_transitions": [
        {
          "from": "active",
          "to": "active",
          "state_change": "job_count := job_count + 1"
        }
      ],
      "external_transitions": [],
      "output_function": [
        {
          "state": "active",
          "output_port": "out",
          "value": "job"
        }
      ]
    },
    {
      "name": "Forker",
      "description": "Replicates each arriving job to all parallel branches",
      "inputs": [
        "in"
      ],
      "outputs": [
        "out"
      ],
      "states": [
        {
          "name": "idle",
          "time_advance": "infinity"
        },
        {
          "name": "forking",
          "time_advance": 0
        }
      ],
      "initial_state": "idle",
      "state_variables": {},
      "internal_transitions": [
        {
          "from": "forking",
          "to": "idle"
        }
      ],
      "external_transitions": [
        {
          "from": "idle",
          "input_port": "in",
          "to": "forking"
        },
        {
          "from": "forking",
          "input_port": "in",
          "to": "forking"
        }
      ],
      "output_function": [
        {
          "state": "forking",
          "output_port": "out",
          "value": "job"
        }
      ]
    },
    {
      "name": "Branch_Server_1",
      "description": "Single-server queue-processor at branch 1",
      "inputs": [
        "in"
      ],
      "outputs": [
        "out"
      ],
      "states": [
        {
          "name": "passive",
          "time_advance": "infinity"
        },
        {
          "name": "starting",
          "time_advance": 0
        },
        {
          "name": "busy",
          "time_advance": "service_time_1"
        }
      ],
      "initial_state": "passive",
      "state_variables": {
        "queue_count": {
          "type": "Nat",
          "initial": 0
        },
        "server_count": {
          "type": "Nat",
          "initial": 0
        }
      },
      "internal_transitions": [
        {
          "from": "starting",
          "to": "busy",
          "state_change": "queue_count := queue_count - 1; server_count := server_count + 1"
        },
        {
          "from": "busy",
          "to": "starting",
          "condition": "queue_count > 0",
          "state_change": "server_count := server_count - 1"
        },
        {
          "from": "busy",
          "to": "passive",
          "condition": "queue_count == 0",
          "state_change": "server_count := server_count - 1"
        }
      ],
      "external_transitions": [
        {
          "from": "passive",
          "input_port": "in",
          "to": "starting",
          "state_change": "queue_count := queue_count + 1"
        },
        {
          "from": "starting",
          "input_port": "in",
          "to": "starting",
          "state_change": "queue_count := queue_count + 1"
        },
        {
          "from": "busy",
          "input_port": "in",
          "to": "busy",
          "state_change": "queue_count := queue_count + 1"
        }
      ],
      "output_function": [
        {
          "state": "busy",
          "output_port": "out",
          "value": "job"
        }
      ]
    },
