{
  "model_name": "fork_join_10_acd",
  "description": "Fork-Join 10-Queue using Activity Cycle Diagram - 10 parallel branches",
  "parameters": {
    "num_servers": {
      "type": "Nat",
      "value": 5,
      "description": "Number of servers per branch"
    },
    "iat_mean": {
      "type": "Real",
      "value": 1.25,
      "description": "Inter-arrival time mean"
    },
    "ist_mean": {
      "type": "Real",
      "value": 1.0,
      "description": "Service time mean per branch"
    },
    "sim_end_time": {
      "type": "Real",
      "value": 10000.0,
      "description": "Simulation end time"
    }
  },
  "token_types": {
    "Job": {
      "name": "Job",
      "parent": "Token",
      "attributes": {
        "arrival_time": {
          "type": "Real",
          "description": "Time job arrived"
        },
        "service_start_time_1": {
          "type": "Real",
          "description": "Time job started service at branch 1"
        },
        "service_start_time_2": {
          "type": "Real",
          "description": "Time job started service at branch 2"
        },
        "service_start_time_3": {
          "type": "Real",
          "description": "Time job started service at branch 3"
        },
        "service_start_time_4": {
          "type": "Real",
          "description": "Time job started service at branch 4"
        },
        "service_start_time_5": {
          "type": "Real",
          "description": "Time job started service at branch 5"
        },
        "service_start_time_6": {
          "type": "Real",
          "description": "Time job started service at branch 6"
        },
        "service_start_time_7": {
          "type": "Real",
          "description": "Time job started service at branch 7"
        },
        "service_start_time_8": {
          "type": "Real",
          "description": "Time job started service at branch 8"
        },
        "service_start_time_9": {
          "type": "Real",
          "description": "Time job started service at branch 9"
        },
        "service_start_time_10": {
          "type": "Real",
          "description": "Time job started service at branch 10"
        }
      },
      "description": "Customer job token"
    },
    "Resource": {
      "name": "Resource",
      "parent": "Token",
      "attributes": {},
      "description": "Reusable resource token"
    }
  },
  "queues": {
    "C": {
      "token_type": "Resource",
      "is_resource": true,
      "description": "Creator resource queue",
      "initial_marking": 1
    },
    "Q_fork": {
      "token_type": "Job",
      "is_resource": false,
      "description": "Pre-fork queue",
      "initial_marking": 0
    },
    "Q_1": {
      "token_type": "Job",
      "is_resource": false,
      "description": "Job waiting queue at branch 1",
      "initial_marking": 0
    },
    "S_1": {
      "token_type": "Resource",
      "is_resource": true,
      "description": "Server resource queue at branch 1",
      "initial_marking": 5
    },
    "P_1": {
      "token_type": "Job",
      "is_resource": false,
      "description": "Part completion queue at branch 1",
      "initial_marking": 0
    },
    "Q_2": {
      "token_type": "Job",
      "is_resource": false,
      "description": "Job waiting queue at branch 2",
      "initial_marking": 0
    },
    "S_2": {
      "token_type": "Resource",
      "is_resource": true,
      "description": "Server resource queue at branch 2",
      "initial_marking": 5
    },
    "P_2": {
      "token_type": "Job",
      "is_resource": false,
