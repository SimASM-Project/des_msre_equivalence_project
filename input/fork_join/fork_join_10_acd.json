      "initial_marking": 0
    },
    "S_8": {
      "token_type": "Resource",
      "is_resource": true,
      "description": "Server resource queue at branch 8",
      "initial_marking": 5
    },
    "P_8": {
      "token_type": "Job",
      "is_resource": false,
      "description": "Part completion queue at branch 8",
      "initial_marking": 0
    },
    "Q_9": {
      "token_type": "Job",
      "is_resource": false,
