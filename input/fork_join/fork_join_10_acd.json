    "S_10": {
      "token_type": "Resource",
      "is_resource": true,
      "description": "Server resource queue at branch 10",
      "initial_marking": 5
    },
    "P_10": {
      "token_type": "Job",
      "is_resource": false,
      "description": "Part completion queue at branch 10",
      "initial_marking": 0
    },
    "Jobs": {
      "token_type": "Job",
      "is_resource": false,
      "description": "Completed jobs (sink)",
      "initial_marking": 0
    }
  },
  "activities": [
    {
      "name": "Create",
      "priority": 3,
      "description": "Job creation activity",
      "at_begin": {
        "condition": "marking(C) >= 1",
        "action": "C--",
        "bind": [
          "creator_token:C"
        ]
      },
      "bto_event": {
        "time": "duration_create",
        "name": "Create_done"
      },
      "at_end": [
        {
          "arc": 1,
          "action": "C++ <- creator_token; Q_fork++ <- new Job",
          "accumulate": [
            "job_id_counter += 1"
          ]
        }
      ]
    },
    {
      "name": "Fork",
      "priority": 2,
      "description": "Fork: distribute job to all branches",
      "at_begin": {
        "condition": "marking(Q_fork) >= 1",
        "action": "Q_fork--",
        "bind": [
          "fork_token:Q_fork"
        ]
      },
      "bto_event": {
        "time": "duration_fork",
        "name": "Fork_done"
      },
      "at_end": [
        {
          "arc": 1,
          "action": "Q_1++ <- new Job; Q_2++ <- new Job; Q_3++ <- new Job; Q_4++ <- new Job; Q_5++ <- new Job; Q_6++ <- new Job; Q_7++ <- new Job; Q_8++ <- new Job; Q_9++ <- new Job; Q_10++ <- new Job"
        }
      ]
    },
    {
      "name": "Serve_1",
      "priority": 1,
      "description": "Service activity at branch 1",
      "at_begin": {
        "condition": "marking(S_1) >= 1 and marking(Q_1) >= 1",
        "action": "S_1--; Q_1--",
        "bind": [
          "server_token:S_1",
          "job_token:Q_1"
        ],
        "set": [
          "job_token.service_start_time_1 = sim_clocktime"
        ]
      },
      "bto_event": {
        "time": "duration_serve_1",
        "name": "Serve_1_done"
      },
      "at_end": [
        {
          "arc": 1,
          "action": "S_1++ <- server_token; P_1++ <- job_token"
        }
      ]
    },
    {
      "name": "Serve_2",
      "priority": 1,
      "description": "Service activity at branch 2",
      "at_begin": {
        "condition": "marking(S_2) >= 1 and marking(Q_2) >= 1",
        "action": "S_2--; Q_2--",
        "bind": [
          "server_token:S_2",
          "job_token:Q_2"
        ],
        "set": [
          "job_token.service_start_time_2 = sim_clocktime"
        ]
      },
      "bto_event": {
        "time": "duration_serve_2",
        "name": "Serve_2_done"
      },
      "at_end": [
        {
          "arc": 1,
          "action": "S_2++ <- server_token; P_2++ <- job_token"
        }
      ]
    },
    {
      "name": "Serve_3",
