      },
      "stream_name": "service_10"
    }
  },
  "state_variables": {
    "job_id_counter": {
      "type": "Nat",
      "initial": 0
    },
    "departure_count": {
      "type": "Nat",
      "initial": 0
    }
  },
  "stopping_condition": "sim_clocktime >= sim_end_time",
  "observables": {
    "queue_count_1": {
      "name": "queue_count_1",
      "expression": "marking(Q_1)",
      "description": "Number in queue at branch 1"
    },
    "server_count_1": {
      "name": "server_count_1",
      "expression": "num_servers - marking(S_1)",
      "description": "Number of busy servers at branch 1"
    },
    "queue_count_2": {
      "name": "queue_count_2",
      "expression": "marking(Q_2)",
      "description": "Number in queue at branch 2"
    },
    "server_count_2": {
