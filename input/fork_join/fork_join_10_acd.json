      "description": "Part completion queue at branch 3",
      "initial_marking": 0
    },
    "Q_4": {
      "token_type": "Job",
      "is_resource": false,
      "description": "Job waiting queue at branch 4",
      "initial_marking": 0
    },
    "S_4": {
      "token_type": "Resource",
      "is_resource": true,
      "description": "Server resource queue at branch 4",
      "initial_marking": 5
    },
    "P_4": {
      "token_type": "Job",
      "is_resource": false,
      "description": "Part completion queue at branch 4",
      "initial_marking": 0
    },
    "Q_5": {
      "token_type": "Job",
      "is_resource": false,
      "description": "Job waiting queue at branch 5",
      "initial_marking": 0
    },
    "S_5": {
      "token_type": "Resource",
      "is_resource": true,
      "description": "Server resource queue at branch 5",
      "initial_marking": 5
    },
    "P_5": {
      "token_type": "Job",
      "is_resource": false,
      "description": "Part completion queue at branch 5",
      "initial_marking": 0
    },
    "Q_6": {
      "token_type": "Job",
      "is_resource": false,
      "description": "Job waiting queue at branch 6",
      "initial_marking": 0
    },
    "S_6": {
      "token_type": "Resource",
      "is_resource": true,
      "description": "Server resource queue at branch 6",
      "initial_marking": 5
    },
    "P_6": {
      "token_type": "Job",
      "is_resource": false,
