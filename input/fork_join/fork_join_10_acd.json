      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "service_8"
    },
    "duration_serve_9": {
      "distribution": "exponential",
      "params": {
        "mean": "ist_mean"
      },
      "stream_name": "service_9"
    },
    "duration_serve_10": {
      "distribution": "exponential",
      "params": {
