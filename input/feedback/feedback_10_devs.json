          "state_change": "queue_count := queue_count + 1"
        }
      ],
      "output_function": [
        {
          "state": "busy",
          "output_port": "out",
          "value": "job"
        }
      ]
    },
    {
      "name": "Router",
      "description": "Probabilistic router: feedback to Server_1 or depart to Sink",
      "inputs": [
        "in"
      ],
      "outputs": [
        "feedback",
        "depart"
      ],
      "states": [
        {
          "name": "idle",
          "time_advance": "infinity"
        },
        {
          "name": "routing",
          "time_advance": 0
        }
      ],
      "initial_state": "idle",
      "state_variables": {
        "route_decision": {
          "type": "Real",
          "initial": 0.0
        }
      },
      "internal_transitions": [
        {
          "from": "routing",
          "to": "idle"
        }
      ],
      "external_transitions": [
        {
          "from": "idle",
          "input_port": "in",
          "to": "routing",
          "state_change": "route_decision := rnd.uniform(0.0, 1.0)"
        },
        {
          "from": "routing",
          "input_port": "in",
          "to": "routing",
          "state_change": "route_decision := rnd.uniform(0.0, 1.0)"
        }
      ],
      "output_function": [
        {
          "state": "routing",
          "output_port": "feedback",
          "value": "job",
          "condition": "route_decision < feedback_prob"
        },
        {
          "state": "routing",
          "output_port": "depart",
          "value": "job",
          "condition": "route_decision >= feedback_prob"
        }
      ]
    },
    {
      "name": "Sink",
      "description": "Job sink (absorbs completed jobs)",
      "inputs": [
        "in"
      ],
      "outputs": [],
      "states": [
        {
          "name": "idle",
          "time_advance": "infinity"
        }
      ],
      "initial_state": "idle",
      "state_variables": {
        "departure_count": {
          "type": "Nat",
          "initial": 0
        }
      },
      "internal_transitions": [],
      "external_transitions": [
        {
          "from": "idle",
          "input_port": "in",
          "to": "idle",
          "state_change": "departure_count := departure_count + 1"
        }
      ],
      "output_function": []
    }
  ],
