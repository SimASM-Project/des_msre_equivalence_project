{
  "model_name": "tandem_15_acd",
  "description": "Tandem 15-Queue using Activity Cycle Diagram - 15 stations in series",
  "parameters": {
    "num_servers": {
      "type": "Nat",
      "value": 5,
      "description": "Number of servers per station"
    },
    "iat_mean": {
      "type": "Real",
      "value": 1.25,
      "description": "Inter-arrival time mean"
    },
    "ist_mean": {
      "type": "Real",
      "value": 1.0,
      "description": "Service time mean per station"
    },
    "sim_end_time": {
      "type": "Real",
      "value": 10000.0,
      "description": "Simulation end time"
    }
  },
  "token_types": {
    "Job": {
      "name": "Job",
      "parent": "Token",
      "attributes": {
        "arrival_time": {
          "type": "Real",
          "description": "Time job arrived"
        },
        "service_start_time_1": {
