  "activities": [
    {
      "name": "Create",
      "priority": 2,
      "description": "Job creation activity",
      "at_begin": {
        "condition": "marking(C) >= 1",
        "action": "C--",
        "bind": [
          "creator_token:C"
        ]
      },
      "bto_event": {
        "time": "duration_create",
        "name": "Create_done"
      },
      "at_end": [
        {
          "arc": 1,
          "action": "C++ <- creator_token; Q_1++ <- new Job",
          "accumulate": [
            "job_id_counter += 1"
          ]
        }
      ]
    },
    {
      "name": "Serve_1",
      "priority": 1,
      "description": "Service activity at station 1",
      "at_begin": {
        "condition": "marking(S_1) >= 1 and marking(Q_1) >= 1",
        "action": "S_1--; Q_1--",
        "bind": [
          "server_token:S_1",
          "job_token:Q_1"
        ],
        "set": [
          "job_token.service_start_time_1 = sim_clocktime"
        ]
      },
      "bto_event": {
        "time": "duration_serve_1",
        "name": "Serve_1_done"
      },
      "at_end": [
        {
          "arc": 1,
          "action": "S_1++ <- server_token; Q_2++ <- job_token"
        }
      ]
    },
    {
