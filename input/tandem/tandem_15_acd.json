      "description": "Customer job token"
    },
    "Resource": {
      "name": "Resource",
      "parent": "Token",
      "attributes": {},
      "description": "Reusable resource token"
    }
  },
  "queues": {
    "C": {
      "token_type": "Resource",
      "is_resource": true,
      "description": "Creator resource queue",
      "initial_marking": 1
    },
    "Q_1": {
