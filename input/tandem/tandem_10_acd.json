        },
        "service_start_time_9": {
          "type": "Real"
        },
        "service_start_time_10": {
          "type": "Real"
        }
      },
      "description": "Customer job token"
    },
    "Resource": {
      "name": "Resource",
      "parent": "Token",
      "attributes": {},
      "description": "Reusable resource token"
    }
  },
  "queues": {
    "C": {
      "initial_tokens": 1,
      "token_type": "Resource",
      "is_resource": true,
