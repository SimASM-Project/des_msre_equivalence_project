      "expression": "num_servers - marking(S_10)",
      "description": "Number of busy servers at station 10"
    },
    "in_system": {
      "name": "in_system",
      "expression": "marking(Q_1) + (num_servers - marking(S_1)) + marking(Q_2) + (num_servers - marking(S_2)) + marking(Q_3) + (num_servers - marking(S_3)) + marking(Q_4) + (num_servers - marking(S_4)) + marking(Q_5) + (num_servers - marking(S_5)) + marking(Q_6) + (num_servers - marking(S_6)) + marking(Q_7) + (num_servers - marking(S_7)) + marking(Q_8) + (num_servers - marking(S_8)) + marking(Q_9) + (num_servers - marking(S_9)) + marking(Q_10) + (num_servers - marking(S_10))",
      "description": "Total in system"
    }
  },
  "statistics": [
    {
      "name": "L_q_total",
      "type": "time_average",
      "expression": "marking(Q_1) + marking(Q_2) + marking(Q_3) + marking(Q_4) + marking(Q_5) + marking(Q_6) + marking(Q_7) + marking(Q_8) + marking(Q_9) + marking(Q_10)",
      "description": "Average total queue length"
    },
    {
      "name": "L",
      "type": "time_average",
      "expression": "marking(Q_1) + (num_servers - marking(S_1)) + marking(Q_2) + (num_servers - marking(S_2)) + marking(Q_3) + (num_servers - marking(S_3)) + marking(Q_4) + (num_servers - marking(S_4)) + marking(Q_5) + (num_servers - marking(S_5)) + marking(Q_6) + (num_servers - marking(S_6)) + marking(Q_7) + (num_servers - marking(S_7)) + marking(Q_8) + (num_servers - marking(S_8)) + marking(Q_9) + (num_servers - marking(S_9)) + marking(Q_10) + (num_servers - marking(S_10))",
      "description": "Average number in system"
    },
    {
      "name": "throughput",
      "type": "count",
      "expression": "departure_count",
      "description": "Total departures"
    }
  ]
