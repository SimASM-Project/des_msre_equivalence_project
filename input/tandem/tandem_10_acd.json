  "activities": [
    {
      "name": "Create",
      "priority": 2,
      "at_begin": {
        "condition": "true",
        "consume": [
          {
            "queue": "C",
            "count": 1,
            "bind_as": "creator_token"
          }
        ],
        "actions": []
      },
      "at_end": [
        {
          "condition": "true",
          "produce": [
            {
              "queue": "C",
              "count": 1,
              "token_source": "creator_token"
            },
            {
              "queue": "Q_1",
              "count": 1,
              "token_source": "new"
            }
          ],
          "actions": [
            "job_id_counter := job_id_counter + 1"
          ]
        }
      ],
      "description": "Job creation activity",
      "duration": "duration_create"
    },
    {
      "name": "Serve_1",
      "priority": 1,
      "at_begin": {
        "condition": "true",
        "consume": [
          {
            "queue": "S_1",
            "count": 1,
            "bind_as": "server_token"
          },
          {
            "queue": "Q_1",
            "count": 1,
            "bind_as": "job_token"
          }
        ],
        "actions": [
          "service_start_time_1(job_token) := sim_clocktime"
        ]
      },
      "at_end": [
        {
          "condition": "true",
          "produce": [
            {
              "queue": "S_1",
              "count": 1,
              "token_source": "server_token"
            },
            {
