// Internal transition: delta_int for PickA
rule internal_transition_PickA() =
    if phase_PickA == "dispatch_to_1" and PickA_queue_count > 1 and PickA_srv_2_free == 1 then
        phase_PickA := "dispatch_to_2"
        PickA_queue_count := PickA_queue_count - 1
        PickA_srv_1_free := 0
        PickA_server_count := PickA_server_count + 1
    elseif phase_PickA == "dispatch_to_1" and PickA_queue_count > 1 and PickA_srv_2_free == 0 and PickA_srv_3_free == 1 then
        phase_PickA := "dispatch_to_3"
        PickA_queue_count := PickA_queue_count - 1
        PickA_srv_1_free := 0
        PickA_server_count := PickA_server_count + 1
    elseif phase_PickA == "dispatch_to_1" and PickA_queue_count > 1 and PickA_srv_2_free == 0 and PickA_srv_3_free == 0 and PickA_srv_4_free == 1 then
        phase_PickA := "dispatch_to_4"
        PickA_queue_count := PickA_queue_count - 1
        PickA_srv_1_free := 0
        PickA_server_count := PickA_server_count + 1
    elseif phase_PickA == "dispatch_to_1" and PickA_queue_count == 1 then
        phase_PickA := "idle"
        PickA_queue_count := PickA_queue_count - 1
        PickA_srv_1_free := 0
        PickA_server_count := PickA_server_count + 1
    elseif phase_PickA == "dispatch_to_1" and PickA_queue_count > 1 and PickA_srv_2_free == 0 and PickA_srv_3_free == 0 and PickA_srv_4_free == 0 then
        phase_PickA := "idle"
        PickA_queue_count := PickA_queue_count - 1
        PickA_srv_1_free := 0
        PickA_server_count := PickA_server_count + 1
    elseif phase_PickA == "dispatch_to_2" and PickA_queue_count > 1 and PickA_srv_3_free == 1 then
        phase_PickA := "dispatch_to_3"
        PickA_queue_count := PickA_queue_count - 1
        PickA_srv_2_free := 0
        PickA_server_count := PickA_server_count + 1
    elseif phase_PickA == "dispatch_to_2" and PickA_queue_count > 1 and PickA_srv_3_free == 0 and PickA_srv_4_free == 1 then
        phase_PickA := "dispatch_to_4"
        PickA_queue_count := PickA_queue_count - 1
        PickA_srv_2_free := 0
        PickA_server_count := PickA_server_count + 1
    elseif phase_PickA == "dispatch_to_2" and PickA_queue_count == 1 then
        phase_PickA := "idle"
        PickA_queue_count := PickA_queue_count - 1
        PickA_srv_2_free := 0
        PickA_server_count := PickA_server_count + 1
    elseif phase_PickA == "dispatch_to_2" and PickA_queue_count > 1 and PickA_srv_3_free == 0 and PickA_srv_4_free == 0 then
        phase_PickA := "idle"
        PickA_queue_count := PickA_queue_count - 1
        PickA_srv_2_free := 0
        PickA_server_count := PickA_server_count + 1
    elseif phase_PickA == "dispatch_to_3" and PickA_queue_count > 1 and PickA_srv_4_free == 1 then
        phase_PickA := "dispatch_to_4"
        PickA_queue_count := PickA_queue_count - 1
        PickA_srv_3_free := 0
        PickA_server_count := PickA_server_count + 1
    elseif phase_PickA == "dispatch_to_3" and PickA_queue_count == 1 then
        phase_PickA := "idle"
        PickA_queue_count := PickA_queue_count - 1
        PickA_srv_3_free := 0
        PickA_server_count := PickA_server_count + 1
    elseif phase_PickA == "dispatch_to_3" and PickA_queue_count > 1 and PickA_srv_4_free == 0 then
        phase_PickA := "idle"
        PickA_queue_count := PickA_queue_count - 1
        PickA_srv_3_free := 0
        PickA_server_count := PickA_server_count + 1
    elseif phase_PickA == "dispatch_to_4" and PickA_queue_count == 1 then
        phase_PickA := "idle"
        PickA_queue_count := PickA_queue_count - 1
        PickA_srv_4_free := 0
        PickA_server_count := PickA_server_count + 1
    elseif phase_PickA == "dispatch_to_4" and PickA_queue_count > 1 then
        phase_PickA := "idle"
        PickA_queue_count := PickA_queue_count - 1
        PickA_srv_4_free := 0
        PickA_server_count := PickA_server_count + 1
    endif

    // Update timing
    tl_PickA := sim_clocktime
    if phase_PickA == "idle" then
        tn_PickA := sim_clocktime + 999999999.0
    elseif phase_PickA == "dispatch_to_1" then
        tn_PickA := sim_clocktime + 0.0
    elseif phase_PickA == "dispatch_to_2" then
        tn_PickA := sim_clocktime + 0.0
    elseif phase_PickA == "dispatch_to_3" then
        tn_PickA := sim_clocktime + 0.0
    else
        tn_PickA := sim_clocktime + 0.0
    endif
endrule

// External transition: delta_ext for PickA
rule external_transition_PickA() =
    if phase_PickA == "idle" and current_input_port == "in" and PickA_srv_1_free == 1 then
        phase_PickA := "dispatch_to_1"
        PickA_queue_count := PickA_queue_count + 1
        tl_PickA := sim_clocktime
        tn_PickA := sim_clocktime + 0.0
