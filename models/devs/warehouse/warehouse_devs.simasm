// ============================================================
// Coordinator Rules
// ============================================================

// Select imminent component: sort event list, pop earliest (tie-break by Select priority)
rule select_imminent() =
    // Sort event list by scheduled time (stable sort preserves Select priority)
    lib.sort(future_event_list, "cel_time")

    // Pop imminent (earliest) event
    let imminent_event = lib.pop(future_event_list)
    imminent_component := cel_component(imminent_event)

    // Advance clock to event time
    sim_clocktime := cel_time(imminent_event)
endrule

// Route output from imminent component to influenced receivers
rule route_output() =
    if imminent_component == "GenZA1" then
        // Route: GenZA1.out -> PickA.in
        current_input_port := "in"
        external_transition_PickA()
    elseif imminent_component == "GenZA2" then
        // Route: GenZA2.out -> PickA.in
        current_input_port := "in"
        external_transition_PickA()
    elseif imminent_component == "GenZB1" then
        // Route: GenZB1.out -> PickB.in
        current_input_port := "in"
        external_transition_PickB()
    elseif imminent_component == "GenZB2" then
        // Route: GenZB2.out -> PickB.in
        current_input_port := "in"
        external_transition_PickB()
    elseif imminent_component == "PickA" then
        if output_value == "dispatch_1" then
            // Route: PickA.dispatch_1 -> PickA_Srv_1.in
            current_input_port := "in"
            external_transition_PickA_Srv_1()
        elseif output_value == "dispatch_2" then
            // Route: PickA.dispatch_2 -> PickA_Srv_2.in
            current_input_port := "in"
            external_transition_PickA_Srv_2()
        elseif output_value == "dispatch_3" then
            // Route: PickA.dispatch_3 -> PickA_Srv_3.in
            current_input_port := "in"
            external_transition_PickA_Srv_3()
        elseif output_value == "dispatch_4" then
            // Route: PickA.dispatch_4 -> PickA_Srv_4.in
            current_input_port := "in"
            external_transition_PickA_Srv_4()
        endif
    elseif imminent_component == "PickA_Srv_1" then
        // Route: PickA_Srv_1.out -> Label.in
        current_input_port := "in"
        external_transition_Label()
        // Route: PickA_Srv_1.out -> PickA.done_1
        current_input_port := "done_1"
        external_transition_PickA()
    elseif imminent_component == "PickA_Srv_2" then
        // Route: PickA_Srv_2.out -> Label.in
        current_input_port := "in"
        external_transition_Label()
        // Route: PickA_Srv_2.out -> PickA.done_2
        current_input_port := "done_2"
        external_transition_PickA()
    elseif imminent_component == "PickA_Srv_3" then
        // Route: PickA_Srv_3.out -> Label.in
        current_input_port := "in"
        external_transition_Label()
        // Route: PickA_Srv_3.out -> PickA.done_3
        current_input_port := "done_3"
        external_transition_PickA()
    elseif imminent_component == "PickA_Srv_4" then
        // Route: PickA_Srv_4.out -> Label.in
        current_input_port := "in"
        external_transition_Label()
        // Route: PickA_Srv_4.out -> PickA.done_4
        current_input_port := "done_4"
        external_transition_PickA()
    elseif imminent_component == "PickB" then
        if output_value == "dispatch_1" then
            // Route: PickB.dispatch_1 -> PickB_Srv_1.in
            current_input_port := "in"
            external_transition_PickB_Srv_1()
        elseif output_value == "dispatch_2" then
            // Route: PickB.dispatch_2 -> PickB_Srv_2.in
            current_input_port := "in"
            external_transition_PickB_Srv_2()
        endif
    elseif imminent_component == "PickB_Srv_1" then
        // Route: PickB_Srv_1.out -> Label.in
        current_input_port := "in"
        external_transition_Label()
        // Route: PickB_Srv_1.out -> PickB.done_1
        current_input_port := "done_1"
        external_transition_PickB()
    elseif imminent_component == "PickB_Srv_2" then
        // Route: PickB_Srv_2.out -> Label.in
        current_input_port := "in"
        external_transition_Label()
        // Route: PickB_Srv_2.out -> PickB.done_2
        current_input_port := "done_2"
        external_transition_PickB()
    elseif imminent_component == "Label" then
        if output_value == "dispatch_1" then
            // Route: Label.dispatch_1 -> Label_Srv_1.in
            current_input_port := "in"
            external_transition_Label_Srv_1()
        elseif output_value == "dispatch_2" then
            // Route: Label.dispatch_2 -> Label_Srv_2.in
            current_input_port := "in"
            external_transition_Label_Srv_2()
        elseif output_value == "dispatch_3" then
            // Route: Label.dispatch_3 -> Label_Srv_3.in
            current_input_port := "in"
            external_transition_Label_Srv_3()
        endif
    elseif imminent_component == "Label_Srv_1" then
        // Route: Label_Srv_1.out -> Scan.in
        current_input_port := "in"
        external_transition_Scan()
        // Route: Label_Srv_1.out -> Label.done_1
        current_input_port := "done_1"
        external_transition_Label()
    elseif imminent_component == "Label_Srv_2" then
        // Route: Label_Srv_2.out -> Scan.in
        current_input_port := "in"
        external_transition_Scan()
        // Route: Label_Srv_2.out -> Label.done_2
        current_input_port := "done_2"
        external_transition_Label()
    elseif imminent_component == "Label_Srv_3" then
        // Route: Label_Srv_3.out -> Scan.in
        current_input_port := "in"
        external_transition_Scan()
        // Route: Label_Srv_3.out -> Label.done_3
        current_input_port := "done_3"
        external_transition_Label()
    elseif imminent_component == "Scan" then
        // Route: Scan.dispatch_1 -> Scan_Srv_1.in
        current_input_port := "in"
        external_transition_Scan_Srv_1()
    elseif imminent_component == "Scan_Srv_1" then
        // Route: Scan_Srv_1.out -> Pack.in
        current_input_port := "in"
        external_transition_Pack()
        // Route: Scan_Srv_1.out -> Scan.done_1
        current_input_port := "done_1"
        external_transition_Scan()
    elseif imminent_component == "Pack" then
        if output_value == "dispatch_1" then
            // Route: Pack.dispatch_1 -> Pack_Srv_1.in
            current_input_port := "in"
            external_transition_Pack_Srv_1()
        elseif output_value == "dispatch_2" then
            // Route: Pack.dispatch_2 -> Pack_Srv_2.in
            current_input_port := "in"
            external_transition_Pack_Srv_2()
        elseif output_value == "dispatch_3" then
            // Route: Pack.dispatch_3 -> Pack_Srv_3.in
            current_input_port := "in"
            external_transition_Pack_Srv_3()
        endif
    elseif imminent_component == "Pack_Srv_1" then
        // Route: Pack_Srv_1.out -> Release.in
        current_input_port := "in"
        external_transition_Release()
        // Route: Pack_Srv_1.out -> Pack.done_1
        current_input_port := "done_1"
        external_transition_Pack()
    elseif imminent_component == "Pack_Srv_2" then
        // Route: Pack_Srv_2.out -> Release.in
        current_input_port := "in"
        external_transition_Release()
        // Route: Pack_Srv_2.out -> Pack.done_2
        current_input_port := "done_2"
        external_transition_Pack()
    elseif imminent_component == "Pack_Srv_3" then
        // Route: Pack_Srv_3.out -> Release.in
        current_input_port := "in"
        external_transition_Release()
        // Route: Pack_Srv_3.out -> Pack.done_3
        current_input_port := "done_3"
        external_transition_Pack()
    elseif imminent_component == "Release" then
        if output_value == "dispatch_1" then
            // Route: Release.dispatch_1 -> Release_Srv_1.in
            current_input_port := "in"
            external_transition_Release_Srv_1()
        elseif output_value == "dispatch_2" then
            // Route: Release.dispatch_2 -> Release_Srv_2.in
            current_input_port := "in"
            external_transition_Release_Srv_2()
        endif
    elseif imminent_component == "Release_Srv_1" then
        // Route: Release_Srv_1.out -> Sink.in
        current_input_port := "in"
        external_transition_Sink()
        // Route: Release_Srv_1.out -> Release.done_1
        current_input_port := "done_1"
        external_transition_Release()
    elseif imminent_component == "Release_Srv_2" then
        // Route: Release_Srv_2.out -> Sink.in
        current_input_port := "in"
        external_transition_Sink()
        // Route: Release_Srv_2.out -> Release.done_2
        current_input_port := "done_2"
        external_transition_Release()
    endif
endrule

// Rebuild event list from current tn values (Select priority order for tie-breaking)
rule update_event_list() =
    future_event_list := []

    let evt_GenZA1 = new ComponentEvent
    cel_component(evt_GenZA1) := "GenZA1"
    cel_time(evt_GenZA1) := tn_GenZA1
    lib.add(future_event_list, evt_GenZA1)

    let evt_GenZA2 = new ComponentEvent
    cel_component(evt_GenZA2) := "GenZA2"
    cel_time(evt_GenZA2) := tn_GenZA2
    lib.add(future_event_list, evt_GenZA2)

    let evt_GenZB1 = new ComponentEvent
    cel_component(evt_GenZB1) := "GenZB1"
    cel_time(evt_GenZB1) := tn_GenZB1
    lib.add(future_event_list, evt_GenZB1)

    let evt_GenZB2 = new ComponentEvent
    cel_component(evt_GenZB2) := "GenZB2"
    cel_time(evt_GenZB2) := tn_GenZB2
    lib.add(future_event_list, evt_GenZB2)

    let evt_PickA = new ComponentEvent
    cel_component(evt_PickA) := "PickA"
    cel_time(evt_PickA) := tn_PickA
    lib.add(future_event_list, evt_PickA)

    let evt_PickA_Srv_1 = new ComponentEvent
    cel_component(evt_PickA_Srv_1) := "PickA_Srv_1"
    cel_time(evt_PickA_Srv_1) := tn_PickA_Srv_1
    lib.add(future_event_list, evt_PickA_Srv_1)

    let evt_PickA_Srv_2 = new ComponentEvent
