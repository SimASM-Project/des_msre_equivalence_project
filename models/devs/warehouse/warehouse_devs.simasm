    cel_time(evt_Release) := tn_Release
    lib.add(future_event_list, evt_Release)

    let evt_Release_Srv_1 = new ComponentEvent
    cel_component(evt_Release_Srv_1) := "Release_Srv_1"
    cel_time(evt_Release_Srv_1) := tn_Release_Srv_1
    lib.add(future_event_list, evt_Release_Srv_1)

    let evt_Release_Srv_2 = new ComponentEvent
    cel_component(evt_Release_Srv_2) := "Release_Srv_2"
    cel_time(evt_Release_Srv_2) := tn_Release_Srv_2
    lib.add(future_event_list, evt_Release_Srv_2)

    let evt_Sink = new ComponentEvent
    cel_component(evt_Sink) := "Sink"
    cel_time(evt_Sink) := tn_Sink
    lib.add(future_event_list, evt_Sink)

endrule

// ============================================================
// Abstract Simulator Algorithm
// ============================================================

// Initialization: send (i, t0) to all component simulators
rule initialisation_routine() =
    sim_clocktime := 0.0

    // Initialize GenZA1
    phase_GenZA1 := "active"
    tl_GenZA1 := 0.0
    tn_GenZA1 := interarrival_za1
    GenZA1_job_count := 0

    // Initialize GenZA2
    phase_GenZA2 := "active"
    tl_GenZA2 := 0.0
    tn_GenZA2 := interarrival_za2
    GenZA2_job_count := 0

    // Initialize GenZB1
    phase_GenZB1 := "active"
    tl_GenZB1 := 0.0
    tn_GenZB1 := interarrival_zb1
    GenZB1_job_count := 0

    // Initialize GenZB2
    phase_GenZB2 := "active"
    tl_GenZB2 := 0.0
    tn_GenZB2 := interarrival_zb2
    GenZB2_job_count := 0

    // Initialize PickA
    phase_PickA := "idle"
    tl_PickA := 0.0
    tn_PickA := 999999999.0
    PickA_queue_count := 0
    PickA_server_count := 0
    PickA_srv_1_free := 1
    PickA_srv_2_free := 1
    PickA_srv_3_free := 1
    PickA_srv_4_free := 1

    // Initialize PickA_Srv_1
    phase_PickA_Srv_1 := "passive"
    tl_PickA_Srv_1 := 0.0
    tn_PickA_Srv_1 := 999999999.0

    // Initialize PickA_Srv_2
    phase_PickA_Srv_2 := "passive"
    tl_PickA_Srv_2 := 0.0
    tn_PickA_Srv_2 := 999999999.0

    // Initialize PickA_Srv_3
    phase_PickA_Srv_3 := "passive"
    tl_PickA_Srv_3 := 0.0
    tn_PickA_Srv_3 := 999999999.0

    // Initialize PickA_Srv_4
    phase_PickA_Srv_4 := "passive"
    tl_PickA_Srv_4 := 0.0
    tn_PickA_Srv_4 := 999999999.0

    // Initialize PickB
    phase_PickB := "idle"
    tl_PickB := 0.0
    tn_PickB := 999999999.0
    PickB_queue_count := 0
    PickB_server_count := 0
    PickB_srv_1_free := 1
    PickB_srv_2_free := 1

    // Initialize PickB_Srv_1
    phase_PickB_Srv_1 := "passive"
    tl_PickB_Srv_1 := 0.0
    tn_PickB_Srv_1 := 999999999.0

    // Initialize PickB_Srv_2
    phase_PickB_Srv_2 := "passive"
    tl_PickB_Srv_2 := 0.0
    tn_PickB_Srv_2 := 999999999.0

    // Initialize Label
    phase_Label := "idle"
    tl_Label := 0.0
    tn_Label := 999999999.0
    Label_queue_count := 0
    Label_server_count := 0
    Label_srv_1_free := 1
    Label_srv_2_free := 1
    Label_srv_3_free := 1

    // Initialize Label_Srv_1
    phase_Label_Srv_1 := "passive"
    tl_Label_Srv_1 := 0.0
    tn_Label_Srv_1 := 999999999.0

    // Initialize Label_Srv_2
    phase_Label_Srv_2 := "passive"
    tl_Label_Srv_2 := 0.0
    tn_Label_Srv_2 := 999999999.0

    // Initialize Label_Srv_3
    phase_Label_Srv_3 := "passive"
    tl_Label_Srv_3 := 0.0
    tn_Label_Srv_3 := 999999999.0

    // Initialize Scan
    phase_Scan := "idle"
    tl_Scan := 0.0
    tn_Scan := 999999999.0
    Scan_queue_count := 0
    Scan_server_count := 0
    Scan_srv_1_free := 1

    // Initialize Scan_Srv_1
    phase_Scan_Srv_1 := "passive"
    tl_Scan_Srv_1 := 0.0
    tn_Scan_Srv_1 := 999999999.0

    // Initialize Pack
    phase_Pack := "idle"
    tl_Pack := 0.0
    tn_Pack := 999999999.0
    Pack_queue_count := 0
    Pack_server_count := 0
    Pack_srv_1_free := 1
    Pack_srv_2_free := 1
    Pack_srv_3_free := 1

    // Initialize Pack_Srv_1
    phase_Pack_Srv_1 := "passive"
    tl_Pack_Srv_1 := 0.0
    tn_Pack_Srv_1 := 999999999.0

    // Initialize Pack_Srv_2
    phase_Pack_Srv_2 := "passive"
    tl_Pack_Srv_2 := 0.0
    tn_Pack_Srv_2 := 999999999.0

    // Initialize Pack_Srv_3
    phase_Pack_Srv_3 := "passive"
    tl_Pack_Srv_3 := 0.0
    tn_Pack_Srv_3 := 999999999.0

    // Initialize Release
    phase_Release := "idle"
    tl_Release := 0.0
    tn_Release := 999999999.0
    Release_queue_count := 0
    Release_server_count := 0
    Release_srv_1_free := 1
    Release_srv_2_free := 1

    // Initialize Release_Srv_1
    phase_Release_Srv_1 := "passive"
    tl_Release_Srv_1 := 0.0
    tn_Release_Srv_1 := 999999999.0

    // Initialize Release_Srv_2
    phase_Release_Srv_2 := "passive"
    tl_Release_Srv_2 := 0.0
    tn_Release_Srv_2 := 999999999.0

    // Initialize Sink
    phase_Sink := "idle"
    tl_Sink := 0.0
    tn_Sink := 999999999.0
    Sink_departure_count := 0

    stopping_condition := false

    // Initialize event list
    future_event_list := []
    let evt_GenZA1 = new ComponentEvent
    cel_component(evt_GenZA1) := "GenZA1"
    cel_time(evt_GenZA1) := tn_GenZA1
    lib.add(future_event_list, evt_GenZA1)
    let evt_GenZA2 = new ComponentEvent
    cel_component(evt_GenZA2) := "GenZA2"
    cel_time(evt_GenZA2) := tn_GenZA2
    lib.add(future_event_list, evt_GenZA2)
    let evt_GenZB1 = new ComponentEvent
    cel_component(evt_GenZB1) := "GenZB1"
    cel_time(evt_GenZB1) := tn_GenZB1
    lib.add(future_event_list, evt_GenZB1)
    let evt_GenZB2 = new ComponentEvent
    cel_component(evt_GenZB2) := "GenZB2"
    cel_time(evt_GenZB2) := tn_GenZB2
    lib.add(future_event_list, evt_GenZB2)
    let evt_PickA = new ComponentEvent
    cel_component(evt_PickA) := "PickA"
    cel_time(evt_PickA) := tn_PickA
    lib.add(future_event_list, evt_PickA)
    let evt_PickA_Srv_1 = new ComponentEvent
    cel_component(evt_PickA_Srv_1) := "PickA_Srv_1"
    cel_time(evt_PickA_Srv_1) := tn_PickA_Srv_1
    lib.add(future_event_list, evt_PickA_Srv_1)
    let evt_PickA_Srv_2 = new ComponentEvent
    cel_component(evt_PickA_Srv_2) := "PickA_Srv_2"
    cel_time(evt_PickA_Srv_2) := tn_PickA_Srv_2
    lib.add(future_event_list, evt_PickA_Srv_2)
    let evt_PickA_Srv_3 = new ComponentEvent
    cel_component(evt_PickA_Srv_3) := "PickA_Srv_3"
    cel_time(evt_PickA_Srv_3) := tn_PickA_Srv_3
    lib.add(future_event_list, evt_PickA_Srv_3)
    let evt_PickA_Srv_4 = new ComponentEvent
    cel_component(evt_PickA_Srv_4) := "PickA_Srv_4"
    cel_time(evt_PickA_Srv_4) := tn_PickA_Srv_4
    lib.add(future_event_list, evt_PickA_Srv_4)
    let evt_PickB = new ComponentEvent
    cel_component(evt_PickB) := "PickB"
    cel_time(evt_PickB) := tn_PickB
    lib.add(future_event_list, evt_PickB)
    let evt_PickB_Srv_1 = new ComponentEvent
    cel_component(evt_PickB_Srv_1) := "PickB_Srv_1"
    cel_time(evt_PickB_Srv_1) := tn_PickB_Srv_1
    lib.add(future_event_list, evt_PickB_Srv_1)
    let evt_PickB_Srv_2 = new ComponentEvent
    cel_component(evt_PickB_Srv_2) := "PickB_Srv_2"
    cel_time(evt_PickB_Srv_2) := tn_PickB_Srv_2
    lib.add(future_event_list, evt_PickB_Srv_2)
    let evt_Label = new ComponentEvent
    cel_component(evt_Label) := "Label"
    cel_time(evt_Label) := tn_Label
    lib.add(future_event_list, evt_Label)
    let evt_Label_Srv_1 = new ComponentEvent
    cel_component(evt_Label_Srv_1) := "Label_Srv_1"
    cel_time(evt_Label_Srv_1) := tn_Label_Srv_1
    lib.add(future_event_list, evt_Label_Srv_1)
    let evt_Label_Srv_2 = new ComponentEvent
    cel_component(evt_Label_Srv_2) := "Label_Srv_2"
    cel_time(evt_Label_Srv_2) := tn_Label_Srv_2
    lib.add(future_event_list, evt_Label_Srv_2)
    let evt_Label_Srv_3 = new ComponentEvent
    cel_component(evt_Label_Srv_3) := "Label_Srv_3"
    cel_time(evt_Label_Srv_3) := tn_Label_Srv_3
    lib.add(future_event_list, evt_Label_Srv_3)
    let evt_Scan = new ComponentEvent
    cel_component(evt_Scan) := "Scan"
    cel_time(evt_Scan) := tn_Scan
    lib.add(future_event_list, evt_Scan)
    let evt_Scan_Srv_1 = new ComponentEvent
    cel_component(evt_Scan_Srv_1) := "Scan_Srv_1"
    cel_time(evt_Scan_Srv_1) := tn_Scan_Srv_1
    lib.add(future_event_list, evt_Scan_Srv_1)
    let evt_Pack = new ComponentEvent
    cel_component(evt_Pack) := "Pack"
    cel_time(evt_Pack) := tn_Pack
    lib.add(future_event_list, evt_Pack)
    let evt_Pack_Srv_1 = new ComponentEvent
    cel_component(evt_Pack_Srv_1) := "Pack_Srv_1"
    cel_time(evt_Pack_Srv_1) := tn_Pack_Srv_1
    lib.add(future_event_list, evt_Pack_Srv_1)
    let evt_Pack_Srv_2 = new ComponentEvent
    cel_component(evt_Pack_Srv_2) := "Pack_Srv_2"
    cel_time(evt_Pack_Srv_2) := tn_Pack_Srv_2
    lib.add(future_event_list, evt_Pack_Srv_2)
    let evt_Pack_Srv_3 = new ComponentEvent
    cel_component(evt_Pack_Srv_3) := "Pack_Srv_3"
    cel_time(evt_Pack_Srv_3) := tn_Pack_Srv_3
    lib.add(future_event_list, evt_Pack_Srv_3)
    let evt_Release = new ComponentEvent
    cel_component(evt_Release) := "Release"
    cel_time(evt_Release) := tn_Release
    lib.add(future_event_list, evt_Release)
    let evt_Release_Srv_1 = new ComponentEvent
    cel_component(evt_Release_Srv_1) := "Release_Srv_1"
    cel_time(evt_Release_Srv_1) := tn_Release_Srv_1
    lib.add(future_event_list, evt_Release_Srv_1)
    let evt_Release_Srv_2 = new ComponentEvent
    cel_component(evt_Release_Srv_2) := "Release_Srv_2"
    cel_time(evt_Release_Srv_2) := tn_Release_Srv_2
    lib.add(future_event_list, evt_Release_Srv_2)
    let evt_Sink = new ComponentEvent
    cel_component(evt_Sink) := "Sink"
    cel_time(evt_Sink) := tn_Sink
    lib.add(future_event_list, evt_Sink)
endrule

// One macro-step of the Abstract Simulator
rule simulator_step() =
    // Phase 1: Select imminent and advance time (sort FEL, pop earliest)
    select_imminent()

    // Phase 2: Output function (lambda) then internal transition (delta_int)
    output_value := ""
    if imminent_component == "GenZA1" then
        output_function_GenZA1()
        internal_transition_GenZA1()
    elseif imminent_component == "GenZA2" then
        output_function_GenZA2()
        internal_transition_GenZA2()
    elseif imminent_component == "GenZB1" then
        output_function_GenZB1()
        internal_transition_GenZB1()
    elseif imminent_component == "GenZB2" then
        output_function_GenZB2()
        internal_transition_GenZB2()
    elseif imminent_component == "PickA" then
        output_function_PickA()
        internal_transition_PickA()
    elseif imminent_component == "PickA_Srv_1" then
        output_function_PickA_Srv_1()
        internal_transition_PickA_Srv_1()
    elseif imminent_component == "PickA_Srv_2" then
        output_function_PickA_Srv_2()
        internal_transition_PickA_Srv_2()
    elseif imminent_component == "PickA_Srv_3" then
        output_function_PickA_Srv_3()
        internal_transition_PickA_Srv_3()
    elseif imminent_component == "PickA_Srv_4" then
        output_function_PickA_Srv_4()
        internal_transition_PickA_Srv_4()
    elseif imminent_component == "PickB" then
        output_function_PickB()
        internal_transition_PickB()
    elseif imminent_component == "PickB_Srv_1" then
        output_function_PickB_Srv_1()
        internal_transition_PickB_Srv_1()
    elseif imminent_component == "PickB_Srv_2" then
        output_function_PickB_Srv_2()
        internal_transition_PickB_Srv_2()
    elseif imminent_component == "Label" then
        output_function_Label()
        internal_transition_Label()
    elseif imminent_component == "Label_Srv_1" then
        output_function_Label_Srv_1()
        internal_transition_Label_Srv_1()
    elseif imminent_component == "Label_Srv_2" then
        output_function_Label_Srv_2()
        internal_transition_Label_Srv_2()
    elseif imminent_component == "Label_Srv_3" then
        output_function_Label_Srv_3()
        internal_transition_Label_Srv_3()
    elseif imminent_component == "Scan" then
        output_function_Scan()
        internal_transition_Scan()
    elseif imminent_component == "Scan_Srv_1" then
        output_function_Scan_Srv_1()
        internal_transition_Scan_Srv_1()
    elseif imminent_component == "Pack" then
        output_function_Pack()
        internal_transition_Pack()
    elseif imminent_component == "Pack_Srv_1" then
        output_function_Pack_Srv_1()
        internal_transition_Pack_Srv_1()
    elseif imminent_component == "Pack_Srv_2" then
        output_function_Pack_Srv_2()
        internal_transition_Pack_Srv_2()
    elseif imminent_component == "Pack_Srv_3" then
        output_function_Pack_Srv_3()
        internal_transition_Pack_Srv_3()
    elseif imminent_component == "Release" then
        output_function_Release()
        internal_transition_Release()
    elseif imminent_component == "Release_Srv_1" then
        output_function_Release_Srv_1()
        internal_transition_Release_Srv_1()
    elseif imminent_component == "Release_Srv_2" then
        output_function_Release_Srv_2()
        internal_transition_Release_Srv_2()
    elseif imminent_component == "Sink" then
        output_function_Sink()
        internal_transition_Sink()
    endif

    // Phase 3: Route output to receivers (only if lambda produced output)
    if output_value != "" then
        route_output()
    endif

    // Phase 4: Rebuild event list with updated tn values
    update_event_list()

    // Phase 5: Check stopping condition
    if sim_clocktime >= sim_end_time then
        stopping_condition := true
    endif
endrule

// ============================================================
// Initialization Block
// ============================================================

init:
    Q1_max := 30
    Q2_max := 20
    Q3_max := 50
    Q4_max := 20
    Q5_max := 30
    Q6_max := 20
    S1_capacity := 4
    S2_capacity := 2
    S3_capacity := 3
    S4_capacity := 1
    S5_capacity := 3
    S6_capacity := 2
    iat_c1_mean := 325.5
    iat_c2_mean := 527.6
    iat_c3_mean := 226.1
    iat_c4_mean := 985.6
    ist_s1_mean := 78.4
    ist_s2_mean := 76.2
    ist_s3_mean := 288.8
    ist_s4_mean := 31.2
    ist_s5_mean := 66.8
    ist_s6_mean := 1.0
    sim_end_time := 10000.0

    future_event_list := []
    initialisation_routine()
endinit

// ============================================================
// Main Rule
// ============================================================

main rule main =
    if not stopping_condition then
        simulator_step()
    else
        skip
    endif
endrule