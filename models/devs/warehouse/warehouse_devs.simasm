    lib.add(future_event_list, evt_Label_Srv_1)

    let evt_Label_Srv_2 = new ComponentEvent
    cel_component(evt_Label_Srv_2) := "Label_Srv_2"
    cel_time(evt_Label_Srv_2) := tn_Label_Srv_2
    lib.add(future_event_list, evt_Label_Srv_2)

    let evt_Label_Srv_3 = new ComponentEvent
    cel_component(evt_Label_Srv_3) := "Label_Srv_3"
    cel_time(evt_Label_Srv_3) := tn_Label_Srv_3
