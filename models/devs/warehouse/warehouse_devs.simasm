// Internal transition: delta_int for GenZA1
rule internal_transition_GenZA1() =
    if phase_GenZA1 == "active" then
        phase_GenZA1 := "active"
        GenZA1_job_count := GenZA1_job_count + 1
    endif

    // Update timing
    tl_GenZA1 := sim_clocktime
    tn_GenZA1 := sim_clocktime + interarrival_za1
endrule

// External transition: delta_ext for GenZA1
rule external_transition_GenZA1() =
    skip
endrule

// Output function: lambda for GenZA1
rule output_function_GenZA1() =
    if phase_GenZA1 == "active" then
        output_value := "out"
    endif
endrule

