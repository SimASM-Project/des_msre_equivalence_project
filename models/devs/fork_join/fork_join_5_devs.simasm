// SimASM: fork_join_5_devs
// Fork-Join 5-Queue using DEVS formalism - 5 parallel branches with synchronizing join
// Generated from DEVS specification
// Date: 2026-03-06 21:47:45
// Formalism: Discrete Event System Specification (DEVS)
// Algorithm: Abstract Simulator (Zeigler et al. 2019)

// ============================================================
// Imports
// ============================================================

import Random as rnd
import Stdlib as lib

// ============================================================
// Domains
// ============================================================

// Components: Generator, Forker, Branch_Server_1, Branch_Server_2, Branch_Server_3, Branch_Server_4, Branch_Server_5, Joiner, Sink
domain Component

// Phases: active
domain Phase_Generator
// Phases: idle, forking
domain Phase_Forker
// Phases: passive, starting, busy
domain Phase_Branch_Server_1
// Phases: passive, starting, busy
domain Phase_Branch_Server_2
// Phases: passive, starting, busy
domain Phase_Branch_Server_3
// Phases: passive, starting, busy
domain Phase_Branch_Server_4
// Phases: passive, starting, busy
domain Phase_Branch_Server_5
// Phases: idle, checking, joining
domain Phase_Joiner
// Phases: idle
domain Phase_Sink

domain Object
domain Load <: Object

// Coordinator event type
domain ComponentEvent

// Multi-server finish time tracking
domain FinishTime

// ============================================================
// Constants
// ============================================================

const service_capacity: Nat
const iat_mean: Real
const ist_mean: Real
const sim_end_time: Real

// ============================================================
