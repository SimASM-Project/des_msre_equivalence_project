    elseif phase_Joiner == "checking" and current_input_port == "in_4" then
        phase_Joiner := "checking"
        Joiner_part_4_count := Joiner_part_4_count + 1
    elseif phase_Joiner == "joining" and current_input_port == "in_4" then
        phase_Joiner := "checking"
        Joiner_part_4_count := Joiner_part_4_count + 1
        tl_Joiner := sim_clocktime
        tn_Joiner := sim_clocktime + 0.0
    elseif phase_Joiner == "idle" and current_input_port == "in_5" then
        phase_Joiner := "checking"
        Joiner_part_5_count := Joiner_part_5_count + 1
        tl_Joiner := sim_clocktime
        tn_Joiner := sim_clocktime + 0.0
    elseif phase_Joiner == "checking" and current_input_port == "in_5" then
        phase_Joiner := "checking"
        Joiner_part_5_count := Joiner_part_5_count + 1
    elseif phase_Joiner == "joining" and current_input_port == "in_5" then
        phase_Joiner := "checking"
        Joiner_part_5_count := Joiner_part_5_count + 1
        tl_Joiner := sim_clocktime
        tn_Joiner := sim_clocktime + 0.0
    endif
endrule

// Output function: lambda for Joiner
rule output_function_Joiner() =
    if phase_Joiner == "joining" then
        output_value := "out"
    endif
endrule

// Internal transition: delta_int for Sink
rule internal_transition_Sink() =
    skip
endrule

// External transition: delta_ext for Sink
rule external_transition_Sink() =
    if phase_Sink == "idle" then
        phase_Sink := "idle"
        Sink_departure_count := Sink_departure_count + 1
    endif
endrule

// Output function: lambda for Sink
rule output_function_Sink() =
    skip
endrule


// ============================================================
// Coordinator Rules
// ============================================================

// Select imminent component: sort event list, pop earliest (tie-break by Select priority)
rule select_imminent() =
    // Sort event list by scheduled time (stable sort preserves Select priority)
    lib.sort(future_event_list, "cel_time")

    // Pop imminent (earliest) event
    let imminent_event = lib.pop(future_event_list)
    imminent_component := cel_component(imminent_event)

    // Advance clock to event time
    sim_clocktime := cel_time(imminent_event)
endrule

// Route output from imminent component to influenced receivers
rule route_output() =
    if imminent_component == "Generator" then
        // Route: Generator.out -> Forker.in
        current_input_port := "in"
        external_transition_Forker()
    elseif imminent_component == "Forker" then
        // Route: Forker.out -> Branch_Server_1.in
        current_input_port := "in"
        external_transition_Branch_Server_1()
        // Route: Forker.out -> Branch_Server_2.in
        current_input_port := "in"
        external_transition_Branch_Server_2()
        // Route: Forker.out -> Branch_Server_3.in
        current_input_port := "in"
        external_transition_Branch_Server_3()
        // Route: Forker.out -> Branch_Server_4.in
        current_input_port := "in"
        external_transition_Branch_Server_4()
        // Route: Forker.out -> Branch_Server_5.in
        current_input_port := "in"
        external_transition_Branch_Server_5()
    elseif imminent_component == "Branch_Server_1" then
        // Route: Branch_Server_1.out -> Joiner.in_1
        current_input_port := "in_1"
        external_transition_Joiner()
    elseif imminent_component == "Branch_Server_2" then
        // Route: Branch_Server_2.out -> Joiner.in_2
        current_input_port := "in_2"
        external_transition_Joiner()
    elseif imminent_component == "Branch_Server_3" then
        // Route: Branch_Server_3.out -> Joiner.in_3
        current_input_port := "in_3"
        external_transition_Joiner()
    elseif imminent_component == "Branch_Server_4" then
        // Route: Branch_Server_4.out -> Joiner.in_4
        current_input_port := "in_4"
        external_transition_Joiner()
    elseif imminent_component == "Branch_Server_5" then
        // Route: Branch_Server_5.out -> Joiner.in_5
        current_input_port := "in_5"
        external_transition_Joiner()
    elseif imminent_component == "Joiner" then
        // Route: Joiner.out -> Sink.in
        current_input_port := "in"
        external_transition_Sink()
    endif
endrule

// Rebuild event list from current tn values (Select priority order for tie-breaking)
rule update_event_list() =
    future_event_list := []

    let evt_Generator = new ComponentEvent
    cel_component(evt_Generator) := "Generator"
    cel_time(evt_Generator) := tn_Generator
    lib.add(future_event_list, evt_Generator)

    let evt_Forker = new ComponentEvent
    cel_component(evt_Forker) := "Forker"
    cel_time(evt_Forker) := tn_Forker
    lib.add(future_event_list, evt_Forker)

    let evt_Branch_Server_1 = new ComponentEvent
    cel_component(evt_Branch_Server_1) := "Branch_Server_1"
    cel_time(evt_Branch_Server_1) := tn_Branch_Server_1
    lib.add(future_event_list, evt_Branch_Server_1)

    let evt_Branch_Server_2 = new ComponentEvent
    cel_component(evt_Branch_Server_2) := "Branch_Server_2"
    cel_time(evt_Branch_Server_2) := tn_Branch_Server_2
    lib.add(future_event_list, evt_Branch_Server_2)

    let evt_Branch_Server_3 = new ComponentEvent
    cel_component(evt_Branch_Server_3) := "Branch_Server_3"
    cel_time(evt_Branch_Server_3) := tn_Branch_Server_3
    lib.add(future_event_list, evt_Branch_Server_3)

    let evt_Branch_Server_4 = new ComponentEvent
    cel_component(evt_Branch_Server_4) := "Branch_Server_4"
    cel_time(evt_Branch_Server_4) := tn_Branch_Server_4
    lib.add(future_event_list, evt_Branch_Server_4)

    let evt_Branch_Server_5 = new ComponentEvent
    cel_component(evt_Branch_Server_5) := "Branch_Server_5"
    cel_time(evt_Branch_Server_5) := tn_Branch_Server_5
    lib.add(future_event_list, evt_Branch_Server_5)

    let evt_Joiner = new ComponentEvent
    cel_component(evt_Joiner) := "Joiner"
    cel_time(evt_Joiner) := tn_Joiner
    lib.add(future_event_list, evt_Joiner)

    let evt_Sink = new ComponentEvent
    cel_component(evt_Sink) := "Sink"
    cel_time(evt_Sink) := tn_Sink
    lib.add(future_event_list, evt_Sink)

endrule

// ============================================================
// Abstract Simulator Algorithm
// ============================================================

// Initialization: send (i, t0) to all component simulators
rule initialisation_routine() =
    sim_clocktime := 0.0

    // Initialize Generator
    phase_Generator := "active"
    tl_Generator := 0.0
    tn_Generator := interarrival_time
    Generator_job_count := 0

    // Initialize Forker
    phase_Forker := "idle"
    tl_Forker := 0.0
    tn_Forker := 999999999.0

    // Initialize Branch_Server_1
    phase_Branch_Server_1 := "passive"
    tl_Branch_Server_1 := 0.0
    tn_Branch_Server_1 := 999999999.0
    Branch_Server_1_queue_count := 0
    Branch_Server_1_server_count := 0
    Branch_Server_1_finish_list := []

    // Initialize Branch_Server_2
    phase_Branch_Server_2 := "passive"
    tl_Branch_Server_2 := 0.0
    tn_Branch_Server_2 := 999999999.0
    Branch_Server_2_queue_count := 0
    Branch_Server_2_server_count := 0
    Branch_Server_2_finish_list := []

    // Initialize Branch_Server_3
    phase_Branch_Server_3 := "passive"
    tl_Branch_Server_3 := 0.0
    tn_Branch_Server_3 := 999999999.0
    Branch_Server_3_queue_count := 0
    Branch_Server_3_server_count := 0
    Branch_Server_3_finish_list := []

    // Initialize Branch_Server_4
    phase_Branch_Server_4 := "passive"
    tl_Branch_Server_4 := 0.0
    tn_Branch_Server_4 := 999999999.0
    Branch_Server_4_queue_count := 0
    Branch_Server_4_server_count := 0
    Branch_Server_4_finish_list := []

    // Initialize Branch_Server_5
    phase_Branch_Server_5 := "passive"
    tl_Branch_Server_5 := 0.0
    tn_Branch_Server_5 := 999999999.0
    Branch_Server_5_queue_count := 0
    Branch_Server_5_server_count := 0
    Branch_Server_5_finish_list := []

    // Initialize Joiner
    phase_Joiner := "idle"
    tl_Joiner := 0.0
    tn_Joiner := 999999999.0
    Joiner_part_1_count := 0
    Joiner_part_2_count := 0
    Joiner_part_3_count := 0
    Joiner_part_4_count := 0
    Joiner_part_5_count := 0

    // Initialize Sink
    phase_Sink := "idle"
    tl_Sink := 0.0
    tn_Sink := 999999999.0
    Sink_departure_count := 0

    stopping_condition := false

    // Initialize event list
    future_event_list := []
    let evt_Generator = new ComponentEvent
    cel_component(evt_Generator) := "Generator"
    cel_time(evt_Generator) := tn_Generator
    lib.add(future_event_list, evt_Generator)
    let evt_Forker = new ComponentEvent
    cel_component(evt_Forker) := "Forker"
    cel_time(evt_Forker) := tn_Forker
    lib.add(future_event_list, evt_Forker)
    let evt_Branch_Server_1 = new ComponentEvent
    cel_component(evt_Branch_Server_1) := "Branch_Server_1"
    cel_time(evt_Branch_Server_1) := tn_Branch_Server_1
    lib.add(future_event_list, evt_Branch_Server_1)
    let evt_Branch_Server_2 = new ComponentEvent
    cel_component(evt_Branch_Server_2) := "Branch_Server_2"
    cel_time(evt_Branch_Server_2) := tn_Branch_Server_2
    lib.add(future_event_list, evt_Branch_Server_2)
    let evt_Branch_Server_3 = new ComponentEvent
    cel_component(evt_Branch_Server_3) := "Branch_Server_3"
    cel_time(evt_Branch_Server_3) := tn_Branch_Server_3
    lib.add(future_event_list, evt_Branch_Server_3)
    let evt_Branch_Server_4 = new ComponentEvent
    cel_component(evt_Branch_Server_4) := "Branch_Server_4"
    cel_time(evt_Branch_Server_4) := tn_Branch_Server_4
    lib.add(future_event_list, evt_Branch_Server_4)
    let evt_Branch_Server_5 = new ComponentEvent
    cel_component(evt_Branch_Server_5) := "Branch_Server_5"
    cel_time(evt_Branch_Server_5) := tn_Branch_Server_5
    lib.add(future_event_list, evt_Branch_Server_5)
    let evt_Joiner = new ComponentEvent
    cel_component(evt_Joiner) := "Joiner"
    cel_time(evt_Joiner) := tn_Joiner
    lib.add(future_event_list, evt_Joiner)
    let evt_Sink = new ComponentEvent
    cel_component(evt_Sink) := "Sink"
    cel_time(evt_Sink) := tn_Sink
    lib.add(future_event_list, evt_Sink)
endrule

// One macro-step of the Abstract Simulator
rule simulator_step() =
    // Phase 1: Select imminent and advance time (sort FEL, pop earliest)
    select_imminent()

    // Phase 2: Output function (lambda) then internal transition (delta_int)
    output_value := ""
    if imminent_component == "Generator" then
        output_function_Generator()
        internal_transition_Generator()
    elseif imminent_component == "Forker" then
        output_function_Forker()
        internal_transition_Forker()
    elseif imminent_component == "Branch_Server_1" then
        output_function_Branch_Server_1()
        internal_transition_Branch_Server_1()
    elseif imminent_component == "Branch_Server_2" then
        output_function_Branch_Server_2()
        internal_transition_Branch_Server_2()
    elseif imminent_component == "Branch_Server_3" then
        output_function_Branch_Server_3()
        internal_transition_Branch_Server_3()
    elseif imminent_component == "Branch_Server_4" then
        output_function_Branch_Server_4()
        internal_transition_Branch_Server_4()
    elseif imminent_component == "Branch_Server_5" then
        output_function_Branch_Server_5()
        internal_transition_Branch_Server_5()
    elseif imminent_component == "Joiner" then
        output_function_Joiner()
        internal_transition_Joiner()
    elseif imminent_component == "Sink" then
        output_function_Sink()
        internal_transition_Sink()
    endif

    // Phase 3: Route output to receivers (only if lambda produced output)
    if output_value != "" then
        route_output()
    endif

    // Phase 4: Rebuild event list with updated tn values
    update_event_list()

    // Phase 5: Check stopping condition
    if sim_clocktime >= sim_end_time then
        stopping_condition := true
    endif
endrule

// ============================================================
// Initialization Block
// ============================================================

init:
    service_capacity := 5
    iat_mean := 1.25
    ist_mean := 1.0
    sim_end_time := 10000.0

    future_event_list := []
    initialisation_routine()
endinit

// ============================================================
// Main Rule
// ============================================================

main rule main =
    if not stopping_condition then
        simulator_step()
    else
        skip
    endif
endrule