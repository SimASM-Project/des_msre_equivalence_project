// Internal transition: delta_int for Joiner
rule internal_transition_Joiner() =
    if phase_Joiner == "checking" and Joiner_part_1_count > 0 and Joiner_part_2_count > 0 and Joiner_part_3_count > 0 and Joiner_part_4_count > 0 and Joiner_part_5_count > 0 then
        phase_Joiner := "joining"
    elseif phase_Joiner == "checking" and not (Joiner_part_1_count > 0 and Joiner_part_2_count > 0 and Joiner_part_3_count > 0 and Joiner_part_4_count > 0 and Joiner_part_5_count > 0) then
        phase_Joiner := "idle"
    elseif phase_Joiner == "joining" then
        phase_Joiner := "idle"
        Joiner_part_1_count := Joiner_part_1_count - 1
        Joiner_part_2_count := Joiner_part_2_count - 1
        Joiner_part_3_count := Joiner_part_3_count - 1
        Joiner_part_4_count := Joiner_part_4_count - 1
        Joiner_part_5_count := Joiner_part_5_count - 1
    endif

    // Update timing
    tl_Joiner := sim_clocktime
    if phase_Joiner == "idle" then
        tn_Joiner := sim_clocktime + 999999999.0
    elseif phase_Joiner == "checking" then
        tn_Joiner := sim_clocktime + 0.0
    else
        tn_Joiner := sim_clocktime + 0.0
    endif
endrule

// External transition: delta_ext for Joiner
rule external_transition_Joiner() =
    if phase_Joiner == "idle" and current_input_port == "in_1" then
        phase_Joiner := "checking"
        Joiner_part_1_count := Joiner_part_1_count + 1
        tl_Joiner := sim_clocktime
        tn_Joiner := sim_clocktime + 0.0
    elseif phase_Joiner == "checking" and current_input_port == "in_1" then
        phase_Joiner := "checking"
        Joiner_part_1_count := Joiner_part_1_count + 1
    elseif phase_Joiner == "joining" and current_input_port == "in_1" then
        phase_Joiner := "checking"
        Joiner_part_1_count := Joiner_part_1_count + 1
        tl_Joiner := sim_clocktime
        tn_Joiner := sim_clocktime + 0.0
    elseif phase_Joiner == "idle" and current_input_port == "in_2" then
        phase_Joiner := "checking"
        Joiner_part_2_count := Joiner_part_2_count + 1
        tl_Joiner := sim_clocktime
        tn_Joiner := sim_clocktime + 0.0
    elseif phase_Joiner == "checking" and current_input_port == "in_2" then
        phase_Joiner := "checking"
        Joiner_part_2_count := Joiner_part_2_count + 1
    elseif phase_Joiner == "joining" and current_input_port == "in_2" then
        phase_Joiner := "checking"
        Joiner_part_2_count := Joiner_part_2_count + 1
        tl_Joiner := sim_clocktime
        tn_Joiner := sim_clocktime + 0.0
    elseif phase_Joiner == "idle" and current_input_port == "in_3" then
