    elseif phase_Joiner == "checking" and current_input_port == "in_3" then
        phase_Joiner := "checking"
        Joiner_part_3_count := Joiner_part_3_count + 1
    elseif phase_Joiner == "joining" and current_input_port == "in_3" then
        phase_Joiner := "checking"
        Joiner_part_3_count := Joiner_part_3_count + 1
        tl_Joiner := sim_clocktime
