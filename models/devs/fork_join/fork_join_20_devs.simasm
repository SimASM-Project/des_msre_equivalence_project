// One macro-step of the Abstract Simulator
rule simulator_step() =
    // Phase 1: Select imminent and advance time (sort FEL, pop earliest)
    select_imminent()

    // Phase 2: Output function (lambda) then internal transition (delta_int)
    output_value := ""
    if imminent_component == "Generator" then
        output_function_Generator()
        internal_transition_Generator()
    elseif imminent_component == "Forker" then
        output_function_Forker()
        internal_transition_Forker()
    elseif imminent_component == "Branch_Server_1" then
        output_function_Branch_Server_1()
        internal_transition_Branch_Server_1()
    elseif imminent_component == "Branch_Server_2" then
        output_function_Branch_Server_2()
        internal_transition_Branch_Server_2()
    elseif imminent_component == "Branch_Server_3" then
        output_function_Branch_Server_3()
        internal_transition_Branch_Server_3()
    elseif imminent_component == "Branch_Server_4" then
        output_function_Branch_Server_4()
        internal_transition_Branch_Server_4()
    elseif imminent_component == "Branch_Server_5" then
        output_function_Branch_Server_5()
        internal_transition_Branch_Server_5()
    elseif imminent_component == "Branch_Server_6" then
        output_function_Branch_Server_6()
        internal_transition_Branch_Server_6()
    elseif imminent_component == "Branch_Server_7" then
        output_function_Branch_Server_7()
        internal_transition_Branch_Server_7()
    elseif imminent_component == "Branch_Server_8" then
        output_function_Branch_Server_8()
        internal_transition_Branch_Server_8()
    elseif imminent_component == "Branch_Server_9" then
        output_function_Branch_Server_9()
        internal_transition_Branch_Server_9()
    elseif imminent_component == "Branch_Server_10" then
        output_function_Branch_Server_10()
        internal_transition_Branch_Server_10()
    elseif imminent_component == "Branch_Server_11" then
        output_function_Branch_Server_11()
        internal_transition_Branch_Server_11()
    elseif imminent_component == "Branch_Server_12" then
        output_function_Branch_Server_12()
        internal_transition_Branch_Server_12()
    elseif imminent_component == "Branch_Server_13" then
        output_function_Branch_Server_13()
        internal_transition_Branch_Server_13()
    elseif imminent_component == "Branch_Server_14" then
        output_function_Branch_Server_14()
        internal_transition_Branch_Server_14()
    elseif imminent_component == "Branch_Server_15" then
        output_function_Branch_Server_15()
        internal_transition_Branch_Server_15()
    elseif imminent_component == "Branch_Server_16" then
        output_function_Branch_Server_16()
        internal_transition_Branch_Server_16()
    elseif imminent_component == "Branch_Server_17" then
        output_function_Branch_Server_17()
        internal_transition_Branch_Server_17()
    elseif imminent_component == "Branch_Server_18" then
        output_function_Branch_Server_18()
        internal_transition_Branch_Server_18()
    elseif imminent_component == "Branch_Server_19" then
        output_function_Branch_Server_19()
        internal_transition_Branch_Server_19()
    elseif imminent_component == "Branch_Server_20" then
        output_function_Branch_Server_20()
        internal_transition_Branch_Server_20()
    elseif imminent_component == "Joiner" then
        output_function_Joiner()
        internal_transition_Joiner()
    elseif imminent_component == "Sink" then
        output_function_Sink()
        internal_transition_Sink()
    endif

    // Phase 3: Route output to receivers (only if lambda produced output)
    if output_value != "" then
        route_output()
    endif

    // Phase 4: Rebuild event list with updated tn values
    update_event_list()

    // Phase 5: Check stopping condition
    if sim_clocktime >= sim_end_time then
        stopping_condition := true
    endif
endrule

// ============================================================
// Initialization Block
// ============================================================

init:
    service_capacity := 5
    iat_mean := 1.25
    ist_mean := 1.0
    sim_end_time := 10000.0

    future_event_list := []
    initialisation_routine()
endinit

// ============================================================
// Main Rule
// ============================================================

main rule main =
    if not stopping_condition then
        simulator_step()
    else
        skip
    endif
endrule