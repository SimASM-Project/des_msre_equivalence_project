// ============================================================
// Dynamic Function Declarations
// ============================================================

// Event list entry properties
dynamic function cel_component(e: ComponentEvent): Component
dynamic function cel_time(e: ComponentEvent): Real
dynamic function ft_time(e: FinishTime): Real

// ============================================================
// Component Rules (Atomic Model Transitions)
// ============================================================

// Internal transition: delta_int for Generator
rule internal_transition_Generator() =
    if phase_Generator == "active" then
        phase_Generator := "active"
        Generator_job_count := Generator_job_count + 1
    endif

    // Update timing
    tl_Generator := sim_clocktime
    tn_Generator := sim_clocktime + interarrival_time
endrule

// External transition: delta_ext for Generator
rule external_transition_Generator() =
    skip
endrule

// Output function: lambda for Generator
rule output_function_Generator() =
    if phase_Generator == "active" then
        output_value := "out"
    endif
endrule

// Internal transition: delta_int for Forker
rule internal_transition_Forker() =
    if phase_Forker == "forking" then
        phase_Forker := "idle"
    endif

    // Update timing
    tl_Forker := sim_clocktime
    if phase_Forker == "idle" then
        tn_Forker := sim_clocktime + 999999999.0
    else
        tn_Forker := sim_clocktime + 0.0
    endif
endrule

// External transition: delta_ext for Forker
rule external_transition_Forker() =
    if phase_Forker == "idle" then
        phase_Forker := "forking"
        tl_Forker := sim_clocktime
        tn_Forker := sim_clocktime + 0.0
    elseif phase_Forker == "forking" then
        phase_Forker := "forking"
    endif
endrule

// Output function: lambda for Forker
rule output_function_Forker() =
    if phase_Forker == "forking" then
        output_value := "out"
    endif
endrule

// Internal transition: delta_int for Branch_Server_1 (multi-server c=5)
rule internal_transition_Branch_Server_1() =
    if phase_Branch_Server_1 == "starting" then
        phase_Branch_Server_1 := "busy"
        Branch_Server_1_queue_count := Branch_Server_1_queue_count - 1
        Branch_Server_1_server_count := Branch_Server_1_server_count + 1
        let new_finish = new FinishTime
        ft_time(new_finish) := sim_clocktime + service_time_1
        lib.add(Branch_Server_1_finish_list, new_finish)
        if Branch_Server_1_queue_count > 0 and Branch_Server_1_server_count < service_capacity then
            phase_Branch_Server_1 := "starting"
        endif
    elseif phase_Branch_Server_1 == "busy" then
        lib.sort(Branch_Server_1_finish_list, "ft_time")
        let finished = lib.pop(Branch_Server_1_finish_list)
        Branch_Server_1_server_count := Branch_Server_1_server_count - 1
        if Branch_Server_1_queue_count > 0 then
            phase_Branch_Server_1 := "starting"
        elseif Branch_Server_1_server_count == 0 then
            phase_Branch_Server_1 := "passive"
        endif
    endif

    tl_Branch_Server_1 := sim_clocktime
    if phase_Branch_Server_1 == "passive" then
        tn_Branch_Server_1 := sim_clocktime + 999999999.0
    elseif phase_Branch_Server_1 == "starting" then
        tn_Branch_Server_1 := sim_clocktime + 0.0
    else
        lib.sort(Branch_Server_1_finish_list, "ft_time")
        let earliest = lib.get(Branch_Server_1_finish_list, 0)
        tn_Branch_Server_1 := ft_time(earliest)
    endif
endrule

// External transition: delta_ext for Branch_Server_1 (multi-server c=5)
rule external_transition_Branch_Server_1() =
    Branch_Server_1_queue_count := Branch_Server_1_queue_count + 1
    if phase_Branch_Server_1 == "passive" then
        phase_Branch_Server_1 := "starting"
        tl_Branch_Server_1 := sim_clocktime
        tn_Branch_Server_1 := sim_clocktime + 0.0
    elseif phase_Branch_Server_1 == "starting" then
        skip
    elseif phase_Branch_Server_1 == "busy" and Branch_Server_1_server_count < service_capacity then
        phase_Branch_Server_1 := "starting"
        tl_Branch_Server_1 := sim_clocktime
        tn_Branch_Server_1 := sim_clocktime + 0.0
    endif
endrule

// Output function: lambda for Branch_Server_1
rule output_function_Branch_Server_1() =
    if phase_Branch_Server_1 == "busy" then
        output_value := "out"
    endif
endrule

// Internal transition: delta_int for Branch_Server_2 (multi-server c=5)
rule internal_transition_Branch_Server_2() =
    if phase_Branch_Server_2 == "starting" then
        phase_Branch_Server_2 := "busy"
        Branch_Server_2_queue_count := Branch_Server_2_queue_count - 1
        Branch_Server_2_server_count := Branch_Server_2_server_count + 1
        let new_finish = new FinishTime
        ft_time(new_finish) := sim_clocktime + service_time_2
        lib.add(Branch_Server_2_finish_list, new_finish)
        if Branch_Server_2_queue_count > 0 and Branch_Server_2_server_count < service_capacity then
            phase_Branch_Server_2 := "starting"
        endif
    elseif phase_Branch_Server_2 == "busy" then
        lib.sort(Branch_Server_2_finish_list, "ft_time")
        let finished = lib.pop(Branch_Server_2_finish_list)
        Branch_Server_2_server_count := Branch_Server_2_server_count - 1
        if Branch_Server_2_queue_count > 0 then
            phase_Branch_Server_2 := "starting"
        elseif Branch_Server_2_server_count == 0 then
            phase_Branch_Server_2 := "passive"
        endif
    endif

    tl_Branch_Server_2 := sim_clocktime
    if phase_Branch_Server_2 == "passive" then
        tn_Branch_Server_2 := sim_clocktime + 999999999.0
    elseif phase_Branch_Server_2 == "starting" then
        tn_Branch_Server_2 := sim_clocktime + 0.0
    else
        lib.sort(Branch_Server_2_finish_list, "ft_time")
        let earliest = lib.get(Branch_Server_2_finish_list, 0)
        tn_Branch_Server_2 := ft_time(earliest)
    endif
endrule

// External transition: delta_ext for Branch_Server_2 (multi-server c=5)
rule external_transition_Branch_Server_2() =
    Branch_Server_2_queue_count := Branch_Server_2_queue_count + 1
    if phase_Branch_Server_2 == "passive" then
        phase_Branch_Server_2 := "starting"
        tl_Branch_Server_2 := sim_clocktime
        tn_Branch_Server_2 := sim_clocktime + 0.0
    elseif phase_Branch_Server_2 == "starting" then
        skip
    elseif phase_Branch_Server_2 == "busy" and Branch_Server_2_server_count < service_capacity then
        phase_Branch_Server_2 := "starting"
        tl_Branch_Server_2 := sim_clocktime
        tn_Branch_Server_2 := sim_clocktime + 0.0
    endif
endrule

// Output function: lambda for Branch_Server_2
rule output_function_Branch_Server_2() =
    if phase_Branch_Server_2 == "busy" then
        output_value := "out"
    endif
endrule

// Internal transition: delta_int for Branch_Server_3 (multi-server c=5)
rule internal_transition_Branch_Server_3() =
    if phase_Branch_Server_3 == "starting" then
