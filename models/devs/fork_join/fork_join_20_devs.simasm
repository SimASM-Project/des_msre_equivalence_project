    elseif imminent_component == "Branch_Server_17" then
        // Route: Branch_Server_17.out -> Joiner.in_17
        current_input_port := "in_17"
        external_transition_Joiner()
    elseif imminent_component == "Branch_Server_18" then
        // Route: Branch_Server_18.out -> Joiner.in_18
        current_input_port := "in_18"
