    elseif imminent_component == "Branch_Server_19" then
        // Route: Branch_Server_19.out -> Joiner.in_19
        current_input_port := "in_19"
        external_transition_Joiner()
    elseif imminent_component == "Branch_Server_20" then
        // Route: Branch_Server_20.out -> Joiner.in_20
        current_input_port := "in_20"
        external_transition_Joiner()
    elseif imminent_component == "Joiner" then
        // Route: Joiner.out -> Sink.in
        current_input_port := "in"
        external_transition_Sink()
    endif
endrule

// Rebuild event list from current tn values (Select priority order for tie-breaking)
rule update_event_list() =
    future_event_list := []

    let evt_Generator = new ComponentEvent
    cel_component(evt_Generator) := "Generator"
    cel_time(evt_Generator) := tn_Generator
    lib.add(future_event_list, evt_Generator)

    let evt_Forker = new ComponentEvent
    cel_component(evt_Forker) := "Forker"
    cel_time(evt_Forker) := tn_Forker
    lib.add(future_event_list, evt_Forker)

    let evt_Branch_Server_1 = new ComponentEvent
    cel_component(evt_Branch_Server_1) := "Branch_Server_1"
    cel_time(evt_Branch_Server_1) := tn_Branch_Server_1
    lib.add(future_event_list, evt_Branch_Server_1)

    let evt_Branch_Server_2 = new ComponentEvent
    cel_component(evt_Branch_Server_2) := "Branch_Server_2"
    cel_time(evt_Branch_Server_2) := tn_Branch_Server_2
    lib.add(future_event_list, evt_Branch_Server_2)

    let evt_Branch_Server_3 = new ComponentEvent
    cel_component(evt_Branch_Server_3) := "Branch_Server_3"
    cel_time(evt_Branch_Server_3) := tn_Branch_Server_3
    lib.add(future_event_list, evt_Branch_Server_3)

