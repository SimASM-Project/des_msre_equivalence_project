        external_transition_Branch_Server_19()
        // Route: Forker.out -> Branch_Server_20.in
        current_input_port := "in"
        external_transition_Branch_Server_20()
    elseif imminent_component == "Branch_Server_1" then
        // Route: Branch_Server_1.out -> Joiner.in_1
        current_input_port := "in_1"
        external_transition_Joiner()
    elseif imminent_component == "Branch_Server_2" then
        // Route: Branch_Server_2.out -> Joiner.in_2
