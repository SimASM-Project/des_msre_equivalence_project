// SimASM: feedback_7_devs
// Feedback 7-Queue using DEVS formalism - 7 stations in series with probabilistic feedback from station 7 to station 1
// Generated from DEVS specification
// Date: 2026-03-06 21:47:45
// Formalism: Discrete Event System Specification (DEVS)
// Algorithm: Abstract Simulator (Zeigler et al. 2019)

// ============================================================
// Imports
// ============================================================

import Random as rnd
import Stdlib as lib

// ============================================================
// Domains
// ============================================================

// Components: Generator, Server_1, Server_2, Server_3, Server_4, Server_5, Server_6, Server_7, Router, Sink
domain Component

// Phases: active
domain Phase_Generator
// Phases: passive, starting, busy
domain Phase_Server_1
// Phases: passive, starting, busy
domain Phase_Server_2
// Phases: passive, starting, busy
domain Phase_Server_3
// Phases: passive, starting, busy
domain Phase_Server_4
// Phases: passive, starting, busy
domain Phase_Server_5
// Phases: passive, starting, busy
domain Phase_Server_6
// Phases: passive, starting, busy
domain Phase_Server_7
// Phases: idle, routing
domain Phase_Router
// Phases: idle
domain Phase_Sink

domain Object
domain Load <: Object

// Coordinator event type
domain ComponentEvent

// Multi-server finish time tracking
domain FinishTime

// ============================================================
// Constants
// ============================================================

const service_capacity: Nat
const iat_mean: Real
const ist_mean: Real
const feedback_prob: Real
const sim_end_time: Real

// ============================================================
// State Variables
// ============================================================

// Simulation clock
var sim_clocktime: Real

// Per-component phase
var phase_Generator: String
var phase_Server_1: String
var phase_Server_2: String
var phase_Server_3: String
var phase_Server_4: String
var phase_Server_5: String
var phase_Server_6: String
var phase_Server_7: String
var phase_Router: String
var phase_Sink: String

// Per-component timing
var tl_Generator: Real
var tn_Generator: Real
var tl_Server_1: Real
var tn_Server_1: Real
var tl_Server_2: Real
var tn_Server_2: Real
var tl_Server_3: Real
var tn_Server_3: Real
var tl_Server_4: Real
var tn_Server_4: Real
var tl_Server_5: Real
var tn_Server_5: Real
var tl_Server_6: Real
var tn_Server_6: Real
var tl_Server_7: Real
var tn_Server_7: Real
var tl_Router: Real
var tn_Router: Real
var tl_Sink: Real
var tn_Sink: Real

// Per-component state variables
var Generator_job_count: Nat
var Server_1_queue_count: Nat
var Server_1_server_count: Nat
var Server_1_finish_list: List<FinishTime>
var Server_2_queue_count: Nat
var Server_2_server_count: Nat
var Server_2_finish_list: List<FinishTime>
var Server_3_queue_count: Nat
var Server_3_server_count: Nat
var Server_3_finish_list: List<FinishTime>
var Server_4_queue_count: Nat
var Server_4_server_count: Nat
var Server_4_finish_list: List<FinishTime>
var Server_5_queue_count: Nat
var Server_5_server_count: Nat
var Server_5_finish_list: List<FinishTime>
var Server_6_queue_count: Nat
var Server_6_server_count: Nat
var Server_6_finish_list: List<FinishTime>
var Server_7_queue_count: Nat
var Server_7_server_count: Nat
var Server_7_finish_list: List<FinishTime>
var Router_route_decision: Real
var Sink_departure_count: Nat

// Event list (coordinator)
var future_event_list: List<ComponentEvent>

// Coordinator auxiliary variables
var imminent_component: String
var output_value: String
var current_input_port: String
var stopping_condition: Boolean

// ============================================================
// Random Streams
// ============================================================

var interarrival_time: rnd.exponential(iat_mean) as "arrivals"
var service_time_1: rnd.exponential(ist_mean) as "service_1"
var service_time_2: rnd.exponential(ist_mean) as "service_2"
var service_time_3: rnd.exponential(ist_mean) as "service_3"
var service_time_4: rnd.exponential(ist_mean) as "service_4"
var service_time_5: rnd.exponential(ist_mean) as "service_5"
var service_time_6: rnd.exponential(ist_mean) as "service_6"
var service_time_7: rnd.exponential(ist_mean) as "service_7"
var feedback_rng: rnd.uniform(0.0, 1.0) as "feedback"

// ============================================================
// Observables
// ============================================================

derived function queue_count_1(): Real = Server_1_queue_count
derived function server_count_1(): Real = Server_1_server_count
derived function queue_count_2(): Real = Server_2_queue_count
derived function server_count_2(): Real = Server_2_server_count
derived function queue_count_3(): Real = Server_3_queue_count
derived function server_count_3(): Real = Server_3_server_count
derived function queue_count_4(): Real = Server_4_queue_count
derived function server_count_4(): Real = Server_4_server_count
derived function queue_count_5(): Real = Server_5_queue_count
derived function server_count_5(): Real = Server_5_server_count
derived function queue_count_6(): Real = Server_6_queue_count
derived function server_count_6(): Real = Server_6_server_count
derived function queue_count_7(): Real = Server_7_queue_count
derived function server_count_7(): Real = Server_7_server_count
derived function in_system(): Real = Server_1_queue_count + Server_1_server_count + Server_2_queue_count + Server_2_server_count + Server_3_queue_count + Server_3_server_count + Server_4_queue_count + Server_4_server_count + Server_5_queue_count + Server_5_server_count + Server_6_queue_count + Server_6_server_count + Server_7_queue_count + Server_7_server_count
derived function L_q_total(): Real = Server_1_queue_count + Server_2_queue_count + Server_3_queue_count + Server_4_queue_count + Server_5_queue_count + Server_6_queue_count + Server_7_queue_count
derived function departure_count(): Real = Sink_departure_count

// ============================================================
// Dynamic Function Declarations
// ============================================================

// Event list entry properties
dynamic function cel_component(e: ComponentEvent): Component
dynamic function cel_time(e: ComponentEvent): Real
dynamic function ft_time(e: FinishTime): Real

// ============================================================
// Component Rules (Atomic Model Transitions)
// ============================================================

// Internal transition: delta_int for Generator
rule internal_transition_Generator() =
    if phase_Generator == "active" then
        phase_Generator := "active"
        Generator_job_count := Generator_job_count + 1
    endif

    // Update timing
    tl_Generator := sim_clocktime
    tn_Generator := sim_clocktime + interarrival_time
endrule

// External transition: delta_ext for Generator
rule external_transition_Generator() =
    skip
endrule

// Output function: lambda for Generator
rule output_function_Generator() =
    if phase_Generator == "active" then
        output_value := "out"
    endif
endrule

// Internal transition: delta_int for Server_1 (multi-server c=5)
rule internal_transition_Server_1() =
    if phase_Server_1 == "starting" then
        phase_Server_1 := "busy"
        Server_1_queue_count := Server_1_queue_count - 1
        Server_1_server_count := Server_1_server_count + 1
        let new_finish = new FinishTime
        ft_time(new_finish) := sim_clocktime + service_time_1
        lib.add(Server_1_finish_list, new_finish)
        if Server_1_queue_count > 0 and Server_1_server_count < service_capacity then
            phase_Server_1 := "starting"
        endif
    elseif phase_Server_1 == "busy" then
        lib.sort(Server_1_finish_list, "ft_time")
        let finished = lib.pop(Server_1_finish_list)
        Server_1_server_count := Server_1_server_count - 1
        if Server_1_queue_count > 0 then
            phase_Server_1 := "starting"
        elseif Server_1_server_count == 0 then
            phase_Server_1 := "passive"
        endif
    endif

    tl_Server_1 := sim_clocktime
    if phase_Server_1 == "passive" then
        tn_Server_1 := sim_clocktime + 999999999.0
    elseif phase_Server_1 == "starting" then
        tn_Server_1 := sim_clocktime + 0.0
    else
        lib.sort(Server_1_finish_list, "ft_time")
        let earliest = lib.get(Server_1_finish_list, 0)
        tn_Server_1 := ft_time(earliest)
    endif
endrule

// External transition: delta_ext for Server_1 (multi-server c=5)
rule external_transition_Server_1() =
    Server_1_queue_count := Server_1_queue_count + 1
    if phase_Server_1 == "passive" then
        phase_Server_1 := "starting"
        tl_Server_1 := sim_clocktime
        tn_Server_1 := sim_clocktime + 0.0
    elseif phase_Server_1 == "starting" then
        skip
    elseif phase_Server_1 == "busy" and Server_1_server_count < service_capacity then
        phase_Server_1 := "starting"
        tl_Server_1 := sim_clocktime
        tn_Server_1 := sim_clocktime + 0.0
    endif
endrule

// Output function: lambda for Server_1
rule output_function_Server_1() =
    if phase_Server_1 == "busy" then
        output_value := "out"
    endif
endrule

