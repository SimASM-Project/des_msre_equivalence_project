// Internal transition: delta_int for Router
rule internal_transition_Router() =
    if phase_Router == "routing" then
        phase_Router := "idle"
    endif

    // Update timing
    tl_Router := sim_clocktime
    if phase_Router == "idle" then
        tn_Router := sim_clocktime + 999999999.0
    else
        tn_Router := sim_clocktime + 0.0
    endif
endrule

// External transition: delta_ext for Router
rule external_transition_Router() =
    if phase_Router == "idle" then
        phase_Router := "routing"
        Router_route_decision := feedback_rng
        tl_Router := sim_clocktime
        tn_Router := sim_clocktime + 0.0
    elseif phase_Router == "routing" then
        phase_Router := "routing"
        Router_route_decision := feedback_rng
    endif
endrule

// Output function: lambda for Router
rule output_function_Router() =
    if phase_Router == "routing" and Router_route_decision < feedback_prob then
        output_value := "feedback"
    elseif phase_Router == "routing" and Router_route_decision >= feedback_prob then
        output_value := "depart"
    endif
endrule

// Internal transition: delta_int for Sink
rule internal_transition_Sink() =
    skip
endrule

// External transition: delta_ext for Sink
rule external_transition_Sink() =
    if phase_Sink == "idle" then
        phase_Sink := "idle"
        Sink_departure_count := Sink_departure_count + 1
    endif
endrule

// Output function: lambda for Sink
rule output_function_Sink() =
    skip
endrule


// ============================================================
// Coordinator Rules
// ============================================================

// Select imminent component: sort event list, pop earliest (tie-break by Select priority)
rule select_imminent() =
    // Sort event list by scheduled time (stable sort preserves Select priority)
    lib.sort(future_event_list, "cel_time")

    // Pop imminent (earliest) event
    let imminent_event = lib.pop(future_event_list)
    imminent_component := cel_component(imminent_event)

    // Advance clock to event time
    sim_clocktime := cel_time(imminent_event)
endrule

// Route output from imminent component to influenced receivers
rule route_output() =
    if imminent_component == "Generator" then
        // Route: Generator.out -> Server_1.in
        current_input_port := "in"
        external_transition_Server_1()
    elseif imminent_component == "Server_1" then
        // Route: Server_1.out -> Server_2.in
        current_input_port := "in"
        external_transition_Server_2()
    elseif imminent_component == "Server_2" then
        // Route: Server_2.out -> Server_3.in
        current_input_port := "in"
        external_transition_Server_3()
    elseif imminent_component == "Server_3" then
        // Route: Server_3.out -> Server_4.in
        current_input_port := "in"
        external_transition_Server_4()
    elseif imminent_component == "Server_4" then
        // Route: Server_4.out -> Server_5.in
        current_input_port := "in"
        external_transition_Server_5()
    elseif imminent_component == "Server_5" then
        // Route: Server_5.out -> Server_6.in
        current_input_port := "in"
        external_transition_Server_6()
    elseif imminent_component == "Server_6" then
        // Route: Server_6.out -> Server_7.in
        current_input_port := "in"
        external_transition_Server_7()
    elseif imminent_component == "Server_7" then
        // Route: Server_7.out -> Router.in
        current_input_port := "in"
        external_transition_Router()
    elseif imminent_component == "Router" then
        if output_value == "feedback" then
            // Route: Router.feedback -> Server_1.in
            current_input_port := "in"
            external_transition_Server_1()
        elseif output_value == "depart" then
            // Route: Router.depart -> Sink.in
            current_input_port := "in"
            external_transition_Sink()
        endif
    endif
endrule

// Rebuild event list from current tn values (Select priority order for tie-breaking)
rule update_event_list() =
    future_event_list := []

    let evt_Generator = new ComponentEvent
    cel_component(evt_Generator) := "Generator"
    cel_time(evt_Generator) := tn_Generator
    lib.add(future_event_list, evt_Generator)

    let evt_Server_1 = new ComponentEvent
    cel_component(evt_Server_1) := "Server_1"
    cel_time(evt_Server_1) := tn_Server_1
    lib.add(future_event_list, evt_Server_1)

    let evt_Server_2 = new ComponentEvent
    cel_component(evt_Server_2) := "Server_2"
    cel_time(evt_Server_2) := tn_Server_2
    lib.add(future_event_list, evt_Server_2)

    let evt_Server_3 = new ComponentEvent
    cel_component(evt_Server_3) := "Server_3"
    cel_time(evt_Server_3) := tn_Server_3
    lib.add(future_event_list, evt_Server_3)

    let evt_Server_4 = new ComponentEvent
    cel_component(evt_Server_4) := "Server_4"
    cel_time(evt_Server_4) := tn_Server_4
    lib.add(future_event_list, evt_Server_4)

    let evt_Server_5 = new ComponentEvent
    cel_component(evt_Server_5) := "Server_5"
    cel_time(evt_Server_5) := tn_Server_5
    lib.add(future_event_list, evt_Server_5)

    let evt_Server_6 = new ComponentEvent
    cel_component(evt_Server_6) := "Server_6"
    cel_time(evt_Server_6) := tn_Server_6
    lib.add(future_event_list, evt_Server_6)

    let evt_Server_7 = new ComponentEvent
    cel_component(evt_Server_7) := "Server_7"
    cel_time(evt_Server_7) := tn_Server_7
    lib.add(future_event_list, evt_Server_7)

    let evt_Router = new ComponentEvent
    cel_component(evt_Router) := "Router"
    cel_time(evt_Router) := tn_Router
    lib.add(future_event_list, evt_Router)

    let evt_Sink = new ComponentEvent
    cel_component(evt_Sink) := "Sink"
    cel_time(evt_Sink) := tn_Sink
    lib.add(future_event_list, evt_Sink)

endrule

// ============================================================
// Abstract Simulator Algorithm
// ============================================================

// Initialization: send (i, t0) to all component simulators
rule initialisation_routine() =
    sim_clocktime := 0.0

    // Initialize Generator
    phase_Generator := "active"
    tl_Generator := 0.0
    tn_Generator := interarrival_time
    Generator_job_count := 0

    // Initialize Server_1
    phase_Server_1 := "passive"
    tl_Server_1 := 0.0
    tn_Server_1 := 999999999.0
    Server_1_queue_count := 0
    Server_1_server_count := 0
    Server_1_finish_list := []

    // Initialize Server_2
    phase_Server_2 := "passive"
    tl_Server_2 := 0.0
    tn_Server_2 := 999999999.0
    Server_2_queue_count := 0
    Server_2_server_count := 0
    Server_2_finish_list := []

    // Initialize Server_3
    phase_Server_3 := "passive"
    tl_Server_3 := 0.0
    tn_Server_3 := 999999999.0
    Server_3_queue_count := 0
    Server_3_server_count := 0
    Server_3_finish_list := []

    // Initialize Server_4
    phase_Server_4 := "passive"
    tl_Server_4 := 0.0
    tn_Server_4 := 999999999.0
    Server_4_queue_count := 0
    Server_4_server_count := 0
    Server_4_finish_list := []

    // Initialize Server_5
    phase_Server_5 := "passive"
    tl_Server_5 := 0.0
    tn_Server_5 := 999999999.0
    Server_5_queue_count := 0
    Server_5_server_count := 0
    Server_5_finish_list := []

    // Initialize Server_6
    phase_Server_6 := "passive"
    tl_Server_6 := 0.0
    tn_Server_6 := 999999999.0
    Server_6_queue_count := 0
    Server_6_server_count := 0
    Server_6_finish_list := []

    // Initialize Server_7
    phase_Server_7 := "passive"
    tl_Server_7 := 0.0
    tn_Server_7 := 999999999.0
    Server_7_queue_count := 0
    Server_7_server_count := 0
    Server_7_finish_list := []

    // Initialize Router
    phase_Router := "idle"
    tl_Router := 0.0
    tn_Router := 999999999.0
    Router_route_decision := 0.0

    // Initialize Sink
    phase_Sink := "idle"
    tl_Sink := 0.0
    tn_Sink := 999999999.0
    Sink_departure_count := 0

    stopping_condition := false

    // Initialize event list
    future_event_list := []
    let evt_Generator = new ComponentEvent
    cel_component(evt_Generator) := "Generator"
    cel_time(evt_Generator) := tn_Generator
    lib.add(future_event_list, evt_Generator)
    let evt_Server_1 = new ComponentEvent
    cel_component(evt_Server_1) := "Server_1"
    cel_time(evt_Server_1) := tn_Server_1
    lib.add(future_event_list, evt_Server_1)
    let evt_Server_2 = new ComponentEvent
    cel_component(evt_Server_2) := "Server_2"
    cel_time(evt_Server_2) := tn_Server_2
    lib.add(future_event_list, evt_Server_2)
    let evt_Server_3 = new ComponentEvent
    cel_component(evt_Server_3) := "Server_3"
    cel_time(evt_Server_3) := tn_Server_3
    lib.add(future_event_list, evt_Server_3)
    let evt_Server_4 = new ComponentEvent
    cel_component(evt_Server_4) := "Server_4"
    cel_time(evt_Server_4) := tn_Server_4
    lib.add(future_event_list, evt_Server_4)
    let evt_Server_5 = new ComponentEvent
    cel_component(evt_Server_5) := "Server_5"
    cel_time(evt_Server_5) := tn_Server_5
    lib.add(future_event_list, evt_Server_5)
    let evt_Server_6 = new ComponentEvent
    cel_component(evt_Server_6) := "Server_6"
    cel_time(evt_Server_6) := tn_Server_6
    lib.add(future_event_list, evt_Server_6)
    let evt_Server_7 = new ComponentEvent
    cel_component(evt_Server_7) := "Server_7"
    cel_time(evt_Server_7) := tn_Server_7
    lib.add(future_event_list, evt_Server_7)
    let evt_Router = new ComponentEvent
    cel_component(evt_Router) := "Router"
    cel_time(evt_Router) := tn_Router
    lib.add(future_event_list, evt_Router)
    let evt_Sink = new ComponentEvent
    cel_component(evt_Sink) := "Sink"
    cel_time(evt_Sink) := tn_Sink
    lib.add(future_event_list, evt_Sink)
endrule

// One macro-step of the Abstract Simulator
rule simulator_step() =
    // Phase 1: Select imminent and advance time (sort FEL, pop earliest)
    select_imminent()

    // Phase 2: Output function (lambda) then internal transition (delta_int)
    output_value := ""
    if imminent_component == "Generator" then
        output_function_Generator()
        internal_transition_Generator()
    elseif imminent_component == "Server_1" then
        output_function_Server_1()
        internal_transition_Server_1()
    elseif imminent_component == "Server_2" then
        output_function_Server_2()
        internal_transition_Server_2()
    elseif imminent_component == "Server_3" then
        output_function_Server_3()
        internal_transition_Server_3()
    elseif imminent_component == "Server_4" then
        output_function_Server_4()
        internal_transition_Server_4()
    elseif imminent_component == "Server_5" then
        output_function_Server_5()
        internal_transition_Server_5()
    elseif imminent_component == "Server_6" then
        output_function_Server_6()
        internal_transition_Server_6()
    elseif imminent_component == "Server_7" then
        output_function_Server_7()
        internal_transition_Server_7()
    elseif imminent_component == "Router" then
        output_function_Router()
        internal_transition_Router()
    elseif imminent_component == "Sink" then
        output_function_Sink()
        internal_transition_Sink()
    endif

    // Phase 3: Route output to receivers (only if lambda produced output)
    if output_value != "" then
        route_output()
    endif

    // Phase 4: Rebuild event list with updated tn values
    update_event_list()

    // Phase 5: Check stopping condition
    if sim_clocktime >= sim_end_time then
        stopping_condition := true
    endif
endrule

// ============================================================
// Initialization Block
// ============================================================

init:
    service_capacity := 5
    iat_mean := 1.25
    ist_mean := 1.0
    feedback_prob := 0.5
    sim_end_time := 10000.0

    future_event_list := []
    initialisation_routine()
endinit

// ============================================================
// Main Rule
// ============================================================

main rule main =
    if not stopping_condition then
        simulator_step()
    else
        skip
    endif
endrule