// -----------------------------------------------------------------------------
// At-begin: Join
// -----------------------------------------------------------------------------

rule at_begin_action_join() =
    // Consume from P_1
    marking(P_1) := marking(P_1) - 1
    let part_token_1 = lib.pop(tokens(P_1))
    // Consume from P_2
    marking(P_2) := marking(P_2) - 1
    let part_token_2 = lib.pop(tokens(P_2))
    // Consume from P_3
    marking(P_3) := marking(P_3) - 1
    let part_token_3 = lib.pop(tokens(P_3))
    // Consume from P_4
    marking(P_4) := marking(P_4) - 1
    let part_token_4 = lib.pop(tokens(P_4))

    // Schedule BTO-event
    let bto_event = new BTOEvent
    bto_activity(bto_event) := Join
    bto_scheduled_time(bto_event) := sim_clocktime + duration_join
    bto_tokens(bto_event) := [part_token_1, part_token_2, part_token_3, part_token_4]
    lib.add(future_event_list, bto_event)
endrule

// -----------------------------------------------------------------------------
// At-end: Create
// -----------------------------------------------------------------------------

rule at_end_action_create(bound_tokens: List<Token>) =
    // Produce to C
    let creator_token = lib.get(bound_tokens, 0)
    lib.add(tokens(C), creator_token)
    marking(C) := marking(C) + 1
    // Produce to Q_1
    let new_token_0 = new Job
    lib.add(tokens(Q_1), new_token_0)
    marking(Q_1) := marking(Q_1) + 1
    job_id_counter := job_id_counter + 1
endrule

// -----------------------------------------------------------------------------
// At-end: Serve_1
// -----------------------------------------------------------------------------

rule at_end_action_serve_1(bound_tokens: List<Token>) =
    // Produce to S_1
    let server_token = lib.get(bound_tokens, 0)
    lib.add(tokens(S_1), server_token)
    marking(S_1) := marking(S_1) + 1
    // Produce to Q_2
    let job_token = lib.get(bound_tokens, 1)
    lib.add(tokens(Q_2), job_token)
    marking(Q_2) := marking(Q_2) + 1
endrule

// -----------------------------------------------------------------------------
// At-end: Serve_2
// -----------------------------------------------------------------------------

rule at_end_action_serve_2(bound_tokens: List<Token>) =
