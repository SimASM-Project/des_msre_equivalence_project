// =============================================================================
// Activity Cycle Diagram (Fine-Grained) Model: hybrid_2_4_acd - SimASM
// =============================================================================
// Hybrid 2x4-Queue using Activity Cycle Diagram - 2 tandem stations, 4 fork-join branches, feedback p=0.5
// Generated: 2026-02-28 23:34:38

// Fine-grained step semantics for trace equivalence with Event Graph
// One ASM step = start ONE activity OR execute ONE BTO event

// =============================================================================
// IMPORT LIBRARIES
// =============================================================================

import Random as rnd
import Stdlib as lib

// =============================================================================
// DOMAIN DECLARATIONS
// =============================================================================

domain Object

// Passive states (Queues)
domain Queue <: Object

// Active states (Activities)
domain Activity <: Object

// Tokens (entities)
domain Token <: Object
domain Job <: Token
domain Resource <: Token

// Bound-to-occur events
domain BTOEvent <: Object

// =============================================================================
// QUEUE DECLARATIONS (Passive States)
// =============================================================================

const C: Queue  // Creator resource queue
const Q_1: Queue  // Job waiting queue at tandem station 1
const S_1: Queue  // Server resource queue at tandem station 1
const Q_2: Queue  // Job waiting queue at tandem station 2
const S_2: Queue  // Server resource queue at tandem station 2
const Q_fork: Queue  // Pre-fork queue
const BQ_1: Queue  // Job waiting queue at branch 1
const BS_1: Queue  // Server resource queue at branch 1
const P_1: Queue  // Part completion queue at branch 1
const BQ_2: Queue  // Job waiting queue at branch 2
const BS_2: Queue  // Server resource queue at branch 2
const P_2: Queue  // Part completion queue at branch 2
const BQ_3: Queue  // Job waiting queue at branch 3
const BS_3: Queue  // Server resource queue at branch 3
const P_3: Queue  // Part completion queue at branch 3
const BQ_4: Queue  // Job waiting queue at branch 4
const BS_4: Queue  // Server resource queue at branch 4
const P_4: Queue  // Part completion queue at branch 4
const Jobs: Queue  // Completed jobs (sink)

// =============================================================================
// ACTIVITY DECLARATIONS (Active States)
// =============================================================================

const Create: Activity  // Job creation activity
const Serve_1: Activity  // Service activity at tandem station 1
const Serve_2: Activity  // Service activity at tandem station 2
const Fork: Activity  // Fork: distribute job to all branches
const Branch_Serve_1: Activity  // Service activity at branch 1
const Branch_Serve_2: Activity  // Service activity at branch 2
const Branch_Serve_3: Activity  // Service activity at branch 3
const Branch_Serve_4: Activity  // Service activity at branch 4
const Join: Activity  // Join: synchronize all branches (with feedback)

// =============================================================================
// CONSTANT DECLARATIONS
// =============================================================================

const num_servers: Nat  // Number of servers per station
const iat_mean: Real  // Inter-arrival time mean
const ist_mean: Real  // Service time mean per station
const feedback_prob: Real  // Probability of feedback to station 1
const sim_end_time: Real  // Simulation end time

// =============================================================================
// DYNAMIC VARIABLE DECLARATIONS
// =============================================================================

var future_event_list: List<BTOEvent>
var sim_clocktime: Real
var current_bto_event: BTOEvent

// Phase control (fine-grained step semantics)
var current_phase: String
var activity_started: Bool

// Additional state variables
var job_id_counter: Nat
var departure_count: Nat


// =============================================================================
// RANDOM STREAM VARIABLES
// =============================================================================

var duration_create: rnd.exponential(iat_mean) as "arrivals"
var duration_fork: rnd.constant(0) as "fork"
var duration_join: rnd.constant(0) as "join"
var duration_serve_1: rnd.exponential(ist_mean) as "service_1"
var duration_serve_2: rnd.exponential(ist_mean) as "service_2"
var duration_branch_serve_1: rnd.exponential(ist_mean) as "branch_service_1"
var duration_branch_serve_2: rnd.exponential(ist_mean) as "branch_service_2"
var duration_branch_serve_3: rnd.exponential(ist_mean) as "branch_service_3"
var duration_branch_serve_4: rnd.exponential(ist_mean) as "branch_service_4"
var feedback_decision: rnd.uniform(0.0, 1.0) as "feedback"

// =============================================================================
// STATIC FUNCTION DECLARATIONS
// =============================================================================

static function id(t: Token): Nat

// =============================================================================
// DYNAMIC FUNCTION DECLARATIONS
// =============================================================================

// Marking (token counts in queues)
dynamic function marking(q: Queue): Nat
dynamic function tokens(q: Queue): List<Token>

// BTO-Event properties
dynamic function bto_activity(e: BTOEvent): Activity
dynamic function bto_scheduled_time(e: BTOEvent): Real
dynamic function bto_tokens(e: BTOEvent): List<Token>

// Job attributes
dynamic function arrival_time(t: Job): Real
dynamic function service_start_time_1(t: Job): Real
dynamic function service_start_time_2(t: Job): Real
dynamic function fork_time(t: Job): Real
dynamic function branch_start_time_1(t: Job): Real
dynamic function branch_start_time_2(t: Job): Real
dynamic function branch_start_time_3(t: Job): Real
dynamic function branch_start_time_4(t: Job): Real


// =============================================================================
// OBSERVABLE STATE (Derived Functions)
// =============================================================================

derived function queue_count_1(): Nat =
    marking(Q_1)

derived function server_count_1(): Nat =
    num_servers - marking(S_1)

derived function queue_count_2(): Nat =
    marking(Q_2)

derived function server_count_2(): Nat =
    num_servers - marking(S_2)

derived function branch_queue_1(): Bool =
    marking(BQ_1)

derived function branch_server_1(): Bool =
    num_servers - marking(BS_1)

derived function branch_queue_2(): Bool =
    marking(BQ_2)

derived function branch_server_2(): Bool =
    num_servers - marking(BS_2)

derived function branch_queue_3(): Bool =
    marking(BQ_3)

derived function branch_server_3(): Bool =
    num_servers - marking(BS_3)

derived function branch_queue_4(): Bool =
    marking(BQ_4)

derived function branch_server_4(): Bool =
    num_servers - marking(BS_4)

derived function in_system(): Nat =
    marking(Q_1) + (num_servers - marking(S_1)) + marking(Q_2) + (num_servers - marking(S_2)) + marking(BQ_1) + (num_servers - marking(BS_1)) + marking(P_1) + marking(BQ_2) + (num_servers - marking(BS_2)) + marking(P_2) + marking(BQ_3) + (num_servers - marking(BS_3)) + marking(P_3) + marking(BQ_4) + (num_servers - marking(BS_4)) + marking(P_4)

derived function L_q_total(): Bool =
    marking(Q_1) + marking(Q_2) + marking(BQ_1) + marking(BQ_2) + marking(BQ_3) + marking(BQ_4)

derived function departure_count(): Nat =
    departure_count

// At-begin conditions (activity enabling)
derived function at_begin_condition_join(): Bool =
    marking(P_1) >= 1 and marking(P_2) >= 1 and marking(P_3) >= 1 and marking(P_4) >= 1
derived function at_begin_condition_branch_serve_1(): Bool =
    marking(BS_1) >= 1 and marking(BQ_1) >= 1
derived function at_begin_condition_branch_serve_2(): Bool =
    marking(BS_2) >= 1 and marking(BQ_2) >= 1
derived function at_begin_condition_branch_serve_3(): Bool =
    marking(BS_3) >= 1 and marking(BQ_3) >= 1
derived function at_begin_condition_branch_serve_4(): Bool =
    marking(BS_4) >= 1 and marking(BQ_4) >= 1
derived function at_begin_condition_fork(): Bool =
    marking(Q_fork) >= 1
derived function at_begin_condition_serve_1(): Bool =
    marking(S_1) >= 1 and marking(Q_1) >= 1
derived function at_begin_condition_serve_2(): Bool =
    marking(S_2) >= 1 and marking(Q_2) >= 1
derived function at_begin_condition_create(): Bool =
    marking(C) >= 1

// =============================================================================
// RULES (ACD Phases)
// =============================================================================

