    marking(P_4) := marking(P_4) + 1
endrule

// -----------------------------------------------------------------------------
// At-end: Join
// -----------------------------------------------------------------------------

rule at_end_action_join(bound_tokens: List<Token>) =
    // Probabilistic branching (feedback)
    let feedback = feedback_decision < feedback_prob

    if feedback then
        // Produce to Q_1
        let new_token_0 = new Job
        lib.add(tokens(Q_1), new_token_0)
        marking(Q_1) := marking(Q_1) + 1
    endif
    if not feedback then
        // Produce to Jobs
        let new_token_1 = new Job
        lib.add(tokens(Jobs), new_token_1)
        marking(Jobs) := marking(Jobs) + 1
        departure_count := departure_count + 1
    endif
endrule

// -----------------------------------------------------------------------------
// Phase 1: Scanning Phase (Fine-Grained - ONE activity)
// -----------------------------------------------------------------------------

rule scanning_phase_single() =
    activity_started := false

    // Try Join (priority 0)
    if not activity_started and at_begin_condition_join() then
        at_begin_action_join()
        activity_started := true
    endif

    // Try Branch_Serve_1 (priority 1)
    if not activity_started and at_begin_condition_branch_serve_1() then
        at_begin_action_branch_serve_1()
        activity_started := true
    endif

    // Try Branch_Serve_2 (priority 1)
    if not activity_started and at_begin_condition_branch_serve_2() then
        at_begin_action_branch_serve_2()
        activity_started := true
    endif

    // Try Branch_Serve_3 (priority 1)
    if not activity_started and at_begin_condition_branch_serve_3() then
        at_begin_action_branch_serve_3()
        activity_started := true
    endif

    // Try Branch_Serve_4 (priority 1)
    if not activity_started and at_begin_condition_branch_serve_4() then
        at_begin_action_branch_serve_4()
        activity_started := true
    endif

    // Try Fork (priority 2)
    if not activity_started and at_begin_condition_fork() then
        at_begin_action_fork()
        activity_started := true
    endif

    // Try Serve_1 (priority 3)
    if not activity_started and at_begin_condition_serve_1() then
        at_begin_action_serve_1()
        activity_started := true
    endif

    // Try Serve_2 (priority 3)
    if not activity_started and at_begin_condition_serve_2() then
        at_begin_action_serve_2()
        activity_started := true
    endif

    // Try Create (priority 4)
    if not activity_started and at_begin_condition_create() then
        at_begin_action_create()
        activity_started := true
    endif
endrule

// -----------------------------------------------------------------------------
// Phase 2: Timing Phase
// -----------------------------------------------------------------------------

rule timing_phase() =
    // Sort FEL by scheduled time
    lib.sort(future_event_list, "bto_scheduled_time")

    let next_event = lib.pop(future_event_list)

    // Advance clock
    sim_clocktime := bto_scheduled_time(next_event)

    // Execute at-end actions
    executing_phase(next_event)
endrule

// -----------------------------------------------------------------------------
// Phase 3: Executing Phase
// -----------------------------------------------------------------------------

rule executing_phase(bto_event: BTOEvent) =
    let activity = bto_activity(bto_event)
    let bound_tokens = bto_tokens(bto_event)

    if activity == Create then
        at_end_action_create(bound_tokens)
    endif

    if activity == Serve_1 then
        at_end_action_serve_1(bound_tokens)
    endif

    if activity == Serve_2 then
        at_end_action_serve_2(bound_tokens)
    endif

    if activity == Fork then
        at_end_action_fork(bound_tokens)
    endif

    if activity == Branch_Serve_1 then
        at_end_action_branch_serve_1(bound_tokens)
    endif

    if activity == Branch_Serve_2 then
        at_end_action_branch_serve_2(bound_tokens)
    endif

    if activity == Branch_Serve_3 then
        at_end_action_branch_serve_3(bound_tokens)
    endif

    if activity == Branch_Serve_4 then
        at_end_action_branch_serve_4(bound_tokens)
    endif

    if activity == Join then
        at_end_action_join(bound_tokens)
    endif
endrule

// =============================================================================
// INITIAL STATE
// =============================================================================

init:
    // Create queue objects
    C := new Queue
    Q_1 := new Queue
    S_1 := new Queue
    Q_2 := new Queue
    S_2 := new Queue
    Q_fork := new Queue
    BQ_1 := new Queue
    BS_1 := new Queue
    P_1 := new Queue
    BQ_2 := new Queue
    BS_2 := new Queue
    P_2 := new Queue
    BQ_3 := new Queue
    BS_3 := new Queue
    P_3 := new Queue
    BQ_4 := new Queue
    BS_4 := new Queue
    P_4 := new Queue
    Jobs := new Queue

    // Create activity objects
    Create := new Activity
    Serve_1 := new Activity
    Serve_2 := new Activity
    Fork := new Activity
    Branch_Serve_1 := new Activity
    Branch_Serve_2 := new Activity
    Branch_Serve_3 := new Activity
    Branch_Serve_4 := new Activity
    Join := new Activity

    // Parameters
    num_servers := 5
    iat_mean := 1.25
    ist_mean := 1.0
    feedback_prob := 0.5
    sim_end_time := 10000.0

    // Initial markings
    marking(C) := 1
    marking(Q_1) := 0
    marking(S_1) := 5
    marking(Q_2) := 0
    marking(S_2) := 5
    marking(Q_fork) := 0
    marking(BQ_1) := 0
    marking(BS_1) := 5
    marking(P_1) := 0
    marking(BQ_2) := 0
    marking(BS_2) := 5
    marking(P_2) := 0
    marking(BQ_3) := 0
    marking(BS_3) := 5
    marking(P_3) := 0
    marking(BQ_4) := 0
    marking(BS_4) := 5
    marking(P_4) := 0
    marking(Jobs) := 0

    // Initialize token lists
    tokens(C) := []
    tokens(Q_1) := []
    tokens(S_1) := []
    tokens(Q_2) := []
    tokens(S_2) := []
    tokens(Q_fork) := []
    tokens(BQ_1) := []
    tokens(BS_1) := []
    tokens(P_1) := []
    tokens(BQ_2) := []
    tokens(BS_2) := []
    tokens(P_2) := []
    tokens(BQ_3) := []
    tokens(BS_3) := []
    tokens(P_3) := []
    tokens(BQ_4) := []
    tokens(BS_4) := []
    tokens(P_4) := []
    tokens(Jobs) := []

    // Simulation state
    sim_clocktime := 0.0
    future_event_list := []

    // Phase control (fine-grained)
    current_phase := "init"
    activity_started := false

    // Additional state variables
    job_id_counter := 0
    departure_count := 0

endinit

// =============================================================================
// MAIN RULE (Fine-Grained Activity Scanning)
// =============================================================================

main rule main =
    // Phase: init - Initialize and switch to scan
    if current_phase == "init" then
        initialisation_routine()
        current_phase := "scan"
    endif

    // Run while not stopped
    if sim_clocktime < sim_end_time then
        if current_phase == "scan" then
            scanning_phase_single()
            // If no activity started, switch to timing
            if not activity_started then
                current_phase := "time"
            endif
            // If activity started, stay in scan to try more
        else
            // current_phase == "time"
            if lib.length(future_event_list) > 0 then
                timing_phase()
            endif
            current_phase := "scan"
        endif
    endif
endrule
