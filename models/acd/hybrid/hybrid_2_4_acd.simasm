    marking(S_2) := marking(S_2) + 1
    // Produce to Q_fork
    let job_token = lib.get(bound_tokens, 1)
    lib.add(tokens(Q_fork), job_token)
    marking(Q_fork) := marking(Q_fork) + 1
endrule

// -----------------------------------------------------------------------------
// At-end: Fork
// -----------------------------------------------------------------------------

rule at_end_action_fork(bound_tokens: List<Token>) =
    // Produce to BQ_1
    let new_token_0 = new Job
    lib.add(tokens(BQ_1), new_token_0)
    marking(BQ_1) := marking(BQ_1) + 1
    // Produce to BQ_2
    let new_token_1 = new Job
    lib.add(tokens(BQ_2), new_token_1)
    marking(BQ_2) := marking(BQ_2) + 1
    // Produce to BQ_3
    let new_token_2 = new Job
    lib.add(tokens(BQ_3), new_token_2)
    marking(BQ_3) := marking(BQ_3) + 1
    // Produce to BQ_4
    let new_token_3 = new Job
    lib.add(tokens(BQ_4), new_token_3)
    marking(BQ_4) := marking(BQ_4) + 1
endrule

