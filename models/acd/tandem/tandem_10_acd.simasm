    marking(S_2) := marking(S_2) + 1
    // Produce to Q_3
    let job_token = lib.get(bound_tokens, 1)
    lib.add(tokens(Q_3), job_token)
    marking(Q_3) := marking(Q_3) + 1
endrule

// -----------------------------------------------------------------------------
// At-end: Serve_3
// -----------------------------------------------------------------------------

rule at_end_action_serve_3(bound_tokens: List<Token>) =
    // Produce to S_3
    let server_token = lib.get(bound_tokens, 0)
    lib.add(tokens(S_3), server_token)
    marking(S_3) := marking(S_3) + 1
    // Produce to Q_4
    let job_token = lib.get(bound_tokens, 1)
    lib.add(tokens(Q_4), job_token)
    marking(Q_4) := marking(Q_4) + 1
endrule

