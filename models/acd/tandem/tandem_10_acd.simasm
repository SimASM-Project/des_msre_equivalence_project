    marking(S_10) := marking(S_10) + 1
    // Produce to Jobs
    let job_token = lib.get(bound_tokens, 1)
    lib.add(tokens(Jobs), job_token)
    marking(Jobs) := marking(Jobs) + 1
    departure_count := departure_count + 1
endrule

// -----------------------------------------------------------------------------
// Phase 1: Scanning Phase (Fine-Grained - ONE activity)
// -----------------------------------------------------------------------------

rule scanning_phase_single() =
    activity_started := false

    // Try Serve_1 (priority 1)
    if not activity_started and at_begin_condition_serve_1() then
        at_begin_action_serve_1()
        activity_started := true
    endif

    // Try Serve_2 (priority 1)
    if not activity_started and at_begin_condition_serve_2() then
        at_begin_action_serve_2()
        activity_started := true
    endif

    // Try Serve_3 (priority 1)
    if not activity_started and at_begin_condition_serve_3() then
        at_begin_action_serve_3()
        activity_started := true
    endif

    // Try Serve_4 (priority 1)
    if not activity_started and at_begin_condition_serve_4() then
        at_begin_action_serve_4()
        activity_started := true
    endif

    // Try Serve_5 (priority 1)
    if not activity_started and at_begin_condition_serve_5() then
        at_begin_action_serve_5()
        activity_started := true
    endif

    // Try Serve_6 (priority 1)
    if not activity_started and at_begin_condition_serve_6() then
        at_begin_action_serve_6()
        activity_started := true
    endif

    // Try Serve_7 (priority 1)
    if not activity_started and at_begin_condition_serve_7() then
        at_begin_action_serve_7()
        activity_started := true
    endif

    // Try Serve_8 (priority 1)
    if not activity_started and at_begin_condition_serve_8() then
        at_begin_action_serve_8()
        activity_started := true
    endif

    // Try Serve_9 (priority 1)
    if not activity_started and at_begin_condition_serve_9() then
        at_begin_action_serve_9()
        activity_started := true
    endif

    // Try Serve_10 (priority 1)
    if not activity_started and at_begin_condition_serve_10() then
        at_begin_action_serve_10()
        activity_started := true
    endif

    // Try Create (priority 2)
    if not activity_started and at_begin_condition_create() then
        at_begin_action_create()
        activity_started := true
    endif
endrule

// -----------------------------------------------------------------------------
// Phase 2: Timing Phase
// -----------------------------------------------------------------------------

rule timing_phase() =
    // Sort FEL by scheduled time
    lib.sort(future_event_list, "bto_scheduled_time")

    let next_event = lib.pop(future_event_list)

    // Advance clock
    sim_clocktime := bto_scheduled_time(next_event)

    // Execute at-end actions
    executing_phase(next_event)
endrule

// -----------------------------------------------------------------------------
// Phase 3: Executing Phase
// -----------------------------------------------------------------------------

rule executing_phase(bto_event: BTOEvent) =
    let activity = bto_activity(bto_event)
    let bound_tokens = bto_tokens(bto_event)

    if activity == Create then
        at_end_action_create(bound_tokens)
    endif

    if activity == Serve_1 then
        at_end_action_serve_1(bound_tokens)
    endif

    if activity == Serve_2 then
        at_end_action_serve_2(bound_tokens)
    endif

    if activity == Serve_3 then
        at_end_action_serve_3(bound_tokens)
    endif

    if activity == Serve_4 then
        at_end_action_serve_4(bound_tokens)
    endif

    if activity == Serve_5 then
        at_end_action_serve_5(bound_tokens)
    endif

    if activity == Serve_6 then
        at_end_action_serve_6(bound_tokens)
    endif

    if activity == Serve_7 then
        at_end_action_serve_7(bound_tokens)
    endif

    if activity == Serve_8 then
        at_end_action_serve_8(bound_tokens)
    endif

    if activity == Serve_9 then
        at_end_action_serve_9(bound_tokens)
    endif

    if activity == Serve_10 then
        at_end_action_serve_10(bound_tokens)
    endif
endrule

// =============================================================================
// INITIAL STATE
// =============================================================================

init:
    // Create queue objects
    C := new Queue
    Q_1 := new Queue
    S_1 := new Queue
    Q_2 := new Queue
    S_2 := new Queue
    Q_3 := new Queue
    S_3 := new Queue
    Q_4 := new Queue
    S_4 := new Queue
    Q_5 := new Queue
    S_5 := new Queue
    Q_6 := new Queue
    S_6 := new Queue
    Q_7 := new Queue
    S_7 := new Queue
    Q_8 := new Queue
    S_8 := new Queue
    Q_9 := new Queue
    S_9 := new Queue
    Q_10 := new Queue
    S_10 := new Queue
    Jobs := new Queue

    // Create activity objects
    Create := new Activity
    Serve_1 := new Activity
    Serve_2 := new Activity
    Serve_3 := new Activity
    Serve_4 := new Activity
    Serve_5 := new Activity
    Serve_6 := new Activity
    Serve_7 := new Activity
    Serve_8 := new Activity
    Serve_9 := new Activity
    Serve_10 := new Activity

    // Parameters
    num_servers := 5
    iat_mean := 1.25
    ist_mean := 1.0
    sim_end_time := 10000.0

    // Initial markings
    marking(C) := 1
    marking(Q_1) := 0
    marking(S_1) := 5
    marking(Q_2) := 0
    marking(S_2) := 5
    marking(Q_3) := 0
    marking(S_3) := 5
    marking(Q_4) := 0
    marking(S_4) := 5
    marking(Q_5) := 0
    marking(S_5) := 5
    marking(Q_6) := 0
    marking(S_6) := 5
    marking(Q_7) := 0
    marking(S_7) := 5
    marking(Q_8) := 0
    marking(S_8) := 5
    marking(Q_9) := 0
    marking(S_9) := 5
    marking(Q_10) := 0
    marking(S_10) := 5
    marking(Jobs) := 0

    // Initialize token lists
    tokens(C) := []
    tokens(Q_1) := []
    tokens(S_1) := []
    tokens(Q_2) := []
    tokens(S_2) := []
    tokens(Q_3) := []
    tokens(S_3) := []
    tokens(Q_4) := []
    tokens(S_4) := []
    tokens(Q_5) := []
    tokens(S_5) := []
    tokens(Q_6) := []
    tokens(S_6) := []
    tokens(Q_7) := []
    tokens(S_7) := []
    tokens(Q_8) := []
    tokens(S_8) := []
    tokens(Q_9) := []
    tokens(S_9) := []
    tokens(Q_10) := []
    tokens(S_10) := []
    tokens(Jobs) := []

    // Simulation state
    sim_clocktime := 0.0
    future_event_list := []

    // Phase control (fine-grained)
    current_phase := "init"
    activity_started := false

    // Additional state variables
    job_id_counter := 0
    departure_count := 0

endinit

// =============================================================================
// MAIN RULE (Fine-Grained Activity Scanning)
// =============================================================================

main rule main =
    // Phase: init - Initialize and switch to scan
    if current_phase == "init" then
        initialisation_routine()
        current_phase := "scan"
    endif

    // Run while not stopped
    if sim_clocktime < sim_end_time then
        if current_phase == "scan" then
            scanning_phase_single()
            // If no activity started, switch to timing
            if not activity_started then
                current_phase := "time"
            endif
            // If activity started, stay in scan to try more
        else
            // current_phase == "time"
            if lib.length(future_event_list) > 0 then
                timing_phase()
            endif
            current_phase := "scan"
        endif
    endif
endrule
