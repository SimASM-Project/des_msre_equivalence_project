    marking(Q_8)

derived function queue_count_9(): Nat =
    marking(Q_9)

derived function queue_count_10(): Nat =
    marking(Q_10)

derived function server_count_1(): Nat =
    num_servers - marking(S_1)

derived function server_count_2(): Nat =
    num_servers - marking(S_2)

derived function server_count_3(): Nat =
    num_servers - marking(S_3)

derived function server_count_4(): Nat =
    num_servers - marking(S_4)

derived function server_count_5(): Nat =
    num_servers - marking(S_5)

derived function server_count_6(): Nat =
    num_servers - marking(S_6)

derived function server_count_7(): Nat =
    num_servers - marking(S_7)

derived function server_count_8(): Nat =
    num_servers - marking(S_8)

derived function server_count_9(): Nat =
    num_servers - marking(S_9)

derived function server_count_10(): Nat =
    num_servers - marking(S_10)

derived function in_system(): Nat =
    marking(Q_1) + (num_servers - marking(S_1)) + marking(Q_2) + (num_servers - marking(S_2)) + marking(Q_3) + (num_servers - marking(S_3)) + marking(Q_4) + (num_servers - marking(S_4)) + marking(Q_5) + (num_servers - marking(S_5)) + marking(Q_6) + (num_servers - marking(S_6)) + marking(Q_7) + (num_servers - marking(S_7)) + marking(Q_8) + (num_servers - marking(S_8)) + marking(Q_9) + (num_servers - marking(S_9)) + marking(Q_10) + (num_servers - marking(S_10))

// At-begin conditions (activity enabling)
derived function at_begin_condition_serve_1(): Bool =
    marking(S_1) >= 1 and marking(Q_1) >= 1
derived function at_begin_condition_serve_2(): Bool =
    marking(S_2) >= 1 and marking(Q_2) >= 1
derived function at_begin_condition_serve_3(): Bool =
    marking(S_3) >= 1 and marking(Q_3) >= 1
derived function at_begin_condition_serve_4(): Bool =
    marking(S_4) >= 1 and marking(Q_4) >= 1
derived function at_begin_condition_serve_5(): Bool =
    marking(S_5) >= 1 and marking(Q_5) >= 1
derived function at_begin_condition_serve_6(): Bool =
    marking(S_6) >= 1 and marking(Q_6) >= 1
derived function at_begin_condition_serve_7(): Bool =
    marking(S_7) >= 1 and marking(Q_7) >= 1
derived function at_begin_condition_serve_8(): Bool =
    marking(S_8) >= 1 and marking(Q_8) >= 1
derived function at_begin_condition_serve_9(): Bool =
    marking(S_9) >= 1 and marking(Q_9) >= 1
derived function at_begin_condition_serve_10(): Bool =
    marking(S_10) >= 1 and marking(Q_10) >= 1
derived function at_begin_condition_create(): Bool =
    marking(C) >= 1

