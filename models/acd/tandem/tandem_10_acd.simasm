// -----------------------------------------------------------------------------
// At-begin: Create
// -----------------------------------------------------------------------------

rule at_begin_action_create() =
    // Consume from C
    marking(C) := marking(C) - 1
    let creator_token = lib.pop(tokens(C))

    // Schedule BTO-event
    let bto_event = new BTOEvent
    bto_activity(bto_event) := Create
    bto_scheduled_time(bto_event) := sim_clocktime + duration_create
    bto_tokens(bto_event) := [creator_token]
    lib.add(future_event_list, bto_event)
endrule

// -----------------------------------------------------------------------------
// At-begin: Serve_1
// -----------------------------------------------------------------------------

rule at_begin_action_serve_1() =
    // Consume from S_1
    marking(S_1) := marking(S_1) - 1
    let server_token = lib.pop(tokens(S_1))
    // Consume from Q_1
    marking(Q_1) := marking(Q_1) - 1
    let job_token = lib.pop(tokens(Q_1))

    service_start_time_1(job_token) := sim_clocktime
    // Schedule BTO-event
    let bto_event = new BTOEvent
    bto_activity(bto_event) := Serve_1
    bto_scheduled_time(bto_event) := sim_clocktime + duration_serve_1
    bto_tokens(bto_event) := [server_token, job_token]
    lib.add(future_event_list, bto_event)
endrule

