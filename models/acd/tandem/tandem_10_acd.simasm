// =============================================================================
// Activity Cycle Diagram (Fine-Grained) Model: tandem_10_acd - SimASM
// =============================================================================
// Tandem 10-Queue using Activity Cycle Diagram - 10 stations in series
// Generated: 2026-01-28 15:00:17

// Fine-grained step semantics for trace equivalence with Event Graph
// One ASM step = start ONE activity OR execute ONE BTO event

// =============================================================================
// IMPORT LIBRARIES
// =============================================================================

import Random as rnd
import Stdlib as lib

// =============================================================================
// DOMAIN DECLARATIONS
// =============================================================================

domain Object

// Passive states (Queues)
domain Queue <: Object

// Active states (Activities)
domain Activity <: Object

// Tokens (entities)
domain Token <: Object
domain Job <: Token
domain Resource <: Token

// Bound-to-occur events
domain BTOEvent <: Object

// =============================================================================
// QUEUE DECLARATIONS (Passive States)
// =============================================================================

const C: Queue  // Creator resource queue
const Q_1: Queue  // Q_1 queue
const S_1: Queue  // S_1 queue
const Q_2: Queue  // Q_2 queue
const S_2: Queue  // S_2 queue
const Q_3: Queue  // Q_3 queue
const S_3: Queue  // S_3 queue
const Q_4: Queue  // Q_4 queue
const S_4: Queue  // S_4 queue
const Q_5: Queue  // Q_5 queue
const S_5: Queue  // S_5 queue
const Q_6: Queue  // Q_6 queue
const S_6: Queue  // S_6 queue
const Q_7: Queue  // Q_7 queue
const S_7: Queue  // S_7 queue
const Q_8: Queue  // Q_8 queue
const S_8: Queue  // S_8 queue
const Q_9: Queue  // Q_9 queue
const S_9: Queue  // S_9 queue
const Q_10: Queue  // Q_10 queue
const S_10: Queue  // S_10 queue
const Jobs: Queue  // Completed jobs (sink)

// =============================================================================
// ACTIVITY DECLARATIONS (Active States)
// =============================================================================

const Create: Activity  // Job creation activity
const Serve_1: Activity  // Serve_1 activity
const Serve_2: Activity  // Serve_2 activity
const Serve_3: Activity  // Serve_3 activity
const Serve_4: Activity  // Serve_4 activity
const Serve_5: Activity  // Serve_5 activity
const Serve_6: Activity  // Serve_6 activity
const Serve_7: Activity  // Serve_7 activity
const Serve_8: Activity  // Serve_8 activity
const Serve_9: Activity  // Serve_9 activity
const Serve_10: Activity  // Serve_10 activity

// =============================================================================
// CONSTANT DECLARATIONS
// =============================================================================

const num_servers: Nat  // Number of servers per station
const iat_mean: Real  // Inter-arrival time mean
const ist_mean: Real  // Service time mean per station
const sim_end_time: Real  // Simulation end time

// =============================================================================
// DYNAMIC VARIABLE DECLARATIONS
// =============================================================================

var future_event_list: List<BTOEvent>
var sim_clocktime: Real
var current_bto_event: BTOEvent

// Phase control (fine-grained step semantics)
var current_phase: String
var activity_started: Bool

// Additional state variables
var job_id_counter: Nat
var departure_count: Nat


// =============================================================================
// RANDOM STREAM VARIABLES
// =============================================================================

var duration_create: rnd.exponential(iat_mean) as "arrivals"
var duration_serve_1: rnd.exponential(ist_mean) as "service_1"
var duration_serve_2: rnd.exponential(ist_mean) as "service_2"
var duration_serve_3: rnd.exponential(ist_mean) as "service_3"
var duration_serve_4: rnd.exponential(ist_mean) as "service_4"
var duration_serve_5: rnd.exponential(ist_mean) as "service_5"
var duration_serve_6: rnd.exponential(ist_mean) as "service_6"
var duration_serve_7: rnd.exponential(ist_mean) as "service_7"
var duration_serve_8: rnd.exponential(ist_mean) as "service_8"
var duration_serve_9: rnd.exponential(ist_mean) as "service_9"
var duration_serve_10: rnd.exponential(ist_mean) as "service_10"

// =============================================================================
// STATIC FUNCTION DECLARATIONS
// =============================================================================

static function id(t: Token): Nat

// =============================================================================
// DYNAMIC FUNCTION DECLARATIONS
// =============================================================================

// Marking (token counts in queues)
dynamic function marking(q: Queue): Nat
dynamic function tokens(q: Queue): List<Token>

// BTO-Event properties
dynamic function bto_activity(e: BTOEvent): Activity
dynamic function bto_scheduled_time(e: BTOEvent): Real
dynamic function bto_tokens(e: BTOEvent): List<Token>

// Job attributes
dynamic function arrival_time(t: Job): Real
dynamic function service_start_time_1(t: Job): Real
dynamic function service_start_time_2(t: Job): Real
dynamic function service_start_time_3(t: Job): Real
dynamic function service_start_time_4(t: Job): Real
dynamic function service_start_time_5(t: Job): Real
dynamic function service_start_time_6(t: Job): Real
dynamic function service_start_time_7(t: Job): Real
dynamic function service_start_time_8(t: Job): Real
dynamic function service_start_time_9(t: Job): Real
dynamic function service_start_time_10(t: Job): Real


// =============================================================================
// OBSERVABLE STATE (Derived Functions)
// =============================================================================

derived function queue_count_1(): Nat =
    marking(Q_1)

derived function queue_count_2(): Nat =
    marking(Q_2)

derived function queue_count_3(): Nat =
    marking(Q_3)

derived function queue_count_4(): Nat =
