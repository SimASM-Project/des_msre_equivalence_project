rule at_end_action_join(bound_tokens: List<Token>) =
    // Produce to Jobs
    let new_token_0 = new Job
    lib.add(tokens(Jobs), new_token_0)
    marking(Jobs) := marking(Jobs) + 1
    departure_count := departure_count + 1
endrule

// -----------------------------------------------------------------------------
// Phase 1: Scanning Phase (Fine-Grained - ONE activity)
// -----------------------------------------------------------------------------

rule scanning_phase_single() =
    activity_started := false

    // Try Join (priority 0)
    if not activity_started and at_begin_condition_join() then
        at_begin_action_join()
        activity_started := true
    endif

    // Try Serve_1 (priority 1)
    if not activity_started and at_begin_condition_serve_1() then
        at_begin_action_serve_1()
        activity_started := true
    endif

    // Try Serve_2 (priority 1)
    if not activity_started and at_begin_condition_serve_2() then
        at_begin_action_serve_2()
        activity_started := true
    endif

    // Try Serve_3 (priority 1)
    if not activity_started and at_begin_condition_serve_3() then
        at_begin_action_serve_3()
        activity_started := true
    endif

    // Try Serve_4 (priority 1)
    if not activity_started and at_begin_condition_serve_4() then
        at_begin_action_serve_4()
        activity_started := true
    endif

    // Try Serve_5 (priority 1)
    if not activity_started and at_begin_condition_serve_5() then
        at_begin_action_serve_5()
        activity_started := true
    endif

    // Try Serve_6 (priority 1)
    if not activity_started and at_begin_condition_serve_6() then
        at_begin_action_serve_6()
        activity_started := true
    endif

    // Try Serve_7 (priority 1)
    if not activity_started and at_begin_condition_serve_7() then
        at_begin_action_serve_7()
        activity_started := true
    endif

    // Try Serve_8 (priority 1)
    if not activity_started and at_begin_condition_serve_8() then
        at_begin_action_serve_8()
        activity_started := true
    endif

    // Try Serve_9 (priority 1)
    if not activity_started and at_begin_condition_serve_9() then
        at_begin_action_serve_9()
        activity_started := true
    endif

    // Try Serve_10 (priority 1)
    if not activity_started and at_begin_condition_serve_10() then
        at_begin_action_serve_10()
        activity_started := true
    endif

    // Try Serve_11 (priority 1)
    if not activity_started and at_begin_condition_serve_11() then
        at_begin_action_serve_11()
        activity_started := true
    endif

    // Try Serve_12 (priority 1)
    if not activity_started and at_begin_condition_serve_12() then
        at_begin_action_serve_12()
        activity_started := true
    endif

    // Try Serve_13 (priority 1)
    if not activity_started and at_begin_condition_serve_13() then
        at_begin_action_serve_13()
        activity_started := true
    endif

    // Try Serve_14 (priority 1)
    if not activity_started and at_begin_condition_serve_14() then
        at_begin_action_serve_14()
        activity_started := true
    endif

    // Try Serve_15 (priority 1)
    if not activity_started and at_begin_condition_serve_15() then
        at_begin_action_serve_15()
        activity_started := true
    endif

    // Try Serve_16 (priority 1)
    if not activity_started and at_begin_condition_serve_16() then
        at_begin_action_serve_16()
        activity_started := true
    endif

    // Try Serve_17 (priority 1)
    if not activity_started and at_begin_condition_serve_17() then
        at_begin_action_serve_17()
        activity_started := true
    endif

    // Try Serve_18 (priority 1)
    if not activity_started and at_begin_condition_serve_18() then
        at_begin_action_serve_18()
        activity_started := true
    endif

    // Try Serve_19 (priority 1)
    if not activity_started and at_begin_condition_serve_19() then
        at_begin_action_serve_19()
        activity_started := true
    endif

    // Try Serve_20 (priority 1)
    if not activity_started and at_begin_condition_serve_20() then
        at_begin_action_serve_20()
        activity_started := true
    endif

    // Try Fork (priority 2)
    if not activity_started and at_begin_condition_fork() then
        at_begin_action_fork()
        activity_started := true
    endif

    // Try Create (priority 3)
    if not activity_started and at_begin_condition_create() then
        at_begin_action_create()
        activity_started := true
    endif
endrule

// -----------------------------------------------------------------------------
// Phase 2: Timing Phase
// -----------------------------------------------------------------------------

rule timing_phase() =
    // Sort FEL by scheduled time
    lib.sort(future_event_list, "bto_scheduled_time")

    let next_event = lib.pop(future_event_list)

    // Advance clock
    sim_clocktime := bto_scheduled_time(next_event)

    // Execute at-end actions
    executing_phase(next_event)
endrule

// -----------------------------------------------------------------------------
// Phase 3: Executing Phase
// -----------------------------------------------------------------------------

rule executing_phase(bto_event: BTOEvent) =
    let activity = bto_activity(bto_event)
    let bound_tokens = bto_tokens(bto_event)

    if activity == Create then
        at_end_action_create(bound_tokens)
    endif

    if activity == Fork then
        at_end_action_fork(bound_tokens)
    endif

    if activity == Serve_1 then
        at_end_action_serve_1(bound_tokens)
    endif

    if activity == Serve_2 then
        at_end_action_serve_2(bound_tokens)
    endif

    if activity == Serve_3 then
        at_end_action_serve_3(bound_tokens)
    endif

    if activity == Serve_4 then
        at_end_action_serve_4(bound_tokens)
    endif

    if activity == Serve_5 then
        at_end_action_serve_5(bound_tokens)
    endif

    if activity == Serve_6 then
        at_end_action_serve_6(bound_tokens)
    endif

    if activity == Serve_7 then
        at_end_action_serve_7(bound_tokens)
    endif

    if activity == Serve_8 then
        at_end_action_serve_8(bound_tokens)
    endif

    if activity == Serve_9 then
        at_end_action_serve_9(bound_tokens)
    endif

    if activity == Serve_10 then
        at_end_action_serve_10(bound_tokens)
    endif

    if activity == Serve_11 then
        at_end_action_serve_11(bound_tokens)
    endif

    if activity == Serve_12 then
        at_end_action_serve_12(bound_tokens)
    endif

    if activity == Serve_13 then
        at_end_action_serve_13(bound_tokens)
    endif

    if activity == Serve_14 then
        at_end_action_serve_14(bound_tokens)
    endif

    if activity == Serve_15 then
        at_end_action_serve_15(bound_tokens)
    endif

    if activity == Serve_16 then
        at_end_action_serve_16(bound_tokens)
    endif

    if activity == Serve_17 then
        at_end_action_serve_17(bound_tokens)
    endif

    if activity == Serve_18 then
        at_end_action_serve_18(bound_tokens)
    endif

    if activity == Serve_19 then
        at_end_action_serve_19(bound_tokens)
    endif

    if activity == Serve_20 then
        at_end_action_serve_20(bound_tokens)
    endif

    if activity == Join then
        at_end_action_join(bound_tokens)
    endif
endrule

// =============================================================================
// INITIAL STATE
// =============================================================================

init:
    // Create queue objects
    C := new Queue
    Q_fork := new Queue
    Q_1 := new Queue
    S_1 := new Queue
    P_1 := new Queue
    Q_2 := new Queue
    S_2 := new Queue
    P_2 := new Queue
    Q_3 := new Queue
    S_3 := new Queue
    P_3 := new Queue
    Q_4 := new Queue
