    // Consume from P_10
    marking(P_10) := marking(P_10) - 1
    let part_token_10 = lib.pop(tokens(P_10))
    // Consume from P_11
    marking(P_11) := marking(P_11) - 1
    let part_token_11 = lib.pop(tokens(P_11))
    // Consume from P_12
    marking(P_12) := marking(P_12) - 1
    let part_token_12 = lib.pop(tokens(P_12))
    // Consume from P_13
    marking(P_13) := marking(P_13) - 1
    let part_token_13 = lib.pop(tokens(P_13))
    // Consume from P_14
    marking(P_14) := marking(P_14) - 1
    let part_token_14 = lib.pop(tokens(P_14))
    // Consume from P_15
    marking(P_15) := marking(P_15) - 1
    let part_token_15 = lib.pop(tokens(P_15))
    // Consume from P_16
    marking(P_16) := marking(P_16) - 1
    let part_token_16 = lib.pop(tokens(P_16))
    // Consume from P_17
    marking(P_17) := marking(P_17) - 1
    let part_token_17 = lib.pop(tokens(P_17))
    // Consume from P_18
    marking(P_18) := marking(P_18) - 1
    let part_token_18 = lib.pop(tokens(P_18))
    // Consume from P_19
    marking(P_19) := marking(P_19) - 1
    let part_token_19 = lib.pop(tokens(P_19))
    // Consume from P_20
    marking(P_20) := marking(P_20) - 1
    let part_token_20 = lib.pop(tokens(P_20))

    // Schedule BTO-event
    let bto_event = new BTOEvent
    bto_activity(bto_event) := Join
    bto_scheduled_time(bto_event) := sim_clocktime + duration_join
    bto_tokens(bto_event) := [part_token_1, part_token_2, part_token_3, part_token_4, part_token_5, part_token_6, part_token_7, part_token_8, part_token_9, part_token_10, part_token_11, part_token_12, part_token_13, part_token_14, part_token_15, part_token_16, part_token_17, part_token_18, part_token_19, part_token_20]
    lib.add(future_event_list, bto_event)
endrule

// -----------------------------------------------------------------------------
// At-end: Create
// -----------------------------------------------------------------------------

rule at_end_action_create(bound_tokens: List<Token>) =
    // Produce to C
    let creator_token = lib.get(bound_tokens, 0)
    lib.add(tokens(C), creator_token)
    marking(C) := marking(C) + 1
    // Produce to Q_fork
    let new_token_0 = new Job
    lib.add(tokens(Q_fork), new_token_0)
    marking(Q_fork) := marking(Q_fork) + 1
    job_id_counter := job_id_counter + 1
endrule

